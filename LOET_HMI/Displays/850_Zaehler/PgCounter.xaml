<Page xmlns:UserControls="clr-namespace:LOET_HMI.UserControls"  x:Class="LOET_HMI.Displays.PgCounter"
      x:Name="PgCount"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      Title="PgCounter"
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded"
      >
<!--HEINRICH-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition  />
            <ColumnDefinition  />
            <ColumnDefinition  />
            <ColumnDefinition  />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Allgemein" Grid.Row="0" Grid.Column="0"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >
            <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                <UserControls:UcCounter DpCounterHMI="{Binding ElementName=PgCount, Path=CounterList[0] }" Margin="0,20,0,0" />
                <UserControls:UcCounter DpCounterHMI="{Binding ElementName=PgCount, Path=CounterList[1] }" Margin="0,20,0,0" />
                <UserControls:UcCounter DpCounterHMI="{Binding ElementName=PgCount, Path=CounterList[2] }" Margin="0,20,0,0"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Modul 1" Grid.Row="0" Grid.Column="1"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >
        </GroupBox>

        <GroupBox Header="Modul 2" Grid.Row="0" Grid.Column="2"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >
        </GroupBox>


        <GroupBox Header="Modul 3" Grid.Row="0" Grid.Column="3"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >
        </GroupBox>

    </Grid>
</Page>
