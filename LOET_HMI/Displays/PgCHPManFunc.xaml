<Page x:Class="LOET_HMI.Displays.PgCHPManFunc"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      mc:Ignorable="d" 
      
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      x:Name="pgStat"
      xmlns:UCs="clr-namespace:LOET_HMI.UserControls"
      Loaded="PgStat_Loaded" Unloaded="PgStat_Unloaded"
      
      Title="PgSt050">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/LOET_HMI;component/Resources/ZF Aufnahme.jpg" Stretch="UniformToFill"/>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UCs:UcBeckhoffAxis PLCToHMI="{Binding ElementName=pgStat, Path=DpAxis}"   Margin="510,22,20,0"  Grid.RowSpan="2" Grid.Column="1" VerticalAlignment="Top" Grid.ColumnSpan="2"/>

        <!--<StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" >-->
        <UCs:UcCylinder  DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[2]}" Margin="21,72,259,159" />
        <UCs:UcCylinder  DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[3]}" Margin="176,164,104,67" Grid.Row="1"/>
        <UCs:UcCylinder  DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[4]}" Margin="180,193,55,38" Grid.Row="1" Grid.Column="2"/>
        <!--</StackPanel>-->

        <!--<StackPanel Orientation="Horizontal"  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Center">-->
        <UCs:UcCylinder  DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[0]}" Margin="462,28,353,203" Grid.ColumnSpan="2"/>
        <UCs:UcCylinder  DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[1]}" Margin="125,215,110,16" Grid.Column="1"/>
        <!--</StackPanel>-->

    </Grid>
</Page>
