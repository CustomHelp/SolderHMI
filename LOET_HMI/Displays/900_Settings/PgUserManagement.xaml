<Page x:Class="LOET_HMI.PgUserManagement"
      x:Name="SettUserAdmin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI"
      mc:Ignorable="d" 
      d:DesignHeight="830" d:DesignWidth="1650"
      Title="SettUserAdmin"
      xmlns:prop="clr-namespace:LOET_HMI.Properties"
      
      >
    <Page.Resources>
        <CollectionViewSource x:Key="itemCollectionViewSource" CollectionViewType="ListCollectionView"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="123*"/>
            <ColumnDefinition Width="152*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <GroupBox Header="{x:Static prop:Resources.UserAdmin_gbHeader}" Grid.Column="0"   Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Grid.Row="0" Grid.Column="0" Width="180" >

                    <Button x:Name="BtnNew"    Content="{x:Static prop:Resources.UserAdmin_btnNewUser}"    Click="BtnNew_Click"     Style="{StaticResource RENADataGridButtons}"    />
                    <Button x:Name="BtnChange" Content="{x:Static prop:Resources.UserAdmin_btnEdituser}"   Click="BtnChange_Click"  Style="{StaticResource RENADataGridButtons}"   />
                    <Button x:Name="BtnDelete" Content="{x:Static prop:Resources.UserAdmin_btnDeleteUser}" Click="BtnDelete_Click"  Style="{StaticResource RENADataGridButtons}"    />
                </StackPanel>


                <DataGrid x:Name="dG" Style="{StaticResource RENADataGridStyle}"  Grid.Column="1"  VerticalAlignment="Stretch"   HorizontalAlignment="Left" Margin="20,0,0,0"

                            IsReadOnly="True"                   
                            ItemsSource="{Binding}" 
                            DataContext="{StaticResource itemCollectionViewSource}" 
                            
                            AutoGenerateColumns="False" 
                            CanUserAddRows="False" 
                            EnableRowVirtualization="True" 
                            RowDetailsVisibilityMode="VisibleWhenSelected" 
                            SelectedCellsChanged="DG_SelectedCellsChanged"            
                          >

                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="ColName"    Binding="{Binding sUserName}"      Header="Name" IsReadOnly="True" Width="*"/>
                        <!-- 
                        <DataGridTextColumn x:Name="ColLvel" Binding="{Binding sUserLevel}" Header="Level" IsReadOnly="True" Width="*"/>
                        -->
                        <DataGridTextColumn x:Name="ColLvelName" Binding="{Binding sUserLevelName}" Header="{x:Static prop:Resources.UserAdmin_dgheaderUserlevel}"  IsReadOnly="True" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>










    </Grid>
</Page>
