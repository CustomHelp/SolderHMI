<Page x:Class="LOET_HMI.Displays._999_Project._10_Station.PgSt10_ManFunc"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays._999_Project._10_Station"
      xmlns:usercontrols="clr-namespace:LOET_HMI.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      Loaded="PgStat_Loaded" Unloaded="PgStat_Unloaded"
      x:Name="pgStat"
      Title="PgSt10_ManFunc">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24*"/>
            <ColumnDefinition Width="251*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="/LOET_HMI;component/Images/Handmenu_ST10.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <usercontrols:UcCylinder x:Name="cylElem1" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[0]}" Margin="363.418,632,843,10" Style="{DynamicResource CHPUserControl}" Grid.Column="1"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem2" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[1]}" Margin="58.418,632,1148,10" Style="{DynamicResource CHPUserControl}" Grid.Column="1"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem3" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[2]}" Margin="10,410,1340,232" Style="{DynamicResource CHPUserControl}" Grid.ColumnSpan="2"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem4" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[3]}" Margin="313,10,893,632" Style="{DynamicResource CHPUserControl}" Grid.Column="1"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem5" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[4]}" Margin="313,195,893,447" Style="{DynamicResource CHPUserControl}" Grid.Column="1"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem6" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[5]}" Margin="1196.418,632,10,10" Style="{DynamicResource CHPUserControl}" Grid.Column="1"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem7" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[6]}" Margin="1033.418,144,173,498" Style="{DynamicResource CHPUserControl}" Grid.Column="1"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem8" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[7]}" Margin="10,10,1340,632" Style="{DynamicResource CHPUserControl}" Grid.ColumnSpan="2"></usercontrols:UcCylinder>
        <usercontrols:UcCylinder x:Name="cylElem9" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[8]}" Margin="10,195,1340,447" Style="{DynamicResource CHPUserControl}" Grid.ColumnSpan="2"/>

        <Button x:Name="resetMeasuremet" Click="ResetMeasuremet_Click" Style="{StaticResource noHoverStyleNoImage}" Content="Reset Festo Measurement" Width="300" Height="100" FontSize="18" 
                FontWeight="Bold" Background="Orange" Foreground="White" Margin="1033.418,329,173,393" Grid.Column="1"/>
    </Grid>
</Page>
