<Page x:Class="LOET_HMI.Displays.PgRFID_IND"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      mc:Ignorable="d" 
      
      xmlns:UserControls="clr-namespace:LOET_HMI.UserControls"
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      Loaded="PgRFID_IND_Loaded" Unloaded="PgRFID_IND_Unloaded"
      
      Title="PgRFID_IND">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="Col0" Width="735" />
            <ColumnDefinition x:Name="Col1" Width="50" />
            <ColumnDefinition x:Name="Col2" Width="{Binding ElementName=Col0, Path=Width}" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Read" Grid.Column="0"
                  Width="{Binding ElementName=Col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >
            <UserControls:UcRFID_IND x:Name="UcRFID_IND_Read" RFIDMode="Read" />
        </GroupBox>

        <GroupBox Header="Write" Grid.Column="2"
                  Width="{Binding ElementName=Col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >
            <UserControls:UcRFID_IND x:Name="UcRFID_IND_Write" RFIDMode="Write" />
        </GroupBox>

    </Grid>
</Page>
