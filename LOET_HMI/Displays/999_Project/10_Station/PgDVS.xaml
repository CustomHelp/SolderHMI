<Page xmlns:LOET_HMI="clr-namespace:LOET_HMI"  x:Class="LOET_HMI.Displays.PgDVS"
      
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      mc:Ignorable="d" 
      
      d:DesignHeight="5000" d:DesignWidth="{StaticResource frameWidth}"
      xmlns:UCs="clr-namespace:LOET_HMI.UserControls"
      x:Name="PageDVS"
      Loaded="PageDVS_Loaded" Unloaded="PageDVS_Unloaded"
      
      Height="auto"
      Title="PgDVS">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Visible"  >
            <Grid Height="auto"  >
                <Grid.RowDefinitions>
                    <RowDefinition Height="850"  />
                    <RowDefinition Height="auto"  />
                    <RowDefinition Height="auto"  />
                </Grid.RowDefinitions>
                <!-- *************************************************************** -->
                <!-- **************************** Row 0 **************************** -->
                <!-- *************************************************************** -->

                <Rectangle  Grid.Row="0" >
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/Drahtvorschub_V2.jpg"  Stretch="UniformToFill"/>
                    </Rectangle.Fill>
                </Rectangle>

                <UCs:UcBeckhoffAxis Margin="38,220,1055,195" PLCToHMI="{Binding ElementName=PageDVS, Path=DpAxis}"  />

                <StackPanel Width="Auto" Height="Auto" Margin="454,755,1002,10">
                    <LOET_HMI:UcValue 
                              sName="{Binding DpEncoder.sName, ElementName=PageDVS}" 
                              sValue="{Binding DpEncoder.lrPosAct, ElementName=PageDVS}" 
                              sUnit="{Binding DpEncoder.sUnit, ElementName=PageDVS}"/>

                </StackPanel>



                <!-- *************************************************************** -->
                <!-- **************************** Row 1 **************************** -->
                <!-- *************************************************************** -->
                <Rectangle  Grid.Row="1" Margin="-50,50,-80,0" Height="1800">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/Explosionszeichnung9B.png"  Stretch="Uniform"/>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- *************************************************************** -->
                <!-- **************************** Row 2 **************************** -->
                <!-- *************************************************************** -->
                <Rectangle  Grid.Row="2" Margin="0,0,0,0" Height="750">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/Stückliste.PNG"  Stretch="Uniform"/>
                    </Rectangle.Fill>
                </Rectangle>

            </Grid>
        </ScrollViewer>

    </Grid>

</Page>
