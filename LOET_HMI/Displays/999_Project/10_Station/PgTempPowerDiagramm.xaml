<Page x:Class="LOET_HMI.Displays.PgTempPowerDiagramm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:oxy="http://oxyplot.org/wpf"
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      x:Name="pgForceDiagramm"
      Loaded="pgForceDiagramm_Loaded" Unloaded="pgForceDiagramm_Unloaded" 
      Title="PgSt1_ForceDiagramm">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <oxy:PlotView x:Name="chartTempPower" Model="{Binding Model1}" Background="Transparent" Grid.Column="0" Margin="20,20,20,20"/>
        </Grid>

        <Grid Grid.Row="1">
            <Button x:Name="ResetBtn"  Content="Reset Zoom" Click="ResetBtn_Click"  Width="300" Background="{StaticResource Brand_Dark}" Foreground="White" VerticalAlignment="Center"  FontSize="30"/>
        </Grid>
    </Grid>
</Page>
