<Page xmlns:LOET_HMI="clr-namespace:LOET_HMI"  xmlns:LOET="clr-namespace:LOET_HMI.UserControls.LOET"  x:Class="LOET_HMI.Displays.PgKROSY"
     
      x:Name="pgKROSY"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      mc:Ignorable="d" 
      xmlns:prop="clr-namespace:LOET_HMI.Properties"
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"

      Loaded="PgKROSY_Loaded" Unloaded="PgKROSY_Unloaded"
      Title="PgKROSY">

    <Grid>
        <ScrollViewer  VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Center" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition  />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <!-- 
                <Rectangle x:Name="rectBackground" Grid.RowSpan="30" Grid.ColumnSpan="30" Fill="#FFE6E5E5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                -->
                
                <!-- Global -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto"  />
                        <RowDefinition Height="20" />
                    </Grid.RowDefinitions>

                    
                    <!--Text: Global-->
                    <TextBlock Grid.Row="0" Text="{x:Static prop:Resources.NavVert_btnGlobal}"  HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition  />
                            <ColumnDefinition  />
                            <ColumnDefinition  />
                            <ColumnDefinition  />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="{x:Static prop:Resources.ProjKROSY_Heartbeats}"  Grid.Column="0" Style="{StaticResource groupboxStyle_KROSY}"   >
                            <StackPanel >
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_PLC}"  />
                                    <LOET_HMI:UcLamp   x:Name="lampHeartbeatPLC"  bIsON="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.bPLC_Heartbeat}"  Style="{StaticResource lampStyle_RFID_LOET_Entries_KROSY}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_KROSY}"  />
                                    <LOET_HMI:UcLamp   x:Name="lampHeartbeatKROSY"  bIsON="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.bKROSY_Heartbeat}"   Style="{StaticResource lampStyle_RFID_LOET_Entries_KROSY}" />
                                </StackPanel>

                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{x:Static prop:Resources.ProjKROSY_InfoPLC}" Grid.Column="1" Style="{StaticResource groupboxStyle_KROSY}"   >
                            <StackPanel >
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_Hostname}" />
                                    <TextBox  x:Name="tbHostname"   Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.strPLC_Hostname}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_IP}"/>
                                    <TextBox x:Name="tbIP"      Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.strPLC_IP}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_Version}"/>
                                    <TextBox  x:Name="tbVersion"     Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.strPLC_Version}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_Lang}" />
                                    <TextBox x:Name="tbLanguage"      Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.strPLC_Language}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{x:Static prop:Resources.ProjKROSY_InfoKROSY}" Grid.Column="2" Style="{StaticResource groupboxStyle_KROSY}"   >
                            <StackPanel >
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_DeviceName}" />
                                    <TextBox x:Name="tbDeviceName"      Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.strKROSY_Device}" />
                                </StackPanel>

                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{x:Static prop:Resources.ProjKROSY_InfoOrder}" Grid.Column="3" Style="{StaticResource groupboxStyle_KROSY}"   >
                            <StackPanel >
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}">
                                        <Run Text="{x:Static prop:Resources.ProjKROSY_Order}" />
                                        <Run Text="{x:Static prop:Resources.ProjKROSY_Max}" />
                                    </TextBlock>
                                    <TextBox  x:Name="tbOrderMax"     Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.iOrderMax}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}"  >
                                        <Run Text="{x:Static prop:Resources.ProjKROSY_Object}" />
                                        <Run Text="{x:Static prop:Resources.ProjKROSY_Max}" />
                                    </TextBlock>
                                    <TextBox  x:Name="tbObjectMax"     Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=pgKROSY, Path=DpKROSY.stGlobal.iObjectMax}" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                    </Grid>


                    <Separator  Grid.Row="2" Margin="20,0,20,0">
                        <Separator.LayoutTransform>
                            <RotateTransform Angle="0" />
                        </Separator.LayoutTransform>
                    </Separator>



                </Grid>


                <!-- Stationen -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="colSt1" Width="640"  />
                        <ColumnDefinition Width="50"  />
                        <ColumnDefinition Width="{Binding ElementName=colSt1, Path=Width}" />
                    </Grid.ColumnDefinitions>

                    <!--Statkion 1 (left)-->
                    <LOET:UcStation x:Name="ucStation1" Grid.Column="0" UCStationNr="1" UCStationName="{x:Static prop:Resources.Proj_StNameStation1}"  Margin="20,0,0,0" />

                    <!-- 
                    <Separator  Grid.Column="1" Margin="1,0,0,20">
                        <Separator.LayoutTransform>
                            <RotateTransform Angle="90" />
                        </Separator.LayoutTransform>
                    </Separator>
                    -->

                    
                    <!-- Station 2 (right) -->
                    <LOET:UcStation x:Name="ucStation2"  Grid.Column="2" UCStationNr="2" UCStationName="{x:Static prop:Resources.Proj_StNameStation2}" Margin="0,0,20,0" />
                </Grid>

            </Grid>

        </ScrollViewer>


    
            
    </Grid>
</Page>
