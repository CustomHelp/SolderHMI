<Page x:Class="LOET_HMI.Displays.PgOrderArchiv"
      x:Name="pgOrdArchiv"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      xmlns:LOET ="clr-namespace:LOET_HMI"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      Loaded="PgOrdArchiv_Loaded"
      Unloaded="PgOrdArchiv_Unloaded"
      xmlns:prop="clr-namespace:LOET_HMI.Properties"
     
      Title="PgOrderArchiv">


    <Page.Resources>
        <LOET:EnumOrderStateConverter x:Key="enumOrderStateConverter"/>
        <LOET:YesNoTextConverter      x:Key="yesNoTextConverter" />
    </Page.Resources>

    <Grid>
        <GroupBox Header="{x:Static prop:Resources.PgOrderArchive_gb_Header}" Grid.Row="0"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="100"  />
                    <RowDefinition  />
                </Grid.RowDefinitions>
                <Button x:Name="BtnRefresh"  Grid.Row="0"   Content="{x:Static prop:Resources.PgOrderArchive_BtnUpdate}" HorizontalAlignment="Left" Margin="30,0,0,0" Style="{StaticResource  RENADataGridButtons}"           Click="BtnRefresh_Click"   />


                <DataGrid x:Name="dGOrderArchiv" Grid.Row="1" Grid.Column="1" Style="{StaticResource RENADataGridStyle}"
                           Margin="20,0,0,0" HorizontalAlignment="Stretch"    
                          AutoGenerateColumns="false"
                          
                          Loaded="DGOrderArchiv_Loaded"
                         >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_paramset}"         Binding="{Binding sParamsetName}"       Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_activeInPLC}"     Binding="{Binding bActiveInPLC,  Converter={StaticResource yesNoTextConverter}}"      Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_State}"                   Binding="{Binding iState,        Converter={StaticResource enumOrderStateConverter}}"      Width="auto" />

                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_Target}"            Binding="{Binding iQuantityTarget}"        Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_PartsDone}"       Binding="{Binding iQuantityDone}"        Width="auto" />

                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_CartonsPerPallet}"       Binding="{Binding iCartonQuantProPallet}"      Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_CartonsDone}"         Binding="{Binding iCartonDone}"      Width="auto" />

                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_AddedBy}"   Binding="{Binding sAddedByToQueue}" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_AddedOn}"      Binding="{Binding dtAddedOnToQueue,       StringFormat=\{0:dd.MM.yyyy HH:mm\} }" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_LoadedOn}"         Binding="{Binding dtLoadedToPLCOn,       StringFormat=\{0:dd.MM.yyyy HH:mm\} }" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_StartedOn}"              Binding="{Binding dtStartedOn,       StringFormat=\{0:dd.MM.yyyy HH:mm\} }" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_FinishedOn}"                Binding="{Binding dtFinishedOn,       StringFormat=\{0:dd.MM.yyyy HH:mm\} }" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrderArchive_CancelledOn}"            Binding="{Binding dtCancelledOn,       StringFormat=\{0:dd.MM.yyyy HH:mm\} }" Width="auto" />



                    </DataGrid.Columns>

                </DataGrid>

            </Grid>
            



        </GroupBox>

    </Grid>
</Page>
