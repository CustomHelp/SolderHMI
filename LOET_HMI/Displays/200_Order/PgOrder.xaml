<Page xmlns:LOET_HMI="clr-namespace:LOET_HMI"  x:Class="LOET_HMI.Displays.PgOrder"
      x:Name="pgOrd"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      Title="PgOrder"
      Loaded="Page_Loaded"
      Unloaded="PgOrd_Unloaded"
      xmlns:prop="clr-namespace:LOET_HMI.Properties"
      >
    <Page.Resources>
        <CollectionViewSource x:Key="itemCollectionViewSourceOrder" CollectionViewType="ListCollectionView"/>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="14" />
        </Style>

    </Page.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="500"  />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- ****************************************************************************************  -->
        <!-- ************************************* SPS-Daten  ***************************************  -->
        <!-- ****************************************************************************************  -->
        <GroupBox Header="{x:Static prop:Resources.PgOrder_gbPLC}" Grid.Row="0"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >

            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                

                <StackPanel Orientation="Vertical"  HorizontalAlignment="Left" Grid.Row="1" Grid.Column="0" >
                    <LOET_HMI:UcButton x:Name="BtnCancelActOrder"     Content="{x:Static prop:Resources.PgOrder_BtnCancel}" Style="{StaticResource  RENADataGridButtons}"           
                                       Click="BtnCancel_Click"    
                                       IsEnabled="True"
                                       
                                        DpShowPopUp     ="True"                                      
                                        DpPopupHeader   ="{x:Static prop:Resources.PgOrder_PopUp_Cancel_Header}"
                                        DpPopupText     ="{x:Static prop:Resources.PgOrder_PopUp_Cancel_Text}"     
                                        DpPopupOKbtnText="{x:Static prop:Resources.Btn_Yes}"  >
                    </LOET_HMI:UcButton>



                    <Label Height="20" />

                </StackPanel>




                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="*" />
                        <ColumnDefinition  Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Vertical" Grid.Column="0" Margin="10,0,0,0">

                        <TextBlock    Text="{x:Static prop:Resources.PgOrder_OrderName}" />
                        <TextBlock    Text="{x:Static prop:Resources.PgOrder_NumberOfPieces}" />
                        <TextBlock    Text="{x:Static prop:Resources.PgOrder_BoxesProduced}" Visibility="Hidden" />
                        <TextBlock    Text="{x:Static prop:Resources.PgOrder_ReadyForNewOrder}" />
                        <TextBlock    Text="{x:Static prop:Resources.PgOrder_Started}"        />
                        <TextBlock    Text="{x:Static prop:Resources.PgOrder_Done}"           />

                    </StackPanel>

                    <StackPanel Orientation="Vertical" Grid.Column="1">
                        <TextBlock x:Name="tbOrderName"     Text="_Name"   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="tbQuantAct"      Text="_QuantAct"  HorizontalAlignment="Center" />
                        <TextBlock x:Name="tbQuantActCart"  Text="_QuantActCart"  HorizontalAlignment="Center" Visibility="Hidden"/>

                        <LOET_HMI:UcLamp  eLEDColor="Green" bIsON="{Binding ElementName=pgOrd, Path=bRX_ReadyForNewOrderProperty }" Margin="0,0,0,0"  HorizontalAlignment="Center"    />
                        <LOET_HMI:UcLamp  eLEDColor="Green" bIsON="{Binding ElementName=pgOrd, Path=bRX_OrderStartedProperty }"     Margin="0,-3,0,0"  HorizontalAlignment="Center"   />
                        <LOET_HMI:UcLamp  eLEDColor="Green" bIsON="{Binding ElementName=pgOrd, Path=bRX_OrderDoneProperty }"        Margin="0,-3,0,0"  HorizontalAlignment="Center"  />
                    </StackPanel>
                </Grid>

            </Grid>
        </GroupBox>



        <GroupBox Header="{x:Static prop:Resources.PgOrder_gbDatabase}" Grid.Row="0" Grid.Column="1"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition  Width="2*"/>
                    <ColumnDefinition  Width="2*"/>
                    <ColumnDefinition  Width="3*"/>
                </Grid.ColumnDefinitions>


                <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="  " FontWeight="Bold" FontSize="16" />

                    <TextBlock  Text="{x:Static prop:Resources.PgOrder_db_Paramsetname}"  />
                    <TextBlock  Text="{x:Static prop:Resources.PgOrder_db_State}" />

                    <TextBlock Text=" " />


                    <TextBlock  Text="{x:Static prop:Resources.PgOrder_db_quantityTarget}" />
                    <TextBlock  Text="{x:Static prop:Resources.PgOrder_db_quantityDone}" />
                    <TextBlock  Text="Cartons per pallet:" Visibility="Hidden" />
                    <TextBlock  Text="Cartons done:" Visibility="Hidden"/>

                    <TextBlock Text=" " />

                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_addedbyUser}" />
                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_addedonTimestamp}" />
                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_loadedonTimestamp}" />
                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_startedonTimestamp}" />
                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_finishedonTimestamp}" />
                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_cancelledonTimestamp}" />

                </StackPanel>

                <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_Current}" FontWeight="Bold" FontSize="16"  HorizontalAlignment="Center"  />

                    <TextBlock x:Name="tbParamsetNameID"   Text="_tbParamsetName" HorizontalAlignment="Center"  />
                    <TextBlock  x:Name="tbState"           Text="_tbState"   HorizontalAlignment="Center" />

                    <TextBlock Text=" " />


                    <TextBlock x:Name="tbQuantTarget"       Text="_tbQuantTarget"  HorizontalAlignment="Center" />
                    <TextBlock x:Name="tbQuantDone"         Text="_tbQuantDone"  HorizontalAlignment="Center" />
                    <TextBlock x:Name="tbCartonsProPallet"  Text="_tbCartonsProPallet"  HorizontalAlignment="Center" Visibility="Hidden"/>
                    <TextBlock x:Name="tbCartonsDone"       Text="_tbCartonsDone"  HorizontalAlignment="Center" Visibility="Hidden"/>

                    <TextBlock Text=" " />

                    <TextBlock x:Name="tbAddedBy"             Text="_tbAddedBy"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbAddedOn"             Text="_tbAddedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbLoadedToPLCDateTime" Text="_tbLoadedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbStartedDateTime"     Text="_tbStartedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbFinishedDateTime"    Text="_tbFinishedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbCanceledDateTime"    Text="_tbCanceledDateTime" HorizontalAlignment="Center" />

                </StackPanel>

                <StackPanel Orientation="Vertical" Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="{x:Static prop:Resources.PgOrder_db_Previous}" FontWeight="Bold" FontSize="16"  HorizontalAlignment="Center"/>

                    <TextBlock x:Name="tbParamsetNameIDPrev"  Text="_tbParamsetName"  HorizontalAlignment="Center" />
                    <TextBlock  x:Name="tbStatePrev"  Text="_tbState" HorizontalAlignment="Center" />

                    <TextBlock Text=" " />


                    <TextBlock x:Name="tbQuantTargetPrev"       Text="_tbQuantTarget"  HorizontalAlignment="Center" />
                    <TextBlock x:Name="tbQuantDonePrev"         Text="_tbQuantDone"   HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbCartonsProPalletPrev"  Text="_tbCartonsProPallet"   HorizontalAlignment="Center" Visibility="Hidden"/>
                    <TextBlock x:Name="tbCartonsDonePrev"       Text="_tbCartonsDone"   HorizontalAlignment="Center" Visibility="Hidden"/>

                    <TextBlock Text=" " />

                    <TextBlock x:Name="tbAddedByPrev"             Text="_tbAddedBy" HorizontalAlignment="Center" />
                    <TextBlock x:Name="tbAddedOnPrev"             Text="_tbAddedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbLoadedToPLCDateTimePrev" Text="_tbLoadedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbStartedDateTimePrev"     Text="_tbStartedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbFinishedDateTimePrev"    Text="_tbFinishedDateTime"  HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbCanceledDateTimePrev"    Text="_tbCanceledDateTime"  HorizontalAlignment="Center"/>

                </StackPanel>
            </Grid>

        </GroupBox>




        <!-- ****************************************************************************************  -->
        <!-- ********************************* Warteschlange ****************************************  -->
        <!-- ****************************************************************************************  -->
        <GroupBox Header="{x:Static prop:Resources.PgOrder_gbQueue}" Grid.Row="1" Grid.ColumnSpan="2"
                  Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition  Height="auto" />
                    <RowDefinition  Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="20,10,0,10">
                    <TextBlock   Margin="0,0,0,10" Text="{x:Static prop:Resources.PgOrder_strHeaderStart}" FontWeight="Bold"  FontSize="16"/>
                    <RadioButton x:Name="rbStartAutomatic" Margin="0,0,0,5" GroupName="rbNextOrder" Checked="RadioButton_Checked" Content="{x:Static prop:Resources.PgOrder_autoStart}"  />
                    <RadioButton x:Name="rbStartManually" Margin="0,0,0,5" GroupName="rbNextOrder"  Checked="RadioButton_Checked" Content="{x:Static prop:Resources.PgOrder_manualStart}" />
                </StackPanel  >


                <StackPanel Orientation="Vertical"  HorizontalAlignment="Left" Grid.Row="0" Grid.RowSpan="2"  Grid.Column="0" >
                    <Label Height="30" />
                    <Button x:Name="BtnStartNextOrder"  Content="{x:Static prop:Resources.PgOrder_BtnLoad}" Style="{StaticResource  RENADataGridButtons}"          Click="BtnStartNextOrder_Click"  />
                    <Label Height="30" />

                    <Button x:Name="BtnDeleteOrder"     Content="{x:Static prop:Resources.PgOrder_BtnDelete}" Style="{StaticResource  RENADataGridButtons}"           Click="BtnDeleteOrder_Click"  />


                </StackPanel>



                <DataGrid x:Name="dGOrder" Grid.Row="1" Grid.Column="1" Style="{StaticResource RENADataGridStyle}"
                           Margin="20,0,0,0" HorizontalAlignment="Stretch"    
                          AutoGenerateColumns="false"
  
                          GotFocus="DGOrder_GotFocus" 
                          SelectionChanged="DGOrder_SelectionChanged"
                          
                          SelectedCellsChanged="DGOrder_SelectedCellsChanged" 
                          PreviewKeyDown="DGOrder_PreviewKeyDown"
                          Loaded="DGOrder_Loaded"
                         >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrder_q_number}"       Binding="{Binding iNrInQueue}" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrder_q_paramset}"     Binding="{Binding sParamSetname}"        Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrder_q_paramsetId}"          Binding="{Binding iParamSetId}"        Width="auto" />

                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrder_q_quantity}"              Binding="{Binding iQuantity}"      Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrder_q_cartonsPerPallet}" Binding="{Binding iCartonQuantProPallet}"      Width="auto" />

                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrder_q_addedOn}"            Binding="{Binding dtAddedOn,       StringFormat=\{0:dd.MM.yyyy HH:mm\} }" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.PgOrder_q_addedBy}"           Binding="{Binding sAddedBy}" Width="auto" />


                    </DataGrid.Columns>

                </DataGrid>

            </Grid>



        </GroupBox>

    </Grid>
</Page>
