<Page x:Class="HOPA_HMI.PageHome"
      x:Name="Homepage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HOPA_HMI"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"
      Title="PageHome"
      xmlns:System="clr-namespace:System;assembly=mscorlib"
       >

    
    <Page.Resources>
        <CollectionViewSource x:Key="itemCollectionViewSourceMessages" CollectionViewType="ListCollectionView"/>
        <CollectionViewSource x:Key="itemCollectionViewSourceErrors" CollectionViewType="ListCollectionView"/>

        <CollectionViewSource x:Key="itemCollectionViewSourceMessages2" CollectionViewType="ListCollectionView"/>
        <CollectionViewSource x:Key="itemCollectionViewSourceErrors2" CollectionViewType="ListCollectionView"/>

        <CollectionViewSource x:Key="itemCollectionViewSourceMessages3" CollectionViewType="ListCollectionView"/>
        <CollectionViewSource x:Key="itemCollectionViewSourceErrors3" CollectionViewType="ListCollectionView"/>

        <CollectionViewSource x:Key="itemCollectionViewSourceMessages4" CollectionViewType="ListCollectionView"/>
        <CollectionViewSource x:Key="itemCollectionViewSourceErrors4" CollectionViewType="ListCollectionView"/>


    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid  Grid.Column="0" Grid.Row="0" Margin="40,5,40,10">
            <Rectangle x:Name="RectBackground" Style="{StaticResource CHP_ControlBackgroundState}" Margin="0,0,0,0" />
            
        <StackPanel Orientation="Vertical">
                <TextBlock Text="Modul 1"  Style="{StaticResource CHP_tbModulName}" ></TextBlock>
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Vertical" Width="79" >

                        <Button  x:Name="btnOP1" Style="{StaticResource CHP_AnimatedButton}"  Width="75" Height="75"  Margin="0,0,0,0" Click="BtnOP1_Click" HorizontalAlignment="Right">
                            <Image Source="{Binding sOPImage1, ElementName=Homepage}"></Image>
                    </Button>
      
                        <Button x:Name="btnStart1" Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,30,5,0" Click="BtnStart1_Click" HorizontalAlignment="Right">
                        <Image Source="/HOPA_HMI;component/Resources/Start.png"  Margin="5,5,5,5"></Image>
                        </Button>

                        <Button x:Name="btnStop1" Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,0,5,0" Click="BtnStop1_Click" HorizontalAlignment="Right">
                        <Image Source="/HOPA_HMI;component/Resources/Stop.png" Margin="5,5,5,5"></Image>
                        </Button>
                        <Button x:Name="btnQuit1" Style="{StaticResource CHP_Button}"   Height="60" Width="60" Margin="0,0,5,0" Click="BtnQuit1_Click" HorizontalAlignment="Right">
                        <Image Source="/HOPA_HMI;component/Resources/Quit.png" Margin="5,5,5,5"></Image>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" x:Name="sp1" Width="{StaticResource spWidthMsg}" HorizontalAlignment="Stretch" >
                        
                    <DataGrid x:Name="dGMeldungen" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceMessages}" 
                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="130" Margin="0,0,10,0" 
                         RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColMessage" Binding="{Binding sText}" Header="Meldungen" IsReadOnly="True" Width="*"/>
                        </DataGrid.Columns>

                        <DataGrid.Resources>
                            <Style TargetType="{x:Type Button}" x:Key="{ComponentResourceKey ResourceId=DataGridSelectAllButtonStyle, TypeInTargetAssembly={x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Hidden" />
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>

                    <DataGrid x:Name="dGFehler" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceErrors}" 
                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="200" Margin="0,10,10,0" 
                        RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColFehler" Binding="{Binding sText}" Header="Fehler" IsReadOnly="True" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        </Grid>

        <Grid  Grid.Column="1" Grid.Row="0" Margin="40,5,40,10">
            <Rectangle  Style="{StaticResource CHP_ControlBackgroundState}" Margin="0,0,0,0" />

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Modul 2" Style="{StaticResource CHP_tbModulName}"></TextBlock>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Width="79" >

                        <Button  x:Name="btnOP2" Style="{StaticResource CHP_AnimatedButton}"  Width="75" Height="75"  Margin="0,0,0,0" Click="BtnOP2_Click" HorizontalAlignment="Right">
                            <Image Source="{Binding sOPImage2, ElementName=Homepage}"></Image>
                        </Button>

                        <Button x:Name="btnStart2" Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,30,5,0" Click="BtnStart2_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Start.png"  Margin="5,5,5,5"></Image>
                        </Button>

                        <Button x:Name="btnStop2" Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,0,5,0" Click="BtnStop2_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Stop.png" Margin="5,5,5,5"></Image>
                        </Button>
                        <Button x:Name="btnQuit2" Style="{StaticResource CHP_Button}"   Height="60" Width="60" Margin="0,0,5,0" Click="BtnQuit2_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Quit.png" Margin="5,5,5,5"></Image>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" x:Name="sp2" Width="{StaticResource spWidthMsg}" >
                        <DataGrid x:Name="dGMeldungen2" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceMessages2}"
                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="130" Margin="0,0,10,0"  
                        RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                 <DataGrid.Columns>
                        <DataGridTextColumn x:Name="ColMessage2" Binding="{Binding sText}" Header="Meldungen" IsReadOnly="True" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="dGFehler2" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceErrors2}" 
                                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="200" Margin="0,10,10,0" 
                        RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="ColFehler2" Binding="{Binding sText}" Header="Fehler" IsReadOnly="True" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>



        <Grid  Grid.Column="0" Grid.Row="1" Margin="40,5,40,10">
            <Rectangle Style="{StaticResource CHP_ControlBackgroundState}" Margin="0,0,0,0" />

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Modul 3" Style="{StaticResource CHP_tbModulName}" ></TextBlock>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Width="79" >

                        <Button Style="{StaticResource CHP_AnimatedButton}"  Width="75" Height="75"  Margin="0,0,0,0" Click="BtnOP3_Click" HorizontalAlignment="Right">
                            <Image Source="{Binding sOPImage3, ElementName=Homepage}"></Image>
                        </Button>

                        <Button Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,30,5,0" Click="BtnStart3_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Start.png"  Margin="5,5,5,5"></Image>
                        </Button>

                        <Button  Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,0,5,0" Click="BtnStop3_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Stop.png" Margin="5,5,5,5"></Image>
                        </Button>
                        <Button  Style="{StaticResource CHP_Button}"   Height="60" Width="60" Margin="0,0,5,0" Click="BtnQuit3_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Quit.png" Margin="5,5,5,5"></Image>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" x:Name="sp3" Width="{StaticResource spWidthMsg}" >

                        <DataGrid x:Name="dGMeldungen3" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceMessages3}" 
                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="130" Margin="0,0,10,0" 
                          RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColMessage3" Binding="{Binding sText}" Header="Meldungen" IsReadOnly="True" Width="*"/>
                            </DataGrid.Columns>

                            <DataGrid.Resources>
                                <Style TargetType="{x:Type Button}" x:Key="{ComponentResourceKey ResourceId=DataGridSelectAllButtonStyle, TypeInTargetAssembly={x:Type DataGrid}}">
                                    <Setter Property="Visibility" Value="Hidden" />
                                </Style>
                            </DataGrid.Resources>
                        </DataGrid>

                        <DataGrid x:Name="dGFehler3" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceErrors3}" 
                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="200" Margin="0,10,10,0" 
                        RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColFehler3" Binding="{Binding sText}" Header="Fehler" IsReadOnly="True" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid  Grid.Column="1" Grid.Row="1" Margin="40,5,40,10">
            <Rectangle Style="{StaticResource CHP_ControlBackgroundState}" Margin="0,0,0,0" />

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Modul 4" Style="{StaticResource CHP_tbModulName}" ></TextBlock>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Width="79" >

                        <Button Style="{StaticResource CHP_AnimatedButton}"  Width="75" Height="75"  Margin="0,0,0,0" Click="BtnOP4_Click" HorizontalAlignment="Right">
                            <Image Source="{Binding sOPImage4, ElementName=Homepage}"></Image>
                        </Button>

                        <Button Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,30,5,0" Click="BtnStart4_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Start.png"  Margin="5,5,5,5"></Image>
                        </Button>

                        <Button  Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,0,5,0" Click="BtnStop4_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Stop.png" Margin="5,5,5,5"></Image>
                        </Button>
                        <Button  Style="{StaticResource CHP_Button}"   Height="60" Width="60" Margin="0,0,5,0" Click="BtnQuit4_Click" HorizontalAlignment="Right">
                            <Image Source="/HOPA_HMI;component/Resources/Quit.png" Margin="5,5,5,5"></Image>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" x:Name="sp4" Width="{StaticResource spWidthMsg}" >
                        <DataGrid x:Name="dGMeldungen4" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceMessages4}"
                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="130" Margin="0,0,10,0"  
                        RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColMessage4" Binding="{Binding sText}" Header="Meldungen" IsReadOnly="True" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="dGFehler4" ItemsSource="{Binding}" DataContext="{StaticResource itemCollectionViewSourceErrors4}" 
                                        Style="{StaticResource CHP_DataGrid}" 
                        ColumnHeaderStyle="{StaticResource CHP_DataGridColumnHeader}"
                        RowStyle="{StaticResource Style_MessDataGridRow}"
                        CellStyle="{StaticResource Style_MessDataGridCell}"
                        IsReadOnly="True" AutoGenerateColumns="False" EnableRowVirtualization="True" Height="200" Margin="0,10,10,0" 
                        RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" FontSize="24" >
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColFehler4" Binding="{Binding sText}" Header="Fehler" IsReadOnly="True" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>

</Page>
