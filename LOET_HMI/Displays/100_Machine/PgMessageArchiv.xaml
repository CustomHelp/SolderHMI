<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      xmlns:UserControls="clr-namespace:LOET_HMI.UserControls" x:Class="LOET_HMI.Displays.PgMessageArchiv"
      xmlns:prop="clr-namespace:LOET_HMI.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}" 
      x:Name="PgMsgArchiv"
      Loaded="Page_Loaded"
      Title="PgMessageArchiv">

    <Page.Resources>
        <CollectionViewSource x:Key="itemCollectionViewSourceMessages" CollectionViewType="{x:Type ListCollectionView}"/>
    </Page.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="dGMeldungen" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="14" Margin="10,10,10,10" 
                  SelectionChanged="DGMeldungen_SelectionChanged"
                  
                  RowStyle="{StaticResource Style_ArchivAlarmDataGridRowColors}"
                                    
                  ItemsSource="{Binding}" 
                  DataContext="{StaticResource itemCollectionViewSourceMessages}" 
                  
                  IsReadOnly                ="True" 
                  AutoGenerateColumns       ="False" 
                  EnableRowVirtualization   ="True"                   
                  RowDetailsVisibilityMode  ="VisibleWhenSelected" 
                  CanUserAddRows            ="False"                                   
                  >

            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColCome"    Binding="{Binding dtCome, StringFormat=\{0:dd.MM.yy HH:mm:ss\}}" Header="{x:Static prop:Resources.DgCol_Occurred}"  IsReadOnly="True" MinWidth="120" Width="Auto" />
                <DataGridTextColumn x:Name="ColGone"    Binding="{Binding dtGone, StringFormat=\{0:dd.MM.yy HH:mm:ss\}}" Header="{x:Static prop:Resources.DgCol_Gone}" IsReadOnly="True" MinWidth="100" Width="Auto"/>
                <DataGridTextColumn x:Name="ColQuit"    Binding="{Binding dtQuit, StringFormat=\{0:dd.MM.yy HH:mm:ss\}}" Header="{x:Static prop:Resources.DgCol_Acknowledged}" IsReadOnly="True" MinWidth="100" Width="Auto"/>
                <DataGridTextColumn x:Name="ColMessage" Binding="{Binding sMessage}" Header="{x:Static prop:Resources.DgCol_Message}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn x:Name="ColBMK"     Binding="{Binding sBMK}"  Header="{x:Static prop:Resources.DgCol_BMK}" IsReadOnly="True" MinWidth="70" Width="Auto"/>
                <DataGridTextColumn x:Name="ColModul"   Binding="{Binding iModul}"   Header="{x:Static prop:Resources.DgCol_Modul}" IsReadOnly="True" MinWidth="70" Width="Auto"/>
                <DataGridTextColumn x:Name="ColStat"    Binding="{Binding sStation}" Header="{x:Static prop:Resources.DgCol_Station}" IsReadOnly="True" MinWidth="70" Width="Auto"/>
                <DataGridTextColumn x:Name="ColUser"    Binding="{Binding sUserName}" Header="{x:Static prop:Resources.DgCol_User}"  IsReadOnly="True" MinWidth="70" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>


        <GroupBox Header="{x:Static prop:Resources.PgMsgArch_gbTimeModul}" Grid.Row="0" Grid.Column="0"  VerticalAlignment="Top"
                  Width="{Binding Width, ElementName=col0}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >

            <StackPanel Orientation="Vertical"  Margin="10,0,10,10" HorizontalAlignment="Center">
                <!-- 
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="Datum"  TextAlignment="center" VerticalAlignment="Center" Margin="90,0,5,0"/>
                        <TextBlock  Text="Uhrzeit"  TextAlignment="center" VerticalAlignment="Center" Margin="100,0,5,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="tblStartDate" Text="Von:"  TextAlignment="Right"  VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker x:Name="dpStartDate" FontSize="16"  VerticalAlignment="Center" />
                        <TextBox   x:Name="tbStartHour" Text="00"   FontSize="16"  VerticalAlignment="Center" Margin="20,0,1,0" TextAlignment="Center" Width="35" GotFocus="TbStartHour_GotFocus" />
                        <TextBlock                      Text=":"    FontSize="16"  VerticalAlignment="Center" Margin="5,0,1,0"/>
                        <TextBox   x:Name="tbStartMin"  Text="00"   FontSize="16"  VerticalAlignment="Center" Margin="5,0,1,0" TextAlignment="Center" Width="35" GotFocus="TbStartMin_GotFocus" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0" >
                        <TextBlock x:Name="tblEndDate" Text="Bis:"  TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker x:Name="dpEndDate" FontSize="16"  VerticalAlignment="Center" Background="#FFE50B0B" Foreground="#FFE50000" />
                        <TextBox   x:Name="tbEndHour"  Text=""   FontSize="16"  VerticalAlignment="Center" Margin="20,0,1,0" TextAlignment="Center" Width="35" GotFocus="TbEndHour_GotFocus" />
                        <TextBlock                       Text=":"    FontSize="16"  VerticalAlignment="Center" Margin="5,0,1,0"/>
                        <TextBox   x:Name="tbEndMin"   Text=""   FontSize="16"  VerticalAlignment="Center" Margin="5,0,1,0" TextAlignment="Center" Width="35" GotFocus="TbEndMin_GotFocus" />
                    </StackPanel>
                </StackPanel>
                -->

                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{x:Static prop:Resources.PgMsgArch_Date}"  TextAlignment="center" VerticalAlignment="Center" Margin="90,0,5,0"/>
                        <TextBlock  Text="{x:Static prop:Resources.PgMsgArch_Time}"   TextAlignment="center" VerticalAlignment="Center" Margin="100,0,5,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="tblStartDate" Text="{x:Static prop:Resources.PgMsgArch_From}"   TextAlignment="Right"  VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker x:Name="datePickerStart" FontSize="16"  VerticalAlignment="Center" />

                        <UserControls:UcTimePickerCHP x:Name="timePickerStart" Width="80" FontSizeUC="16" Margin="20,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0" >
                        <TextBlock x:Name="tblEndDate" Text="{x:Static prop:Resources.PgMsgArch_Until}"   TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker x:Name="datePickerEnd" FontSize="16"  VerticalAlignment="Center" Background="#FFE50B0B" Foreground="#FFE50000" />
                        <UserControls:UcTimePickerCHP x:Name="timePickerEnd" Width="80" FontSizeUC="16" bShowCurrentTimeByLoading="True" Margin="20,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid  Margin="0,30,0,0" Visibility="Hidden">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="6*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />

                    </Grid.RowDefinitions>

                    <ToggleButton Grid.Row="0" Name="togModul1" Width="50" Height="30" Style="{StaticResource SwitchTypeToggleButton}" Margin="0,3,0,3"/>
                    <TextBlock Grid.Row="0"  Grid.Column="1" Text="Modul 1" FontSize="16" HorizontalAlignment="Left" TextAlignment="Center" VerticalAlignment="Center"  />

                    <ToggleButton Grid.Row="1" Name="togStation1" Width="50" Height="30" Style="{StaticResource SwitchTypeToggleButton}" Margin="0,3,0,3"/>
                    <TextBlock Grid.Row="1"  Grid.Column="1" Text="Station 1" FontSize="16" HorizontalAlignment="Left" TextAlignment="Center" VerticalAlignment="Center"/>

                    <ToggleButton Grid.Row="2" Name="togStation2" Width="50" Height="30" Style="{StaticResource SwitchTypeToggleButton}" Margin="0,3,0,3"/>
                    <TextBlock Grid.Row="2"  Grid.Column="1" Text="Station 2" FontSize="16" HorizontalAlignment="Left" TextAlignment="Center" VerticalAlignment="Center"/>

                </Grid>


                <Button x:Name="BtnSearch" Click="BtnSearch_Click"  Content="{x:Static prop:Resources.PgMsgArch_btnSearch}"  Height="40"  Width="180" HorizontalAlignment="Center" Margin="0,30,0,0"/>


            </StackPanel>
        </GroupBox>

        <GroupBox Header="{x:Static prop:Resources.PgMsgArch_gbFilter}"  Grid.Row="0" Grid.Column="1"  VerticalAlignment="Stretch"
                  Width="{Binding Width, ElementName=col0}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >

            <Grid>
                <Grid  Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="row0" Height="25"/>
                        <RowDefinition x:Name="row1" Height="40" />
                        <RowDefinition Height="{Binding ElementName=row1, Path=Height}" />
                        <RowDefinition Height="{Binding ElementName=row1, Path=Height}" />
                        <RowDefinition Height="{Binding ElementName=row1, Path=Height}" />
                        <RowDefinition Height="{Binding ElementName=row1, Path=Height}" />
                        <RowDefinition Height="*" />

                    </Grid.RowDefinitions>

                    <Rectangle Grid.Row="0" Grid.RowSpan="7" Grid.Column="2" Grid.ColumnSpan="1" Fill="LightGray" Margin="0,0,0,5" />
                    <Rectangle Grid.Row="0" Grid.RowSpan="7" Grid.Column="4" Grid.ColumnSpan="4" Fill="LightGray" Margin="0,0,0,5" />

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Static prop:Resources.PgMsgArch_SelectedMsg}" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Bottom" Margin="0,5,0,0"  FontSize="16" Grid.ColumnSpan="2" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{x:Static prop:Resources.PgMsgArch_Condition}" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Bottom" Margin="0,5,0,0"  FontSize="16" Grid.ColumnSpan="2" />




                    <TextBlock Grid.Row="1" Grid.Column="0" TextAlignment="Left" VerticalAlignment="Center" Margin="0,15,0,4"  FontSize="16">
                        <Run Text="{x:Static prop:Resources.PgMsgArch_MsgText}"  />
                        <Run Text=":"  />
                    </TextBlock>
                    <TextBlock Grid.Row="2" Grid.Column="0" TextAlignment="Left" VerticalAlignment="Center" Margin="0,15,0,4"  FontSize="16">
                        <Run Text="{x:Static prop:Resources.PgMsgArch_MsgType}"  />
                        <Run Text=":"  />
                    </TextBlock>
                    <TextBlock Grid.Row="3" Grid.Column="0" TextAlignment="Left" VerticalAlignment="Center" Margin="0,15,0,4"  FontSize="16">
                        <Run Text="{x:Static prop:Resources.DgCol_Station}"   />
                        <Run Text=":"  />
                    </TextBlock>
                    <TextBlock Grid.Row="4" Grid.Column="0" TextAlignment="Left" VerticalAlignment="Center" Margin="0,15,0,4"  FontSize="16">
                        <Run Text="{x:Static prop:Resources.DgCol_BMK}"  />
                        <Run Text=":"  />
                    </TextBlock>
                    <TextBlock Grid.Row="5" Grid.Column="0" TextAlignment="Left" VerticalAlignment="Center" Margin="0,15,0,4"  FontSize="16">
                        <Run Text="{x:Static prop:Resources.DgCol_User}"   />
                        <Run Text=":"  />
                    </TextBlock>




                    <Button x:Name="btnGetFromSelRow_Msg"   Grid.Row="1" Grid.Column="3" Margin="0,0,0,0" Click="BtnGetFromSelRow_Msg_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/arrow_right.png" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/arrow_right.png" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>
                    <Button x:Name="btnGetFromSelRow_Type"  Grid.Row="2" Grid.Column="3" Margin="0,0,0,0" Click="BtnGetFromSelRow_Type_Click"  Background="Transparent" BorderThickness="0" >
                        <Image Source="/LOET_HMI;component/Resources/arrow_right.png" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/arrow_right.png" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>
                    <Button x:Name="btnGetFromSelRow_Stat"  Grid.Row="3" Grid.Column="3" Margin="0,0,0,0"  Click="BtnGetFromSelRow_Stat_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/arrow_right.png" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/arrow_right.png" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>
                    <Button x:Name="btnGetFromSelRow_BMK"   Grid.Row="4" Grid.Column="3" Margin="0,0,0,0" Click="BtnGetFromSelRow_BMK_Click" Background="Transparent" BorderThickness="0" >
                        <Image Source="/LOET_HMI;component/Resources/arrow_right.png" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/arrow_right.png" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>
                    
                    <Button x:Name="btnGetFromSelRow_User"  Grid.Row="5" Grid.Column="3" Margin="0,0,0,0" Click="BtnGetFromSelRow_User_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/arrow_right.png" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/arrow_right.png" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>


                    <TextBlock x:Name="tblSelectedMsg"      Grid.Row="1" Grid.Column="2"  Margin="10,15,0,4"  FontSize="16"  />
                    <TextBlock x:Name="tblSelectedMsgType"  Grid.Row="2" Grid.Column="2"  Margin="10,15,0,4"  FontSize="16"  />
                    <TextBlock x:Name="tblSelectedStation"  Grid.Row="3" Grid.Column="2"  Margin="10,15,0,4"  FontSize="16"  />
                    <TextBlock x:Name="tblSelectedBMK"      Grid.Row="4" Grid.Column="2"  Margin="10,15,0,4"  FontSize="16"  />
                    <TextBlock x:Name="tblSelectedUser"     Grid.Row="5" Grid.Column="2"  Margin="10,15,0,4"  FontSize="16"  />



                    <ComboBox x:Name="cbMsg"      Grid.Row="1" Grid.Column="5" Margin="0,5,0,0"   VerticalAlignment="Center" FontSize="16" SelectedValuePath="Content" IsEditable="True" PreviewMouseDown="CbMsg_PreviewMouseDown" />
                    <ComboBox x:Name="cbMsgType"  Grid.Row="2" Grid.Column="5" Margin="0,5,0,0"   VerticalAlignment="Center" FontSize="16" SelectedValuePath="Content"  />
                    <ComboBox x:Name="cbStation"  Grid.Row="3" Grid.Column="5" Margin="0,5,0,0"   VerticalAlignment="Center" FontSize="16" SelectedValuePath="Content"    />
                    <ComboBox x:Name="cbBMK"      Grid.Row="4" Grid.Column="5" Margin="0,5,0,0"   VerticalAlignment="Center" FontSize="16" SelectedValuePath="Content"  />
                    <ComboBox x:Name="cbUser"     Grid.Row="5" Grid.Column="5" Margin="0,5,0,0"   VerticalAlignment="Center" FontSize="16" SelectedValuePath="Content"   />


                    <Button x:Name="btnReset_Msg"   Grid.Row="1" Grid.Column="6" Margin="10,10,0,0" FontSize="16"  Click="BtnReset_Msg_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>
                    <Button x:Name="btnReset_Type"  Grid.Row="2" Grid.Column="6" Margin="10,10,0,0" FontSize="16"  Click="BtnReset_Type_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>                 
                    </Button>
                    <Button x:Name="btnReset_Stat"  Grid.Row="3" Grid.Column="6" Margin="10,10,0,0" FontSize="16"  Click="BtnReset_Stat_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>
                    <Button x:Name="btnReset_BMK"   Grid.Row="4" Grid.Column="6" Margin="10,10,0,0" FontSize="16"  Click="BtnReset_BMK_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>
                    <Button x:Name="btnReset_User"  Grid.Row="5" Grid.Column="6" Margin="10,10,0,0" FontSize="16"  Click="BtnReset_User_Click" Background="Transparent" BorderThickness="0">
                        <Image Source="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" >
                            <Image.OpacityMask>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/Filter - Delete 64 h g.gif" Stretch="Uniform"/>
                            </Image.OpacityMask>
                        </Image>
                    </Button>


                    <StackPanel Orientation="Horizontal" Grid.Column="5" Grid.ColumnSpan="4" HorizontalAlignment="Center" Grid.Row="6" >
                        <TextBlock x:Name="tbSelectedMsgAll" Visibility="Collapsed" Grid.Row="1" Margin="10,10,0,0" Height="18"/>

                        <Button x:Name="BtnFilter" Click="BtnFilter_Click" Content="{x:Static prop:Resources.PgMsgArch_btnFilterApply}"  Height="40"  Width="180" HorizontalAlignment="Center" Margin="0,0,0,0" />
                        <Button x:Name="BtnReset"  Click="BtnReset_Click" Content="{x:Static prop:Resources.PgMsgArch_btnFilterReset}"  Height="40"  Width="180" HorizontalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>
                </Grid>



            </Grid>
        </GroupBox>


    </Grid>
</Page>
