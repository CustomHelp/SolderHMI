<Page x:Class="LOET_HMI.Displays.PgMessages"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOET_HMI.Displays"
      xmlns:prop="clr-namespace:LOET_HMI.Properties"

      x:Name="pgStat"
      Loaded="PgStat_Loaded" Unloaded="PgStat_Unloaded"
      mc:Ignorable="d" 
      d:DesignHeight="{StaticResource frameHeight}" d:DesignWidth="{StaticResource frameWidth}"         
      xmlns:UCs="clr-namespace:LOET_HMI.UserControls"
      xmlns:hopa_devices="clr-namespace:LOET_HMI.UserControls.HOPA_Devices"
      Height="auto"
      Title="PgMessages"  >
    <Grid>
        <ScrollViewer  VerticalScrollBarVisibility="Auto">
            <Grid x:Name="gridOfUcMessages"
              Height="auto"  
              FocusableChanged="Grid_FocusableChanged"
              IsKeyboardFocusedChanged="Grid_IsKeyboardFocusedChanged"
              >

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" >
                    <StackPanel x:Name="spUcMsgs">
                        <UCs:UcMessage x:Name="ucMsgsModul1"      Margin="10,5,10,5" iModulNrProperty="1" bFilterByStationActive="True" iStationNrProperty="0" strNameProperty="{x:Static prop:Resources.Proj_StNameModul1}" />
                        <UCs:UcMessage x:Name="ucMsgsModul1Stat1" Margin="10,5,10,5" iModulNrProperty="1" bFilterByStationActive="True" iStationNrProperty="1" strNameProperty="{x:Static prop:Resources.Proj_StNameStation1}"  />
                        <UCs:UcMessage x:Name="ucMsgsModul1Stat2" Margin="10,5,10,5" iModulNrProperty="1" bFilterByStationActive="True" iStationNrProperty="2" strNameProperty="{x:Static prop:Resources.Proj_StNameStation2}"  />
                    </StackPanel>
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="quitSt10Btn" Grid.Column="0" Style="{StaticResource noHoverStyleNoImage}" Content="{x:Static prop:Resources.QuitSt10NIO}" Margin="20,5" Click="QuitSt10Btn_Click" FontSize="16" FontWeight="Bold" Background="Red" Foreground="White"/>
                        <hopa_devices:UcCylinderMin Grid.Column="1" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[0]}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0" ></hopa_devices:UcCylinderMin>
                        <hopa_devices:UcCylinderMin Grid.Column="2" DpCylinderHMI="{Binding ElementName=pgStat, Path=CylList[1]}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0" ></hopa_devices:UcCylinderMin>
                        <Button x:Name="quitSt20Btn" Grid.Column="3" Style="{StaticResource noHoverStyleNoImage}" Content="{x:Static prop:Resources.QuitSt20NIO}" Margin="20,5" Click="QuitSt20Btn_Click" FontSize="16" FontWeight="Bold" Background="Red" Foreground="White"/>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="1" Grid.Column="1" >
                    <Grid.Background>
                        <ImageBrush ImageSource="/LOET_HMI;component/Resources/ZFGesamt.bmp" Stretch="UniformToFill" />
                    </Grid.Background>
                </Grid>
                <!--<Image Grid.Row="1" Grid.Column="1" Source="/LOET_HMI;component/Resources/ZFGesamt.bmp" Stretch="Uniform" Margin="0,20,20,20" HorizontalAlignment="Right" VerticalAlignment="Bottom" MaxHeight="300"/>-->

            </Grid>
        
        </ScrollViewer>
    </Grid>
</Page>
