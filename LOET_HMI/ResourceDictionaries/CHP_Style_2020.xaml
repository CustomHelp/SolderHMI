    <Style x:Key="CHP_AnimatedButton" TargetType="{x:Type Button}">
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="MinHeight" Value="20"/>
        <Setter Property="MinWidth" Value="20"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Name="Border" CornerRadius="7" BorderThickness="1.5" Background="{StaticResource AnimatedButtonBackground}" BorderBrush="{StaticResource AnimatedButtonBorder}">
                        <ContentPresenter Margin="2"   HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="scaButton" ScaleX="1" ScaleY="1"  CenterX="25"  CenterY="25" />
                            </TransformGroup>
                        </Border.RenderTransform>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource AnimatedButtonBackground}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AnimatedButtonBorder}" />
                        </Trigger>
                        <Trigger Property="IsDefaulted" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource AnimatedButtonBackground}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AnimatedButtonBorder}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource AnimatedButtonBackground}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AnimatedButtonBorder}" />
                        </Trigger>

                        <EventTrigger RoutedEvent="Button.PreviewMouseDown">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleX)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="1.0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.2" Value="0.9" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <!-- ScaleY -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleY)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="1.0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.2" Value="0.9" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>

                        <EventTrigger RoutedEvent="Button.PreviewMouseUp">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleX)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="0.9" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.5" Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <!-- ScaleY -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleY)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="0.9" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.5" Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

