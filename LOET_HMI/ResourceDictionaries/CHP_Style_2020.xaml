<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:UserControls="clr-namespace:LOET_HMI.UserControls"      
                    xmlns:Themes="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2"
                    xmlns:local="clr-namespace:LOET_HMI">
    
    <!-- INFO: die folgenden Definitionen wurden vom Projekt REEB und HOMS in 2020 übernommen -->

    <!-- ============================================================= -->
    <!-- ==== Corporate Design (Customhelp) - zentrale Markenfarben === -->
    <!-- Primaer = Lila, Sekundaer = Tuerkis. Alle Marken-Literale -->
    <!-- referenzieren diese vier Resources (Color fuer Gradient-Stops, -->
    <!-- Brush fuer direkte Background/Foreground/BorderBrush-Zuweisung). -->
    <Color x:Key="Brand_PrimaryColor">#FF782182</Color>
    <Color x:Key="Brand_SecondaryColor">#FF00AEC8</Color>
    <SolidColorBrush x:Key="Brand_Primary"   Color="{StaticResource Brand_PrimaryColor}" />
    <SolidColorBrush x:Key="Brand_Secondary" Color="{StaticResource Brand_SecondaryColor}" />

    <!-- Design-Modernisierung 2026: Dunkelgrau als neue Flaechenfarbe fuer -->
    <!-- Header/Navigation/Dialog-Header. Lila (Brand_Primary) wird ab jetzt -->
    <!-- NUR noch als Akzent verwendet (aktiver Menuepunkt, Trennlinien, Fokus). -->
    <Color x:Key="Brand_DarkColor">#FF2D2D2D</Color>
    <SolidColorBrush x:Key="Brand_Dark" Color="{StaticResource Brand_DarkColor}" />
    <!-- Aktiver Menuepunkt: leichter Lila-Hintergrund (entspricht rgba(120,33,130,0.2)) -->
    <SolidColorBrush x:Key="Brand_PrimaryFaint" Color="#33782182" />
    <!-- ============================================================= -->

    <SolidColorBrush x:Key="CHP_ColorBrush" Color="{StaticResource Brand_PrimaryColor}" />


    <ControlTemplate x:Key="GlobButtonTempl">
        <Grid>
            <Ellipse  Fill="CadetBlue"/>
            <ContentControl HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding Property=ContentControl.Content}"/>
        </Grid>
    </ControlTemplate>

    <Style x:Key="RENA_GroupBox_Style" TargetType="GroupBox" >
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="#FFE8E8E8" />
        <Setter Property="Padding" Value="0,5,10,0"/>
        <!--Ohne dem 3. Wert dieses Propertys verschiebt sich der Inhalt nach rechts außen. Wenn das Padding so gesetzt wird, und die Child-Elemente HorizontalAlignment="Stretch" Wert haben, bleiben schön innerhalb des Groupbox-Rahmens. -->
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>

                    <TextBlock Text="{Binding}" Width="{Binding ActualWidth, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type GroupBox}}}"  Margin="-9,0,0,0" Padding="3,2,0,4"  FontWeight="Bold"  FontSize="14"  HorizontalAlignment="Stretch"  VerticalAlignment="Top"  Foreground="#FF013F84" >

                        <TextBlock.Background >
                            <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                                <GradientStop Color="#FFDEDBDE" Offset="0.9"/>
                                <GradientStop Color="#FF013F84" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Background>

                    </TextBlock>

                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <Style TargetType="{x:Type CheckBox}" x:Key="RENA_CheckboxStyle_LED">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">

                    <Image x:Name="checkboxImage"  Width="18" RenderOptions.BitmapScalingMode="Fant" />

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkboxImage" Property="Source" Value="/LOET_HMI;component/Resources/LEDs/led-green-th.png"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="checkboxImage" Property="Source" Value="/LOET_HMI;component/Resources/LEDs/grey-led-small.png"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style TargetType="{x:Type Button}" x:Key="noHoverStyleNoImage">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" BorderBrush="Black" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <Style TargetType="{x:Type CheckBox}" x:Key="CheckboxStyle_LED_Cyl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">

                    <Image x:Name="checkboxImage"  Width="30" RenderOptions.BitmapScalingMode="Fant" />

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkboxImage" Property="Source" Value="/LOET_HMI;component/Resources/LEDs/led-green-th.png"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="checkboxImage" Property="Source" Value="/LOET_HMI;component/Resources/LEDs/grey-led-small.png"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>




    <Style TargetType="{x:Type Button}" x:Key="RENA_NavButtonStyle">
        <Setter Property="Background" Value="{StaticResource CHP_ColorBrush}" />
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Height" Value="50" />
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="10,0,0,0" />
        <!-- Text des Buttons von den Seiten nach innen verschienben "LINKS, OBEN, RECHTS, UNTEN"-->
        <Setter Property="FontSize" Value="16" />
        <!-- 
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}" >
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="Black" />
                        </Trigger>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            -->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Name="myBorder" 
                            Background      ="{TemplateBinding Background}" 
                            BorderBrush     ="{TemplateBinding BorderBrush}"
                            BorderThickness ="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"    
                            >
                        
                        <ContentPresenter 
                            HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalAlignment}"
                            
                            >
                            
                        </ContentPresenter>
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="scaButton" ScaleX="1" ScaleY="1"  CenterX="25"  CenterY="25" />
                            </TransformGroup>
                        </Border.RenderTransform>
                    </Border>


                    <ControlTemplate.Triggers>
                        <!-- Mouse-Over Farben -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="myBorder" Property="BorderBrush" Value="{StaticResource Brand_Secondary}" />
                            <Setter Property="Foreground" Value="{StaticResource Brand_Secondary}" />
                            <Setter Property="Background" Value="{StaticResource Brand_Primary}" />
                        </Trigger>

                        <!-- Animation -->
                        <EventTrigger RoutedEvent="Button.PreviewMouseDown">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleX)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="1.0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.2" Value="0.9" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <!-- ScaleY -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleY)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="1.0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.2" Value="0.9" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>

                        <EventTrigger RoutedEvent="Button.PreviewMouseUp">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleX)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="0.95" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.1" Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <!-- ScaleY -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="scaButton" Storyboard.TargetProperty="(ScaleTransform.ScaleY)">
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.0" Value="0.95" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:00.1" Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>




                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>




        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="True">
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="Gray" />
            </Trigger>
        </Style.Triggers>








    </Style>





    <Style TargetType="{x:Type Button}" x:Key="RENA_NavWorkspaceButtonStyle" >
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="20,3,20,5" />
