    <Style x:Key="RENA_PopUpStlye" TargetType="{x:Type Window}">
        <Setter Property="Height" Value="450" />
        <Setter Property="Width" Value="600" />
        <Setter Property="ResizeMode" Value="NoResize" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Window}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Rectangle Grid.Row="0" Height="120"  >
                            <Rectangle.Fill>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="{StaticResource Brand_PrimaryColor}" Offset="0.368"/>
                                    <GradientStop Color="#DAD4E8" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        
                        <Rectangle x:Name="RectLogo"  Grid.Row="0" Margin=" 10,-50,10,10"  Width="180"  HorizontalAlignment="Right"    >
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="/LOET_HMI;component/Resources/CHP.png" Stretch="Uniform" />
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Header -->
                        <Border Grid.Row="0" >
                            <Grid>
                                <TextBlock  Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Title}" Grid.Row="0" Foreground="White" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15"/>
                            </Grid>
                        </Border>


                        <!-- Body -->
                        <Grid  Grid.Row="1" >
                            <Rectangle Grid.Row="1" Fill="#FFF7F7F7" />
                            <ContentPresenter/>
                        </Grid>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

