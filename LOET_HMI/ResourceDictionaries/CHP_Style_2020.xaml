        <Setter Property="DpBackgroundFeedbackOff" Value="LightGray" />
        <Setter Property="DpBackgroundFeedbackOn" Value="LawnGreen" />
        -->
        
        <!-- 
        Hintergrund zum selber definierten Template: wenn ein Taster am Touch-Display gedrückt wird, bleibt der Taster hell blaue ("Highlighted" Zustand).
        Deswegen 
        -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Name="myBorder" 
                            Background      ="{TemplateBinding Background}" 
                            BorderBrush     ="{TemplateBinding BorderBrush}"
                            BorderThickness ="{TemplateBinding BorderThickness}"
