    <!-- Meldefenster -->
    <Style x:Key="StyleCHP_MessDataGridCell" TargetType="{x:Type DataGridCell}">
        <Style.Triggers>
            <Trigger Property="DataGridCell.IsSelected" Value="True">
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="Transparent"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            </Trigger>
            <!-- Farbe der Meldungen -->
            <!-- cMTNoType - Kein Meldetyp asgewählt -->
            <DataTrigger Binding="{Binding iType}"  Value="0">
                <Setter Property="Background" Value="White" />
            </DataTrigger>

            <!-- cMTErrorQuit - Zu quittierender Fehler der noch nicht behoben ist -->
            <DataTrigger Binding="{Binding iType}"  Value="1">
                <Setter Property="Background" Value="#BFFF0000" />
            </DataTrigger>
            <!-- cMTErrorGone - Zu quittierender Fehler der behoben ist -->
            <DataTrigger Binding="{Binding iType}"  Value="2">
                <Setter Property="Background" Value="#BFFF0000" />
            </DataTrigger>

            <!-- cMTErrorMess - selbst quittierender Fehler -->
            <DataTrigger Binding="{Binding iType}"  Value="3">
                <Setter Property="Background" Value="#BFFF0000" />
            </DataTrigger>

            <!-- cMTWarning - Warnung -->
            <DataTrigger Binding="{Binding iType}"  Value="4">
                <Setter Property="Background" Value="#BFFEFF55" />
            </DataTrigger>

            <!-- cMTWaiting - Warte-Meldung -->
            <DataTrigger Binding="{Binding iType}"  Value="5">
                <Setter Property="Background" Value="#BFFFBE00" />
            </DataTrigger>

            <!-- cMTMessage - Hinweis -->
            <DataTrigger Binding="{Binding iType}"  Value="6">
                <Setter Property="Background" Value="#BF00CCFF" />
            </DataTrigger>

            <!-- cMTManual - Handbetrieb -->
            <DataTrigger Binding="{Binding iType}"  Value="7">
                <Setter Property="Background" Value="#BF3366FF" />
            </DataTrigger>

            <!-- cMTModulMess - Modul-Meldung (z.B. Betriebsart) -->
            <DataTrigger Binding="{Binding iType}"  Value="8">
                <Setter Property="Background" Value="#BF9031EE" />
            </DataTrigger>

        </Style.Triggers>
    </Style>


