<Window xmlns:UserControls="clr-namespace:LOET_HMI.UserControls"  
        x:Class="LOET_HMI.SystemPages.PopUps.WindowPopUpSetValue"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI.SystemPages.PopUps"
        mc:Ignorable="d"
        
        xmlns:prop="clr-namespace:LOET_HMI.Properties"
        Title="{x:Static prop:Resources.DlgSetVal_Titel}"       
        Style="{StaticResource RENA_PopUpStlye}" 
        WindowStartupLocation="CenterScreen" Height="600" Width="700"
        Loaded="Window_Loaded"
        FontSize="18"
        
        
        >
    <!-- Das obige "FontSize" Property setzt den Default-FontSize-Wert der Child-Elementen -->
    <!--PreviewMouseUp="StackPanel_PreviewMouseUp"-->



    <Grid>


        <StackPanel>
            <TextBlock Text="{Binding SettingName, FallbackValue=_ParameterName}"  FontSize="22" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"  VerticalAlignment="Top" Margin="30,25,30,0" />
            <TextBlock Text="{Binding Description, FallbackValue=_Descritpion}"  HorizontalAlignment="Center"  VerticalAlignment="Top" Margin="0,10,0,35"/>

            <Separator Margin="20,0,20,-10"   >
                <Separator.LayoutTransform>
                    <RotateTransform Angle="0" />
                </Separator.LayoutTransform>
            </Separator>



            <Grid Margin="0,0,0,0" Height="100" >
                
                <StackPanel Name="groupPanel" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,3" Height="100" >
                    <Grid x:Name="gridNumVal" Width="400"  VerticalAlignment="Bottom" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="132"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition  Height="40" />
                            <RowDefinition  Height="40" />
                        </Grid.RowDefinitions>

                        <TextBlock  Grid.Row="0" Grid.Column="0" Text="{x:Static prop:Resources.DlgSetVal_tbCurrentVal}"  HorizontalAlignment="Left"  VerticalAlignment="Center" Height="24" Width="120" />

                        <StackPanel Grid.Row="0" Grid.Column="1"  Orientation="Horizontal" >
                            <TextBlock  Grid.Row="0" Grid.Column="1"  Text="{Binding ActVal}"  HorizontalAlignment="Left" TextAlignment="Center" VerticalAlignment="Center" Height="24" Width="{Binding ElementName=txtAnswer, Path=Width}"  />
                            <TextBlock x:Name="tbUnit1"  Margin="2,0,2,0" VerticalAlignment="Center" >
                                <Run Text="[" />
                                <Run Text="{Binding Unit}" />
                                <Run Text="]" />
                            </TextBlock>
                        </StackPanel>

                        <TextBlock  Grid.Row="1" Grid.Column="0" Text="{x:Static prop:Resources.DlgSetVal_tbNewVal}"  HorizontalAlignment="Left"  VerticalAlignment="Center" Margin="0,3" Height="24" Width="120" />
                        <StackPanel Grid.Row="1" Grid.Column="1"  Orientation="Horizontal" Panel.ZIndex="1" x:Name="spCol1" >
                            <TextBox   Name="txtAnswer"  Width="180" Height="35" Padding="4" VerticalAlignment="Center" HorizontalContentAlignment="Center" 
                                       PreviewMouseDown="TxtAnswer_PreviewMouseDown"
                                       PreviewTouchDown="TxtAnswer_PreviewTouchDown"
                                                                             
                                       Text="_Wert"
                                       
                                       />
                            <TextBlock x:Name="tbUnit2"  Margin="2,0,2,0" VerticalAlignment="Center" >
                                <Run Text="[" />
                                <Run Text="{Binding Unit}" />
                                <Run Text="]" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>


                    <!-- 
                    <UserControls:UcSettingAnalogString Width="104" VerticalAlignment="Center"   />
                    -->

                    <ComboBox x:Name="cbDropDown" SelectedValuePath="Content" Height="30" VerticalContentAlignment="Bottom" Width="140" Margin="10,5,0,-60" SelectionChanged="CbDropDown_SelectionChanged" PreviewTouchDown="CbDropDown_PreviewTouchDown" MouseDown="CbDropDown_MouseDown"  >

                    </ComboBox>

                    <ToggleButton Name="ToggleButton" Width="90" Height="45" Margin="0,0,0,-55" Style="{StaticResource SwitchTypeToggleButton}" Checked="ToggleButton_Checked"  Unchecked="ToggleButton_Unchecked"/>

                </StackPanel>
                <Button Grid.Row="1" x:Name="btnSet" Content="{x:Static prop:Resources.DlgSetVal_btnSet}" Width="100" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,40,0" IsDefault="True" Background="LawnGreen" Click="BtnSet_Click"   />
                <!--PreviewTouchDown="BtnSet_PreviewTouchDown"-->
            </Grid>

            <Separator Margin="20,10,20,0"   >
                <Separator.LayoutTransform>
                    <RotateTransform Angle="0" />
                </Separator.LayoutTransform>
            </Separator>

            <TextBlock  Name="tbMin"  HorizontalAlignment="Center"  VerticalAlignment="Top" Margin="0,10,0,0" >
                <Run Text="{x:Static prop:Resources.DlgSetVal_tbRangeMin}" />
                <Run Text="{Binding Min_lim}"/>
            </TextBlock>
            <TextBlock Name="tbMax"   HorizontalAlignment="Center"  VerticalAlignment="Top" Margin="0,15,0,0" >
                <Run Text="{x:Static prop:Resources.DlgSetVal_tbRangeMax}"/>
                <Run Text="{Binding Max_lim}"/>
            </TextBlock>

            <Separator Margin="20,10,20,0"   >
                <Separator.LayoutTransform>
                    <RotateTransform Angle="0" />
                </Separator.LayoutTransform>
            </Separator>

        </StackPanel>


        <Button x:Name="btnClose" Content="{x:Static prop:Resources.Btn_Cancel}" VerticalAlignment="Bottom"  Width="140" Height="50" Margin="0,0,0,30" IsCancel="True" Click="BtnClose_Click" PreviewTouchDown="BtnClose_PreviewTouchDown"  />
    </Grid>


</Window>
