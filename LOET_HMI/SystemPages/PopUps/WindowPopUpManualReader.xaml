<Window x:Class="LOET_HMI.SystemPages.PopUps.WindowPopUpManualReader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI.SystemPages.PopUps"
        mc:Ignorable="d"
      Title="WindowPopUpManualReader"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Height="1050" Width="1680">
    <Border BorderBrush="White" BorderThickness="5">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="Indigo" Offset="1"/>
                </LinearGradientBrush>
                <!--<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#66509B" Offset="0"/>
                    <GradientStop Color="#66509B" Offset="1"/>
                </LinearGradientBrush>-->
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Rectangle Grid.Row="0" Height="80"  >
                    <Rectangle.Fill>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#66509B" Offset="0.368"/>
                            <GradientStop Color="#DAD4E8" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>


                <Rectangle x:Name="RectLogo"  Grid.Row="0" Margin=" 10,-25,45,10"  Width="180"  HorizontalAlignment="Right"    >
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Resources/CHP.png" Stretch="Uniform" />
                    </Rectangle.Fill>
                </Rectangle>
                <Button x:Name="closeBtn" HorizontalAlignment="Right" Margin="0,5,7,0" Width="30" Height="30" Click="CloseBtn_Click" BorderBrush="White" VerticalAlignment="Top"
                       HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Foreground="White" BorderThickness="0" >
                    <Button.Background>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/x-button-icon-20_2.png" Stretch="UniformToFill"/>
                    </Button.Background>
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Header -->
                <Border Grid.Row="0" >
                    <Grid>
                        <TextBlock Text="Manual Reader" Grid.Row="0" Foreground="White" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15"/>
                    </Grid>
                </Border>
            </Grid>
            <Grid Grid.Row="1">

                <Grid Grid.Column="1" x:Name="ContentGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="firstPage" Grid.Column="1"  HorizontalAlignment="Right" Margin="40,10,40,10" VerticalAlignment="Stretch"/>
                    <Image x:Name="secondPage" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,10,40,10"/>


                    <Border BorderBrush="White" BorderThickness="2" Margin="10,10,10,10" Grid.Column="0">
                        <Button x:Name="backwardButton" 
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" 
                                Click="BackwardButton_Click" Background="#66509B" >
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <!--
                            <TextBlock Text="Z&#10;U&#10;R&#10;Ü&#10;C&#10;K" TextAlignment="Center" FontSize="30" Foreground="White" ></TextBlock>
                            -->
                            <TextBlock Text="ZURÜCK" Width="25" TextAlignment="Center" FontSize="30" Foreground="White" TextWrapping="Wrap"></TextBlock>

                        </Button>
                    </Border>

                    <Border BorderBrush="White" BorderThickness="2" Margin="10,10,10,10" Grid.Column="3">
                        <Button x:Name="forwardButton" 
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" 
                                Click="ForwardButton_Click" Background="#66509B">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="V&#10;O&#10;R&#10;W&#10;Ä&#10;R&#10;T&#10;S" TextAlignment="Center" FontSize="30" Foreground="White"></TextBlock>
                        </Button>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
