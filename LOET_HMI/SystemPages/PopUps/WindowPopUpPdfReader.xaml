<Window x:Class="LOET_HMI.SystemPages.PopUps.WindowPopUpPdfReader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI.SystemPages.PopUps"
        mc:Ignorable="d"
        Title="WindowPopUpPdfReader"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Height="1050" Width="1680">
    <Border BorderBrush="White" BorderThickness="5">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="Indigo" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header / Toolbar -->
            <Grid Grid.Row="0">
                <Rectangle Height="80" Fill="{StaticResource Brand_Dark}" VerticalAlignment="Top" />
                <!-- Header-Trennlinie unten: 3px Lila-Akzent -->
                <Rectangle Height="3" Fill="{StaticResource Brand_Primary}" VerticalAlignment="Top" Margin="0,77,0,0" />
                <Rectangle Margin="10,-25,45,10" Width="180" HorizontalAlignment="Right">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/CUSTOMHELP_Logo-links_weiss.png" Stretch="Uniform" />
                    </Rectangle.Fill>
                </Rectangle>
                <Button x:Name="closeBtn" HorizontalAlignment="Right" Margin="0,5,7,0" Width="30" Height="30"
                        Click="CloseBtn_Click" BorderBrush="White" VerticalAlignment="Top"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Foreground="White" BorderThickness="0">
                    <Button.Background>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/x-button-icon-20_2.png" Stretch="UniformToFill"/>
                    </Button.Background>
                </Button>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock x:Name="fileLabel" Text="PDF Reader" Foreground="White" FontSize="22" VerticalAlignment="Center" Margin="0,0,30,0"/>
                    <Button x:Name="btnBack" Content="◄ Zurück" Width="110" Height="40" Margin="4,0" FontSize="16" Click="BackButton_Click"/>
                    <Button x:Name="btnForward" Content="Vorwärts ►" Width="110" Height="40" Margin="4,0" FontSize="16" Click="ForwardButton_Click"/>
                    <TextBlock Text="Seite:" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="20,0,6,0"/>
                    <TextBox x:Name="txtPage" Width="60" Height="34" FontSize="16" VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center" KeyDown="TxtPage_KeyDown"/>
                    <Button x:Name="btnGoto" Content="Gehe zu" Width="90" Height="40" Margin="6,0" FontSize="16" Click="GotoButton_Click"/>
                    <TextBlock x:Name="pageInfo" Text="0 / 0" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Button x:Name="btnZoomOut" Content="Zoom −" Width="100" Height="40" Margin="20,0,4,0" FontSize="16" Click="ZoomOutButton_Click"/>
                    <Button x:Name="btnZoomIn" Content="Zoom +" Width="100" Height="40" Margin="4,0" FontSize="16" Click="ZoomInButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- PDF-Seite -->
            <ScrollViewer Grid.Row="1" x:Name="scrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          PanningMode="Both" Margin="10">
                <Image x:Name="pageImage" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
