<Window x:Class="LOET_HMI.SystemPages.PopUps.Window_StartNextOrderManually"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI.SystemPages.PopUps"
        mc:Ignorable="d"
        
                
        Title="{x:Static prop:Resources.PopUpStartOrder_Header}"
        Style="{StaticResource RENA_PopUpStlye}"
        WindowStartupLocation="CenterScreen"
        Height="540" Width="540"
        xmlns:prop="clr-namespace:LOET_HMI.Properties"
        
        Loaded="Window_Loaded" Unloaded="Window_Unloaded"
        >
    <Grid>
        <StackPanel x:Name="StackStatus" VerticalAlignment="Center" HorizontalAlignment="Center" Panel.ZIndex="1" Orientation="Vertical"  Width="400"  Margin="46,14"   >
            <TextBlock   Margin="00,10,0,10" Text="{x:Static prop:Resources.PopUpStartOrder_NextOrder}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Center" FontSize="14"/>

            <Grid Margin="0,0,0,0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition   />
                    <ColumnDefinition   />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" >
                    <TextBlock   Margin="00,3,0,0" Text="{x:Static prop:Resources.PopUpStartOrder_Paramsetname}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock   Margin="00,3,0,0" Text="{x:Static prop:Resources.PopUpStartOrder_Target}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock   Margin="00,3,0,0" Text="{x:Static prop:Resources.PopUpStartOrder_CartonsPerPallet}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock   Margin="00,3,0,0" Text="{x:Static prop:Resources.PopUpStartOrder_CreatedBy}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock   Margin="00,3,0,0" Text="{x:Static prop:Resources.PopUpStartOrder_CreatedOn}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>

                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" >
                    <TextBlock x:Name="tblName"             Margin="00,3,0,0" Text="- name -"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="tblQuant"            Margin="00,3,0,0" Text="- quant -"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="tblCartProPalett"    Margin="00,3,0,0" Text="- cartProPalett -"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="tblCreatedBy"        Margin="00,3,0,0" Text="- CreatedBy -"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="tblCreatedOn"        Margin="00,3,0,0" Text="- CreatedOn -"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Left"/>

                </StackPanel>

            </Grid>


            <TextBlock x:Name="Wirklich"  Margin="00,30,0,0" Text="{x:Static prop:Resources.PopUpStartOrder_Hint}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Center" FontSize="14"/>


            <Grid Margin="0,35,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnStart"      Grid.Column="0" Content="{x:Static prop:Resources.PopUpStartOrder_BtnStart}" IsDefault="True" Click="BtnStart_Click"   Style="{StaticResource RENA_ButtonStyle_PopUp}"   />
                <Button x:Name="BtnCancel"  Grid.Column="1" Content="{x:Static prop:Resources.Btn_Cancel}" IsCancel="True" Click="BtnCancel_Click"  Style="{StaticResource RENA_ButtonStyle_PopUp}" />
            </Grid>

        </StackPanel>
    </Grid>
</Window>
