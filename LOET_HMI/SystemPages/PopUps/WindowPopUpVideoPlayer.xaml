<Window x:Class="LOET_HMI.SystemPages.PopUps.WindowPopUpVideoPlayer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI.SystemPages.PopUps"
        mc:Ignorable="d"
        Title="Video-Instructions" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Topmost="True"
        Height="1000" Width="1900">
    <Border BorderBrush="White" BorderThickness="5">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="Indigo" Offset="1"/>
                </LinearGradientBrush>
                <!--<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="{StaticResource Brand_PrimaryColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource Brand_PrimaryColor}" Offset="1"/>
                </LinearGradientBrush>-->
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Rectangle Grid.Row="0" Height="120" Fill="Black"  />


                <Rectangle x:Name="RectLogo"  Grid.Row="0" Margin=" 10,-50,10,10"  Width="180"  HorizontalAlignment="Right"    >
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/CUSTOMHELP_Logo-links_lila.png" Stretch="Uniform" />
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Header -->
                <Border Grid.Row="0" >
                    <Grid>
                        <TextBlock Text="Video-Instructions" Grid.Row="0" Foreground="White" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15"/>
                    </Grid>
                </Border>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Label Content="Angezeigtes Video:" Foreground="White" FontSize="22"  VerticalAlignment="Top" Margin="324,-106,-1030,0" HorizontalAlignment="Left" Width="1048"/>
                    <Label Content="Test" Foreground="White" FontSize="22" Width="1285" VerticalAlignment="Top" Margin="324,-62,-1267,0" x:Name="videoLabel" HorizontalAlignment="Left"/>


                    <ListBox x:Name="videoList" 
                         VerticalAlignment="Top" Margin="10,10,10,10" HorizontalAlignment="Stretch" 
                         SelectionChanged="VideoList_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True" >
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="Indigo" />
                                    </Trigger>
                                </Style.Triggers>
                                <Style.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                </Style.Resources>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="8*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <MediaElement Grid.Row="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="videoPlayer" Margin="0,20,20,0" MinHeight="300" MinWidth="500"
                              MediaEnded="VideoPlayer_MediaEnded" MediaFailed="VideoPlayer_MediaFailed" Grid.ColumnSpan="2"/>
                    <Grid Grid.Row="1" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="playButton" Grid.Column="0"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch"  Margin="40,10,40,10"
                                Click="PlayButton_Click">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Image Source="/LOET_HMI;component/Resources/StatusRun_grey_100.png"/>
                            </Button>
                            <Button x:Name="pauseButton" Grid.Column="1"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="40,10,40,10"
                                Click="PauseButton_Click">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Image Source="/LOET_HMI;component/Resources/StatusPause_grey_100.png"/>
                            </Button>
                            <Button x:Name="stopButton" Grid.Column="2"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="40,10,40,10"
                                Click="StopButton_Click">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Image Source="/LOET_HMI;component/Resources/StatusStop_grey_100.png"/>
                            </Button>
                            <Button x:Name="backwardButton" Grid.Column="3"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="35,5,35,5"
                                Click="BackwardButton_Click">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Image Source="/LOET_HMI;component/Resources/Backward_disabled_grey.png"/>
                            </Button>
                            <Button x:Name="forwardButton" Grid.Column="4"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="35,5,35,5"
                                Click="ForwardButton_Click">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Image Source="/LOET_HMI;component/Resources/Backward_disabled_grey_gespiegelt.png"/>
                            </Button>
                            <Button x:Name="Close" Grid.Column="5"
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="35,5,35,5"
                                Click="Close_Click">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Image Source="/LOET_HMI;component/Resources/x_button.png"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
