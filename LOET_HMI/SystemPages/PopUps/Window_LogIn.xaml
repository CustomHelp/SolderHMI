<Window x:Class="HOPA_HMI.Window_LogIn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HOPA_HMI"
        mc:Ignorable="d"
        Title="Window_LogIn" Height="450" Width="800">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF360669" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <WrapPanel x:Name="WrapPanel" Grid.Column="0" HorizontalAlignment="Right" Panel.ZIndex="0" Margin="0,0,0,0">
            <!--Canvas x:Name="CanvasTemplate" Height="205" Width="170" MouseUp="Global_MouseUp">
                <local:
            Member x:Name="MemberTemplate" dpMitarbeiter="{Binding dpMitarbeiter[0], ElementName=HauptFenster}"/>
            </>-->
        </WrapPanel>

        <StackPanel x:Name="StackStatus" VerticalAlignment="Bottom" Grid.Column="1" HorizontalAlignment="Right" Panel.ZIndex="1" Orientation="Vertical" Margin="0,0,17.286,14.714" Width="223" >

            <TextBlock x:Name="tblName" Margin="00,0,0,10" Text="UserName" FontFamily="Arial" FontSize="26" Foreground="#FFFCFCFC"/>
            <TextBlock x:Name="tblLevel" Margin="00,0,0,30" Text="Userlevel" FontFamily="Arial" FontSize="22" Foreground="#FFFCFCFC"/>

            <TextBlock x:Name="tblPasswort" Margin="00,10,0,0" Text="Passwort:" FontFamily="Arial" FontSize="20" Foreground="#FFFCFCFC"/>
            <PasswordBox x:Name="passwordBox"  Margin="00,00,0,0" FontFamily="Arial" FontSize="24"/>
            <Button x:Name="BtnOk" Content="OK" Click="BtnOk_Click"  Height="60" Width="100" Margin="102,10,0,0" Panel.ZIndex="0"  FontSize="24"  RenderTransformOrigin="0.5,0.5" Foreground="#FFFCFCFC"  >
                <Button.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="Black" Offset="0"/>
                        <GradientStop Color="#FF855BEC" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>


        </StackPanel>

    </Grid>
</Window>
