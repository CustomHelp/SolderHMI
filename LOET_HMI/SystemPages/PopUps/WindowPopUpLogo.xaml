<Window x:Class="LOET_HMI.SystemPages.PopUps.WindowPopUpLogo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI.SystemPages.PopUps"
        mc:Ignorable="d"
      Title="Tailor made custom machines" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Topmost="True"
        Height="450" Width="800">
    <Border BorderBrush="White" BorderThickness="5">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="Indigo" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Rectangle Grid.Row="0" Height="120" Fill="{StaticResource Brand_Dark}" VerticalAlignment="Top" />
                <!-- Header-Trennlinie unten: 3px Lila-Akzent -->
                <Rectangle Grid.Row="0" Height="3" Fill="{StaticResource Brand_Primary}" VerticalAlignment="Top" Margin="0,117,0,0" />


                <Rectangle x:Name="RectLogo"  Grid.Row="0" Margin=" 10,-50,10,10"  Width="180"  HorizontalAlignment="Right"    >
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Resources/CHP.png" Stretch="Uniform" />
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Header -->
                <Border Grid.Row="0" >
                    <Grid>
                        <TextBlock Text="Tailor made custom machines" Grid.Row="0" Foreground="White" FontSize="30" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,15,15,15"/>
                    </Grid>
                </Border>
            </Grid>
            <Grid Grid.Row="1">
                <!--<Image Source="/LOET_HMI;component/Resources/CHP.png" VerticalAlignment="Top" HorizontalAlignment="Right" Width="400"  Margin="5"/>-->
                <Label Content="CHP Customhelp GmbH&#10;Philipp-Melanchthon-Straße 14&#10;D-92224 Amberg&#10;Telefon: +49 9621 916110&#10;E-Mail: support@customhelp.de"  VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="30" Foreground="White" MouseDoubleClick="Label_MouseDoubleClick" Margin="0,20,0,0"/>

                <Button x:Name="btnBack" Click="BtnBack_Click" Content="Zurück" FontSize="28" Width="150" Height="60" Margin="0,0,0,20"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="White" Foreground="Indigo">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>

