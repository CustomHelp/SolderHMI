<Window x:Class="LOET_HMI.SystemPages.PopUps.WindowPopUpExcelReader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI.SystemPages.PopUps"
        mc:Ignorable="d"
        Title="WindowPopUpExcelReader"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Height="1050" Width="1680">
    <Border BorderBrush="White" BorderThickness="5">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0"/>
                    <GradientStop Color="Indigo" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Rectangle Height="80">
                    <Rectangle.Fill>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#66509B" Offset="0.368"/>
                            <GradientStop Color="#DAD4E8" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Margin="10,-25,45,10" Width="180" HorizontalAlignment="Right">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/CUSTOMHELP_Logo-links_lila.png" Stretch="Uniform" />
                    </Rectangle.Fill>
                </Rectangle>
                <Button x:Name="closeBtn" HorizontalAlignment="Right" Margin="0,5,7,0" Width="30" Height="30"
                        Click="CloseBtn_Click" BorderBrush="White" VerticalAlignment="Top"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Foreground="White" BorderThickness="0">
                    <Button.Background>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/x-button-icon-20_2.png" Stretch="UniformToFill"/>
                    </Button.Background>
                </Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock x:Name="fileLabel" Text="Excel Reader" Foreground="White" FontSize="24" VerticalAlignment="Center"/>
                    <TextBlock Text="Sheet:" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="40,0,8,0"
                               x:Name="sheetCaption"/>
                    <ComboBox x:Name="sheetCB" Width="260" Height="34" VerticalAlignment="Center"
                              SelectionChanged="SheetCB_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <DataGrid x:Name="dataGrid" Grid.Row="1" Margin="20"
                      IsReadOnly="True" AutoGenerateColumns="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" HeadersVisibility="All"
                      Background="White" RowBackground="White" AlternatingRowBackground="#EFEAF7"
                      GridLinesVisibility="All" FontSize="16"/>
        </Grid>
    </Border>
</Window>
