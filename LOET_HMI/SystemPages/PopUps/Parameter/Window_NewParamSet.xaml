<Window x:Class="LOET_HMI.Window_NewParamSet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI"
        mc:Ignorable="d"
        
        
        Title="{x:Static prop:Resources.DlgParamset_lblTitleNew}"
        Height="290" Width="500"
        Style="{StaticResource RENA_PopUpStlye}" 
        WindowStartupLocation="CenterScreen"
        xmlns:prop="clr-namespace:LOET_HMI.Properties"
        >
   
    <Grid>

        <StackPanel x:Name="StackStatus" VerticalAlignment="Bottom" HorizontalAlignment="Center" Panel.ZIndex="1" Orientation="Vertical" Margin="0,0,17.286,14.714" Width="350" >

            <TextBlock x:Name="tblName" Text="Name:"   Margin="0,10,0,0" Style="{StaticResource RENA_TextBlockStyle_PopUp}"  />
            <TextBox x:Name="tbName"  Margin="0,0,0,0" Style="{StaticResource RENA_TextBoxStyle_PopUp}" GotFocus="TbName_GotFocus"/>



            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnOk"      Grid.Column="0" Content="{x:Static prop:Resources.Btn_OK}"     IsDefault="True" Click="BtnOk_Click"   Style="{StaticResource RENA_ButtonStyle_PopUp}"   />
                <Button x:Name="BtnCancel"  Grid.Column="1" Content="{x:Static prop:Resources.Btn_Cancel}" IsCancel="True" Click="BtnCancel_Click"  Style="{StaticResource RENA_ButtonStyle_PopUp}" />
            </Grid>

        </StackPanel>


    </Grid>
</Window>
