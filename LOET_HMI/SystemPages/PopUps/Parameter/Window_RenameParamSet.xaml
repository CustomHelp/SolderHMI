<Window x:Class="LOET_HMI.Window_RenameParamSet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI"
        mc:Ignorable="d"
        
        Title="{x:Static prop:Resources.DlgParamset_lblTitleRename}"
        Height="370" Width="500"
        Style="{StaticResource RENA_PopUpStlye}" 
        WindowStartupLocation="CenterScreen"
        xmlns:prop="clr-namespace:LOET_HMI.Properties"
        
        >

    <Grid>

        <StackPanel x:Name="StackStatus" VerticalAlignment="Center" HorizontalAlignment="Center" Panel.ZIndex="1" Orientation="Vertical"  Width="350" Height="180" >

            <TextBlock x:Name="tblName"     Margin="0,0,0,0" Text="{x:Static prop:Resources.DlgParamset_lblActName}"      Style="{StaticResource RENA_TextBlockStyle_PopUp}"/>
            <TextBlock x:Name="tbActName"   Margin="0,0,0,0" Text="MeinNameIstHase"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}"/>

            <TextBlock x:Name="tblNameNeu"  Margin="00,20,0,0" Text="{x:Static prop:Resources.DlgParamset_lblNewName}"    Style="{StaticResource RENA_TextBlockStyle_PopUp}"/>
            <TextBox x:Name="tbName"  Margin="00,00,0,0" Style="{StaticResource RENA_TextBoxStyle_PopUp}" GotFocus="TbName_GotFocus" />

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnOk"      Grid.Column="0" Content="{x:Static prop:Resources.Btn_OK}"    IsDefault="True" Click="BtnOk_Click"   Style="{StaticResource RENA_ButtonStyle_PopUp}"   />
                <Button x:Name="BtnCancel"  Grid.Column="1" Content="{x:Static prop:Resources.Btn_Cancel}" IsCancel="True" Click="BtnCancel_Click"  Style="{StaticResource RENA_ButtonStyle_PopUp}" />
            </Grid>

        </StackPanel>


    </Grid>
</Window>
