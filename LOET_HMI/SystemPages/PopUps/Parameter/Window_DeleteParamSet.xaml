<Window x:Class="LOET_HMI.Window_DeleteParamSet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOET_HMI"
        mc:Ignorable="d"
        
        Title="{x:Static prop:Resources.DlgParamset_lblTitleDelete}"
        Height="336.904" Width="500"
        Style="{StaticResource RENA_PopUpStlye}" 
        WindowStartupLocation="CenterScreen"    
        xmlns:prop="clr-namespace:LOET_HMI.Properties"
        >

    <Grid>

        <StackPanel x:Name="StackStatus" VerticalAlignment="Center" HorizontalAlignment="Center" Panel.ZIndex="1" Orientation="Vertical"  Width="400" Height="158" Margin="46,14"   >
            <TextBlock x:Name="tblName"  Margin="00,10,0,0" Text="- name -"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="Wirklich"  Margin="00,10,0,0" Text="{x:Static prop:Resources.DlgParamset_lblReallyDelete}"  Style="{StaticResource RENA_TextBlockStyleLARGE_PopUp}" HorizontalAlignment="Center" FontSize="14"/>


            <Grid Margin="0,35,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnOk"      Grid.Column="0" Content="{x:Static prop:Resources.Btn_Delete}" IsDefault="True" Click="BtnOk_Click"   Style="{StaticResource RENA_ButtonStyle_PopUp}"   />
                <Button x:Name="BtnCancel"  Grid.Column="1" Content="{x:Static prop:Resources.Btn_Cancel}" IsCancel="True" Click="BtnCancel_Click"  Style="{StaticResource RENA_ButtonStyle_PopUp}" />
            </Grid>

        </StackPanel>


    </Grid>
</Window>
