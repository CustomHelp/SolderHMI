<UserControl x:Class="LOET_HMI.UserControls.UcContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="200" 
             Name="UC_Container">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Rectangle Grid.Row="0"  Fill="#FFD9D9D9" />
        <TextBlock x:Name="tbHeader" Grid.Row="0" HorizontalAlignment="Left" Text="{Binding sHeaderContent}" VerticalAlignment="Top" Margin="2,2,0,2" Foreground="#FF013F84" FontWeight="Bold" >
        </TextBlock>

        <Separator  Grid.Row="0" VerticalAlignment="Bottom" Margin="0,0,0,0"  Background="#FF013F84"  >
            <!-- horizontale Linie zur Gliederung-->
            <Separator.LayoutTransform>
                <RotateTransform Angle="0" />
            </Separator.LayoutTransform>
        </Separator>


        <Canvas Grid.Row="1" Background="#FFE8E8E8" Margin="0,0,0,0" >
            <!-- <ContentPresenter Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Content}" />  -->   <!-- in diesem Bereich kann man die benutzerdefinierten Inhalte platzieren-->
            <ContentControl Content="{Binding PlaceHolder1, ElementName=UC_Container}"/>
        </Canvas>
    </Grid>

</UserControl>
