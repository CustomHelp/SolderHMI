<UserControl x:Class="LOET_HMI.UserControls.UcTimePickerCHP"
             x:Name="TimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="100"
             Loaded="TimePicker_Loaded"
             >
    <Grid>
        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="3.5*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3.5*"/>

        </Grid.ColumnDefinitions>

        <TextBox   x:Name="tbHour"     Text="00"  Grid.Column="0"  FontSize="{Binding ElementName=TimePicker, Path=FontSizeUC}"  VerticalAlignment="Stretch"  HorizontalAlignment="Stretch" TextAlignment="Center" VerticalContentAlignment="Center" GotFocus="TbHour_GotFocus" PreviewMouseDown="TbHour_PreviewMouseDown"/>
        <TextBlock x:Name="tbPoints"   Text=":"   Grid.Column="1"  FontSize="{Binding ElementName=TimePicker, Path=FontSizeUC}"    VerticalAlignment="Center" TextAlignment="Center" />
        <TextBox   x:Name="tbMinutes"  Text="00"  Grid.Column="2"  FontSize="{Binding ElementName=TimePicker, Path=FontSizeUC}"    VerticalAlignment="Stretch" HorizontalAlignment="Stretch" TextAlignment="Center" VerticalContentAlignment="Center" GotFocus="TbMinutes_GotFocus" PreviewMouseDown="TbMinutes_PreviewMouseDown" />

    </Grid>
</UserControl>
