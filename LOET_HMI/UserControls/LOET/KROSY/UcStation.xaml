<UserControl xmlns:LOET_HMI="clr-namespace:LOET_HMI"  xmlns:UserControls="clr-namespace:LOET_HMI.UserControls"  
             x:Class="LOET_HMI.UserControls.LOET.UcStation"
             x:Name="ucStatObj"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.LOET"
             xmlns:prop="clr-namespace:LOET_HMI.Properties"
             mc:Ignorable="d" 
             xmlns:uc="clr-namespace:LOET_HMI.UserControls"
             d:DesignHeight="900" d:DesignWidth="640"
             Loaded="UcStatObj_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />
            <RowDefinition  Height="auto" />


        </Grid.RowDefinitions>

        <!-- 
        <StackPanel Grid.Row="1" >
            <uc:UcValueInOut x:Name="val1"  Style="{StaticResource ucValueInOutStyle_LOET}" />
            <uc:UcValueInOut x:Name="val2"  Style="{StaticResource ucValueInOutStyle_LOET}"/>
            <uc:UcValueInOut x:Name="val3"  Style="{StaticResource ucValueInOutStyle_LOET}" />
            <uc:UcValueInOut x:Name="val4"  Style="{StaticResource ucValueInOutStyle_LOET}" />
            <uc:UcValueInOut x:Name="val5"  Style="{StaticResource ucValueInOutStyle_LOET}" />
        </StackPanel>
        -->
        <Rectangle x:Name="rectBackground" Grid.RowSpan="11" Grid.ColumnSpan="2" Fill="LightGray" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>


        <Grid Grid.Row="0" Margin="0,0,0,20" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"  />
                <RowDefinition Height="auto"  />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ElementName=ucStatObj, Path=UCStationName, FallbackValue=_StationName}" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="0,5,0,10"/>



            <StackPanel  Grid.Row="1"  Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_Scancode}"  />
                    <TextBox   x:Name="tbScancode"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_KSIDENT}" />
                    <TextBox   x:Name="tbKSIdent"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_Amount}"  />
                    <TextBox   x:Name="tbAmount"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_AmountOK}"  />
                    <TextBox   x:Name="tbAmountOK"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
            </StackPanel>


            <Button  x:Name="btnReset" Grid.Row="1" Width="120" Height="80" 
                     Content="{x:Static prop:Resources.ProjKROSY_btnReset}" FontSize="22" HorizontalAlignment="Right" Margin="0,0,100,0" 
                     Click="BtnReset_Click" >
            </Button>
        </Grid>

        <Rectangle Grid.Row="2" Grid.RowSpan="5" Margin="20,5,20,10" Grid.ColumnSpan="2" >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFA8A7A7" Offset="1"/>
                    <GradientStop Color="#FFC5C4C4"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!--
        <Separator  Grid.Row="1" Margin="5,20,5,0">
            <Separator.LayoutTransform>
                <RotateTransform Angle="0" />
            </Separator.LayoutTransform>
        </Separator>
        -->

        <Grid Grid.Row="2" Height="auto" Grid.ColumnSpan="2">
            <TextBlock Grid.Row="0" Grid.Column="1"  FontSize="18" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,10,0,-20">
                <Run   Text="{x:Static prop:Resources.ProjKROSY_Station}" />
                <Run   Text="{x:Static prop:Resources.ProjKROSY_Object}" />
            </TextBlock>
        </Grid>


        <Grid Grid.Row="3" Height="70" Grid.ColumnSpan="2" Margin="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="col0" Width="20" />
                <ColumnDefinition x:Name="col1" Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding ElementName=col1, Path=Width}"  />
                <ColumnDefinition Width="{Binding ElementName=col0, Path=Width}"  />

            </Grid.ColumnDefinitions >

            <Button Grid.Column="1" x:Name="btnLeft" Style="{StaticResource CHP_AnimatedButton}"    HorizontalAlignment="Center" Click="BtnLeft_Click">
                <Image Source="/LOET_HMI;component/Resources/Arrow Left.png" ></Image>
            </Button>

            <Button Grid.Column="3" x:Name="btnRight" Style="{StaticResource CHP_AnimatedButton}"    HorizontalAlignment="Center" Click="BtnRight_Click">
                <Image Source="/LOET_HMI;component/Resources/Arrow Right.png" ></Image>
            </Button>

            <TextBlock  x:Name="tblStatObjNr"  Grid.Column="2"  
                        Text="{Binding ElementName=ucStatObj, Path=iActObject, FallbackValue=_Nr}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center" 
                        FontSize="18" >
            </TextBlock>
        </Grid>

        <GroupBox Header="{x:Static prop:Resources.ProjKROSY_KROSYState}" Grid.Row="4" Grid.Column="0" Margin="20,10,0,0" Style="{StaticResource groupboxStyle_KROSY}" >
            <StackPanel >
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" >
                        <Run Text="{x:Static prop:Resources.ProjKROSY_Object}"  />
                        <Run Text="{x:Static prop:Resources.ProjKROSY_Type}"  />
                    </TextBlock>
                    <TextBox   x:Name="tbKROSYState_ObjType"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}"  >
                        <Run Text="{x:Static prop:Resources.ProjKROSY_Object}"  />
                        <Run Text="{x:Static prop:Resources.ProjKROSY_State}"  />
                    </TextBlock>
                    <TextBox   x:Name="tbKROSYState_ObjState"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{x:Static prop:Resources.ProjKROSY_PLCState}" Grid.Row="5" Grid.Column="0"  Style="{StaticResource groupboxStyle_KROSY}" Margin="20,10,0,0"  >
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" >
                        <Run Text="{x:Static prop:Resources.ProjKROSY_Object}"  />
                        <Run Text="{x:Static prop:Resources.ProjKROSY_Type}"  />
                    </TextBlock>                    <TextBox    x:Name="tbPLCState_ObjType" Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}"  >
                        <Run Text="{x:Static prop:Resources.ProjKROSY_Object}"  />
                        <Run Text="{x:Static prop:Resources.ProjKROSY_State}"  />
                    </TextBlock>                    <TextBox    x:Name="tbPLCState_ObjState" Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{x:Static prop:Resources.ProjKROSY_OrderData}" Grid.Row="4" Grid.RowSpan="3" Grid.Column="1"  Style="{StaticResource groupboxStyle_KROSY}" Margin="0,10,20,30" >
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_ksidnet}"  />
                    <TextBox    x:Name="tbksidnetObject" Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}">
                        <Run Text="{x:Static prop:Resources.ProjRFID_WT}" />
                        <Run Text="{x:Static prop:Resources.ProjRFID_Number}" />
                    </TextBlock>
                    <TextBox    x:Name="tbWTNr" Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" >
                        <Run Text="{x:Static prop:Resources.ProjRFID_Inductor}" />
                        <Run Text="{x:Static prop:Resources.ProjRFID_Number}" />
                    </TextBlock>
                    <TextBox    x:Name="tbINDNr"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjWT_Override}"  />
                    <TextBox    x:Name="tbOverride"  Style="{StaticResource tboxStyle_RFID_LOET_Entries_KROSY}"   Text="{Binding ElementName=ucHU5000, Path=DpHU5000HMI.iActPower}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}"   >
                        <Run Text="{x:Static prop:Resources.ProjWT_DVS}" />
                        <Run Text="1" />
                        <Run Text="{x:Static prop:Resources.ProjKROSY_On}" />
                    </TextBlock>
                    <LOET_HMI:UcLamp   x:Name="lampDVS1On"    Style="{StaticResource lampStyle_RFID_LOET_Entries_KROSY}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}"  >
                        <Run Text="{x:Static prop:Resources.ProjWT_DVS}" />
                        <Run Text="2" />
                        <Run Text="{x:Static prop:Resources.ProjKROSY_On}" />
                    </TextBlock>
                    <LOET_HMI:UcLamp   x:Name="lampDVS2On"    Style="{StaticResource lampStyle_RFID_LOET_Entries_KROSY}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" >
                        <Run Text="{x:Static prop:Resources.ProjWT_DVS}" />
                        <Run Text="3" />
                        <Run Text="{x:Static prop:Resources.ProjKROSY_On}" />
                    </TextBlock>
                    <LOET_HMI:UcLamp   x:Name="lampDVS3On"   Style="{StaticResource lampStyle_RFID_LOET_Entries_KROSY}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_IO}"  />
                    <LOET_HMI:UcLamp    x:Name="lampIO"  Style="{StaticResource lampStyle_RFID_LOET_Entries_KROSY}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" >
                    <TextBlock   Style="{StaticResource tblockStyle_RFID_LOET_Entries_KROSY}" Text="{x:Static prop:Resources.ProjKROSY_NIO}"    />
                    <LOET_HMI:UcLamp    x:Name="lampNIO"  Style="{StaticResource lampStyle_RFID_LOET_Entries_KROSY}" />
                </StackPanel>
            </StackPanel>
        </GroupBox>


    </Grid>
</UserControl>
