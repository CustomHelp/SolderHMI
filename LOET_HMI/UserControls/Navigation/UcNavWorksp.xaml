<UserControl x:Class="LOET_HMI.UserControls.UcNavWorksp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="90" d:DesignWidth="900" MinHeight="30" MinWidth="800" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
             Name="UC_NavDisplays" >
             
    
 
    <UserControl.Resources>
        <Thickness x:Key="myGlobalMargin" Left="20" Top="0" Right="20" Bottom ="5" ></Thickness> 
        <sys:Double x:Key="myGlobalBtnHeight">14</sys:Double>
        <!-- Hierfür oben hinzugefügt:    xmlns:sys="clr-namespace:System;assembly=mscorlib"       -->
        <!-- Verweis durch: {StaticResource myGlobalBtnHeight}      -->

    </UserControl.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>

        </Grid.RowDefinitions>


        <TextBlock x:Name="tbPageName" Text="{Binding Station_Name, FallbackValue=station_name}"  Grid.Row="0" Margin="5,5,0,5" HorizontalAlignment="Left" FontSize="20"    VerticalAlignment="Center"/>

        <StackPanel x:Name="stackPanelRow1"  Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Stretch"  VerticalAlignment="Stretch"  >
            <Button x:Name="ProbeButton1" Content="Row 1" />
        </StackPanel>

        <StackPanel x:Name="stackPanelRow2"  Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Stretch"  VerticalAlignment="Stretch" >
            <Button x:Name="ProbeButton2" Content="Row 2"  />
        </StackPanel>

        <!-- 
        <Frame x:Name="frDisplays" Content="Frame" HorizontalAlignment="Stretch"  Grid.Row="2" VerticalAlignment="Stretch" />
        -->
        
        <!-- 
        <Canvas Grid.Row="2" HorizontalAlignment="Stretch"   VerticalAlignment="Stretch" Margin="0,0,0,0" >
            <ContentControl Content="{Binding PlaceHolder, ElementName=UC_NavDisplays}"/>

        </Canvas>
        -->


    </Grid>
</UserControl>
