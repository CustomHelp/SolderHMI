<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrSettingAnalogDINT"
             x:Name="UcSettingAnalogDINT"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d"  MouseDown="UcSettingAnalog_MouseDown" Style="{StaticResource UcGrSensorStyle}">
    
    <!--
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,4,0,4" />
        </Style>

        <SolidColorBrush x:Key="BrushOn" Color="LawnGreen" />
        <SolidColorBrush x:Key="BrushOff" Color="LightGray" />
    </UserControl.Resources>
    -->

    <Grid Margin="0,0,5,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Rectangle Grid.RowSpan="2"  >
            <Rectangle.Style >
                <Style  TargetType="{x:Type Rectangle}" BasedOn="{StaticResource UcGrSensorRectOvalStyle}" >
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DpSettingDINT_HMI.bAllowedHMI, ElementName=UcSettingAnalogDINT}" Value="True" >
                            <Setter Property="Fill" Value="{StaticResource UcGrBrushOn}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DpSettingDINT_HMI.bAllowedHMI, ElementName=UcSettingAnalogDINT}" Value="False" >
                            <Setter Property="Fill" Value="{StaticResource UcGrBrushOff}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <Line Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Stretch" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" X1="0" Y1="0" X2="100" Y2="0" Stretch="Uniform"  />

        <TextBlock x:Name="tbRectUp"   Text="{Binding ElementName=UcSettingAnalogDINT, Path=DpSettingDINT_HMI.sFunctionHMI}" Grid.Row="0"  Style="{StaticResource UcGrSensorTextBlockStyleOval}" />
        <TextBlock x:Name="tbRectDown" Text="{Binding ElementName=UcSettingAnalogDINT, Path=DpSettingDINT_HMI.sRIDesignationHMI}" Grid.Row="1" Style="{StaticResource UcGrSensorTextBlockStyleOval}" />

        <Border  Grid.Row="2" Style="{StaticResource UcGrSensorBorderStyle}">
            <TextBlock x:Name="tbValue"  Style="{StaticResource UcGrSensorTextBlockStyleRect}"  >                            
                <Run Text="{Binding DpSettingDINT_HMI.ValHMI, ElementName=UcSettingAnalogDINT}"/>            
                <Run Text="{Binding DpSettingDINT_HMI.sUnitHMI, ElementName=UcSettingAnalogDINT}"/>
            </TextBlock>
        </Border>
        
    </Grid>
    
</UserControl>
