<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrValve"
             x:Name="UcValve"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 

             xmlns:ikriv="clr-namespace:IKriv.Wpf"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"

             Loaded="UcValve_Loaded" Width="auto" Height="auto" MouseDown="UcValve_MouseDown"

             >

    <UserControl.Resources>

        <local:RectConverter x:Key="rectConverter"></local:RectConverter>
        <!-- 
        <local:PointConverter x:Key="PointConverter"></local:PointConverter>
        -->
        <sys:Double x:Key="LocThickness_Thin">1</sys:Double>
        <sys:Double x:Key="LocThickness_Thick">2</sys:Double>

        <Style x:Key="PolygonValveStyle" TargetType="{x:Type Polygon}" >
            <Setter Property="Stroke" Value="Black"  />
            <Setter Property="StrokeThickness" Value="{StaticResource LocThickness_Thin}" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding DpValveHMI.bOut, ElementName=UcValve}" Value="True" >
                    <Setter Property="Fill" Value="{StaticResource BrushValveOn}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DpValveHMI.bOut, ElementName=UcValve}" Value="False" >
                    <Setter Property="Fill" Value="{StaticResource BrushValveOff}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>



    </UserControl.Resources>

    <Grid x:Name="mainGrid" HorizontalAlignment="Center" VerticalAlignment="Center" >
        <Grid.RowDefinitions>
            <RowDefinition x:Name="Row0" Height="10"/>
            <RowDefinition x:Name="Row1" Height="auto"/>
            <RowDefinition x:Name="Row2" Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="Col0" Width="*"/>
            <ColumnDefinition x:Name="Col1" Width="auto"/>
            <ColumnDefinition x:Name="Col2" Width="auto"/>
            <ColumnDefinition x:Name="Col3" Width="*"/>

        </Grid.ColumnDefinitions>



        <Polygon x:Name="PolygonLeft" Grid.Row="1" Grid.Column="1" Style="{StaticResource PolygonValveStyle}"    >
            <!-- HINWEIS: 
            die folgenden Punkte werden im C#-Code GELÖSCHT und anschließend neue Punkte hinzugefügt, 
            die durch das Parameter "length" definiert sind.            
            !!! WENN DIE GRÖßE DES VENTILS GEÄNDERT WERDEN MUSS, MUSS DAHER DAS PARAMETER "length" GEÄNDERT WERDEN !!!
            Im XAML-Code konnten die Point-Objekte nicht parametrisiert vorgegeben werden. 
            Die hier definierten Punkte (die dann gelöscht werden) erleichtern allerdings den Entwurf und das Styling -->
            <Polygon.Points  >
                <Point  X="0"  Y="0"  />
                <Point  X="0"  Y="20" />
                <Point  X="20" Y="10" />
            </Polygon.Points>
        </Polygon>

        <Polygon x:Name="PolygonRight" Grid.Row="1" Grid.Column="2" Style="{StaticResource PolygonValveStyle}" >
            <!-- HINWEIS: 
            die folgenden Punkte werden im C#-Code GELÖSCHT und anschließend neue Punkte hinzugefügt, 
            die durch das Parameter "length" definiert sind.            
            !!! WENN DIE GRÖßE DES VENTILS GEÄNDERT WERDEN MUSS, MUSS DAHER DAS PARAMETER "length" GEÄNDERT WERDEN !!!
            Im XAML-Code konnten die Point-Objekte nicht parametrisiert vorgegeben werden. 
            Die hier definierten Punkte (die dann gelöscht werden) erleichtern allerdings den Entwurf und das Styling -->
            <Polygon.Points >
                <Point X="0"  Y="0"  />
                <Point X="0"  Y="20" />
                <Point X="20" Y="10" />
            </Polygon.Points>
            <Polygon.RenderTransform>
                <RotateTransform Angle="180" CenterX="10" CenterY="10"/>
            </Polygon.RenderTransform>

        </Polygon>

        <Ellipse x:Name="CenterCircle" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"   Width="12" Height="12" Fill="Black" HorizontalAlignment="Center" >

        </Ellipse>

        <TextBlock Grid.Row="2" 
                   Grid.Column="0" 
                   Grid.ColumnSpan="4"  
                   Text="{Binding ElementName=UcValve, Path=DpValveHMI.sRIDesignationHMI}" Margin="0,-2,0,10"
                   Style="{StaticResource UC_RIdescr_TextStyle}"/>

        <Grid x:Name="InnerGrid"  Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Top" Width="20" Height="20" >
            <Ellipse   Stroke="Black" StrokeThickness="{StaticResource LocThickness_Thick}" Fill="White" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Ellipse.Clip>
                    <RectangleGeometry Rect="{Binding ElementName=InnerGrid, Path=Width, Converter={StaticResource rectConverter}}"  />
                    <!-- "Rect" Parameter: "x-coord, y-coord, width, height" -->
                </Ellipse.Clip>
            </Ellipse>

            <Line  X1="0" 
                   Y1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                   X2="{Binding ElementName=InnerGrid, Path=Width}" 
                   Y2="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                   Stroke="Black" 
                   StrokeThickness="{StaticResource LocThickness_Thick}" />

            <Line X1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  Y1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  X2="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  Y2="{Binding ElementName=InnerGrid, Path=Width}" 
                  Stroke="Black" 
                  StrokeThickness="{StaticResource LocThickness_Thick}" />

        </Grid>


        <Border x:Name="borderClickArea" MouseDown="BorderClickArea_MouseDown"  Grid.RowSpan="3" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0.2" Background="Gray" Margin="0,2,0,7" />



        <Rectangle x:Name="rectValveClick" Grid.Row="0"  Grid.RowSpan="2"   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  MouseDown="RectValveClick_MouseDown" Grid.Column="1" Grid.ColumnSpan="2" >
            <Rectangle.Style>
                <Style TargetType="Rectangle">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DpValveHMI.bManualAllowedHMI, ElementName=UcValve}" Value="True" >
                            <Setter Property="Visibility" Value="Visible" />
                            <Setter Property="Margin" Value="25,0,0,17"  />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DpValveHMI.bManualAllowedHMI, ElementName=UcValve}" Value="False" >
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>

                        <!-- Falls das Bild "Manual Mode_White.png"  durch das Bild für "Handfunktion aktiv" erstezt werden muss, wenn Handfunktion aktiv ist -->

                        <DataTrigger Binding="{Binding DpValveHMI.bManOnHMI, ElementName=UcValve}" Value="False" >
                            <!-- 
                            <Setter Property="Fill">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode.png" Stretch="Uniform" />
                                </Setter.Value>
                            </Setter>
                            -->
                            <Setter Property="Fill" Value="Transparent" />
                            <Setter Property="Margin" Value="25,0,0,17"  />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding DpValveHMI.bManOnHMI, ElementName=UcValve}" Value="True" >
                            <Setter Property="Fill">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode - Select.png" Stretch="Uniform" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Margin" Value="15,0,0,0"/>
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </Rectangle.Style>

            <!-- 
            <Rectangle.Fill>
                <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode.png" Stretch="Uniform"/>
            </Rectangle.Fill>
            -->

        </Rectangle>



    </Grid>
</UserControl>
