<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrPump"
             x:Name="UcPump"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 
              Loaded="UcPump_Loaded">
    
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="9*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <Ellipse Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2"  Height="50" Width="50" Stroke="Black" StrokeThickness="1"   >
            <Ellipse.Style>
                <Style TargetType="{x:Type Ellipse}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DpPumpHMI.bOut, ElementName=UcPump}" Value="True" >
                            <Setter Property="Fill" Value="{StaticResource BrushValveOn}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DpPumpHMI.bOut, ElementName=UcPump}" Value="False" >
                            <Setter Property="Fill" Value="{StaticResource BrushValveOff}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>
        <Line x:Name="LineHoriz" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Stretch="Fill" X1="0" Y1="0.5" X2="1" Y2="0.5"   Stroke="Black" />
        <Line x:Name="LineVert"  Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Stretch="Fill" X1="0.5" Y1="0" X2="0.5" Y2="1"   Stroke="Black" />

        <Line x:Name="Line1stQuadr" Grid.Row="0" Grid.Column="1" Stretch="Fill" X1="0" Y1="1" X2="1" Y2="0"  Stroke="Black"   />
        <Line x:Name="Line2ndQuadr" Grid.Row="0" Grid.Column="2" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="1"  Stroke="Black"   />
        <Line x:Name="Line3rdQuadr" Grid.Row="1" Grid.Column="2" Stretch="Fill" X1="0" Y1="1" X2="1" Y2="0"  Stroke="Black"   />
        <Line x:Name="Line4thQuadr" Grid.Row="1" Grid.Column="1" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="1"  Stroke="Black"   />

        <TextBlock Text="{Binding ElementName=UcPump, Path=DpPumpHMI.sRIDesignationHMI}" 
                   Style="{StaticResource UC_RIdescr_TextStyle}" 
                   Grid.Row="2"  Grid.Column="0" Grid.ColumnSpan="4" 
                   HorizontalAlignment="Center" VerticalAlignment="Top"  />

        <Border x:Name="borderClickArea" MouseDown="BorderClickArea_MouseDown"  Grid.RowSpan="3" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0.2" Background="Gray" Margin="0,0,0,2" />


    </Grid>
</UserControl>
