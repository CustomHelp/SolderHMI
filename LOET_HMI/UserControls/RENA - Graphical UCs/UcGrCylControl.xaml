<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrCylControl"
             x:Name="UcCylContr"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 
             
             xmlns:ikriv="clr-namespace:IKriv.Wpf"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Loaded="UcCylContr_Loaded" Unloaded="UcCylContr_Unloaded" >

    <UserControl.Resources>

        <local:RectConverter x:Key="rectConverter"></local:RectConverter>

        <sys:Double x:Key="LocThickness_Thin">1</sys:Double>
        <sys:Double x:Key="LocThickness_Thick">2</sys:Double>

        <Style x:Key="PolygonValveStyle_Left" TargetType="{x:Type Polygon}" >
            <Setter Property="Stroke" Value="Black"  />
            <Setter Property="StrokeThickness" Value="{StaticResource LocThickness_Thin}" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding DpCyl.bValveForerunHMI, ElementName=UcCylContr}" Value="True" >
                    <Setter Property="Fill" Value="{StaticResource BrushValveOn}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DpCyl.bValveForerunHMI, ElementName=UcCylContr}" Value="False" >
                    <Setter Property="Fill" Value="{StaticResource BrushValveOff}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PolygonValveStyle_Right" TargetType="{x:Type Polygon}" >
            <Setter Property="Stroke" Value="Black"  />
            <Setter Property="StrokeThickness" Value="{StaticResource LocThickness_Thin}" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding DpCyl.bValveRestHMI, ElementName=UcCylContr}" Value="True" >
                    <Setter Property="Fill" Value="{StaticResource BrushValveOn}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DpCyl.bValveRestHMI, ElementName=UcCylContr}" Value="False" >
                    <Setter Property="Fill" Value="{StaticResource BrushValveOff}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style  TargetType="TextBlock" x:Key="TextBlockStyle_Setpoint">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>


    </UserControl.Resources>


    <Grid x:Name="grMainUCGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="col0ContainerCylLift1" Width="70"/>
            <ColumnDefinition x:Name="col1ContainerCylLift1" Width="{Binding ElementName=col0ContainerCylLift1, Path=Width}"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="row0ContainerCylLift1" Height="27" />
            <RowDefinition x:Name="row1ContainerCylLift1" Height="105">
               
            </RowDefinition>
            <RowDefinition x:Name="row2ContainerCylLift1" Height="auto"/>
            <RowDefinition x:Name="row3ContainerCylLift1" Height="55"/>
        </Grid.RowDefinitions>

        <Rectangle x:Name="rectBackground" Grid.RowSpan="4" Grid.ColumnSpan="2" Stroke="Black" >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF818181" Offset="1"/>
                    <GradientStop Color="#FFB2B2B2"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <TextBlock x:Name="tbHeader" Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding ElementName=UcCylContr, Path=DpCyl.sCylNameHMI}" Style="{StaticResource RENA_GraphicContainerHeaderStyle}" />

        <Grid Grid.Row="1" Grid.ColumnSpan="2" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="2,2,2,2" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="11*"/>
                <ColumnDefinition Width="9*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="row0"  Height="16" />
                <RowDefinition Height="{Binding ElementName=row0, Path=Height}" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Setpoint high:" Style="{StaticResource TextBlockStyle_Setpoint}" Margin="5,0,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Setpoint low:" Style="{StaticResource TextBlockStyle_Setpoint}"  Margin="5,0,0,0" />


            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBlockStyle_Setpoint}"  >
                <Run Text="{Binding ElementName=UcCylContr, Path=DpCyl.lrAnSensSetpointHighHMI,  StringFormat=N3}"/>
                <Run Text="{Binding ElementName=UcCylContr, Path=DpCyl.sAnSensUnitHMI,  StringFormat=N3}"/>
            </TextBlock>




            <TextBlock  Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBlockStyle_Setpoint}">
                <Run Text="{Binding ElementName=UcCylContr, Path=DpCyl.lrAnSensSetpointLowHMI,  StringFormat=N3}"/>
                <Run Text="{Binding ElementName=UcCylContr, Path=DpCyl.sAnSensUnitHMI,  StringFormat=N3}"/>
            </TextBlock>

        </Grid>



        <!-- ************************************** -->
        <!-- ******** Analoger Sensor Anfang ****** -->
        <Grid   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Width="70" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!-- Falls unterschiedliche Farben dargestellt werden sollen, das Fill-Property von der 1. Zeile löschen und die Triggers anpassen-->
            <Rectangle Grid.RowSpan="2" Fill="{StaticResource UcGrBrushOff}" >
                <Rectangle.Style >
                    <Style  TargetType="{x:Type Rectangle}" BasedOn="{StaticResource UcGrSensorRectOvalStyle}" >
                        <Style.Triggers>

                            <DataTrigger Binding="{Binding DpCyl.iStateHMI, ElementName=UcCylContr}" Value="0" >
                                <Setter Property="Fill" Value="{StaticResource UcGrBrushOff}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCyl.iStateHMI, ElementName=UcCylContr}" Value="1" >
                                <Setter Property="Fill" Value="{StaticResource UcGrBrushOn}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCyl.iStateHMI, ElementName=UcCylContr}" Value="2" >
                                <Setter Property="Fill" Value="Red" />
                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <Line Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Stretch" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" X1="0" Y1="0" X2="100" Y2="0" Stretch="Uniform"  />

            <TextBlock x:Name="tbRectUp"    Grid.Row="0"  Style="{StaticResource UcGrSensorTextBlockStyleOval}" Text="PiA" />
            <TextBlock x:Name="tbRectDown"  Grid.Row="1" Style="{StaticResource UcGrSensorTextBlockStyleOval}" 
                       Text="{Binding ElementName=UcCylContr, Path=DpCyl.sAnSensDescriptionHMI}" >
            </TextBlock>

            <Border  Grid.Row="2" Style="{StaticResource UcGrSensorBorderStyle}">
                <TextBlock x:Name="tbValue"  Style="{StaticResource UcGrSensorTextBlockStyleRect}"  >                                           
                    <Run Text="{Binding ElementName=UcCylContr, Path=DpCyl.lrAnSensValHMI,  StringFormat=N3}"/>
                    <Run Text="{Binding ElementName=UcCylContr, Path=DpCyl.sAnSensUnitHMI,  StringFormat=N3}"/>
                </TextBlock>
            </Border>

        </Grid>
        <!-- ********* Analoger Sensor Ende ******* -->
        <!-- ************************************** -->

        <!-- ***************************************************** -->
        <!-- ******** Symbol "Handfunktion-Ein" Anfang *********** -->
        <Rectangle Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="35" Height="35" Margin="2,0,0,10"  >
            <Rectangle.Style>
                <Style TargetType="Rectangle">
                    <Style.Triggers>

                        <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCylContr}" Value="False" >
                            <Setter Property="Fill" Value="Transparent" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCylContr}" Value="True" >
                            <Setter Property="Fill">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode - Select.png" Stretch="Uniform" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </Rectangle.Style>

            <!-- 
            <Rectangle.Fill>
                <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode - Select.png" Stretch="Uniform"/>
            </Rectangle.Fill>
            -->
        </Rectangle>
        <!-- ******** Symbol "Handfunktion-Ein" Ende *********** -->
        <!-- ***************************************************** -->




        <!-- ************************************** -->
        <!-- ******** Ventil links Anfang ********* -->
        <Grid  x:Name="gridValveL"  Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" 
               Margin="0,0,0,-10" RenderTransformOrigin="0.3, 0.5">

            <Grid.RowDefinitions>
                <RowDefinition x:Name="Row0" Height="10"/>
                <RowDefinition x:Name="Row1" Height="auto"/>
                <RowDefinition x:Name="Row2" Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Col0" Width="*"/>
                <ColumnDefinition x:Name="Col1" Width="auto"/>
                <ColumnDefinition x:Name="Col2" Width="auto"/>
                <ColumnDefinition x:Name="Col3" Width="*"/>

            </Grid.ColumnDefinitions>



            <Polygon x:Name="PolygonLeft" Grid.Row="1" Grid.Column="1" Style="{StaticResource PolygonValveStyle_Left}"    >
                <!-- HINWEIS: 
            die folgenden Punkte werden im C#-Code GELÖSCHT und anschließend neue Punkte hinzugefügt, 
            die durch das Parameter "length" definiert sind.            
            !!! WENN DIE GRÖßE DES VENTILS GEÄNDERT WERDEN MUSS, MUSS DAHER DAS PARAMETER "length" GEÄNDERT WERDEN !!!
            Im XAML-Code konnten die Point-Objekte nicht parametrisiert vorgegeben werden. 
            Die hier definierten Punkte (die dann gelöscht werden) erleichtern allerdings den Entwurf und das Styling -->
                <Polygon.Points  >
                    <Point  X="0"  Y="0"  />
                    <Point  X="0"  Y="20" />
                    <Point  X="20" Y="10" />
                </Polygon.Points>
            </Polygon>

            <Polygon x:Name="PolygonRight" Grid.Row="1" Grid.Column="2" Style="{StaticResource PolygonValveStyle_Left}" >
                <!-- HINWEIS: 
            die folgenden Punkte werden im C#-Code GELÖSCHT und anschließend neue Punkte hinzugefügt, 
            die durch das Parameter "length" definiert sind.            
            !!! WENN DIE GRÖßE DES VENTILS GEÄNDERT WERDEN MUSS, MUSS DAHER DAS PARAMETER "length" GEÄNDERT WERDEN !!!
            Im XAML-Code konnten die Point-Objekte nicht parametrisiert vorgegeben werden. 
            Die hier definierten Punkte (die dann gelöscht werden) erleichtern allerdings den Entwurf und das Styling -->
                <Polygon.Points >
                    <Point X="0"  Y="0"  />
                    <Point X="0"  Y="20" />
                    <Point X="20" Y="10" />
                </Polygon.Points>
                <Polygon.RenderTransform>
                    <RotateTransform Angle="180" CenterX="10" CenterY="10"/>
                </Polygon.RenderTransform>

            </Polygon>

            <Ellipse x:Name="CenterCircle" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"   Width="12" Height="12" Fill="Black" HorizontalAlignment="Center" >

            </Ellipse>

            <TextBlock Grid.Row="2" 
                   Grid.Column="0" 
                   Grid.ColumnSpan="4"  
                   Text="{Binding ElementName=UcCylContr, Path=DpCyl.sValveForerunDescrHMI}" Margin="0,-2,0,10"
                   Style="{StaticResource UC_RIdescr_TextStyle}"  />

            <Grid x:Name="InnerGrid"  Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Top" Width="20" Height="20" >
                <Ellipse   Stroke="Black" StrokeThickness="{StaticResource LocThickness_Thick}" Fill="White" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Ellipse.Clip>
                        <RectangleGeometry Rect="{Binding ElementName=InnerGrid, Path=Width, Converter={StaticResource rectConverter}}"  />
                        <!-- "Rect" Parameter: "x-coord, y-coord, width, height" -->
                    </Ellipse.Clip>
                </Ellipse>

                <Line  X1="0" 
                   Y1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                   X2="{Binding ElementName=InnerGrid, Path=Width}" 
                   Y2="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                   Stroke="Black" 
                   StrokeThickness="{StaticResource LocThickness_Thick}" />

                <Line X1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  Y1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  X2="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  Y2="{Binding ElementName=InnerGrid, Path=Width}" 
                  Stroke="Black" 
                  StrokeThickness="{StaticResource LocThickness_Thick}" />

            </Grid>

            <Rectangle x:Name="rectValveLeft" Fill="Transparent" Grid.RowSpan="3" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  MouseDown="RectValveLeft_MouseDown" Margin="0,0,0,18" >
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DpCyl.bManualAllowedHMI, ElementName=UcCylContr}" Value="True" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCyl.bManualAllowedHMI, ElementName=UcCylContr}" Value="False" >
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>

                            <!-- Falls das Bild "Manual Mode_White.png"  durch das Bild für "Handfunktion aktiv" erstezt werden muss, wenn Handfunktion aktiv ist -->
                            <!--                             
                            <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCylContr}" Value="False" >
                                <Setter Property="Fill">
                                    <Setter.Value>
                                        <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode_White.png" Stretch="Uniform" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCylContr}" Value="True" >
                                <Setter Property="Fill">
                                    <Setter.Value>
                                        <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode - Select_White.png" Stretch="Uniform" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            -->
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>

                <!-- Falls das Symbol für ManualAllowed angezeigt werden soll, untere 3 Zeilen einkommentieren. Evt. muss zusätzlich das Fill="Transparent" Property oben gelöscht werden -->
                <!-- 
                <Rectangle.Fill>
                    <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode_White.png" Stretch="Uniform"/>
                </Rectangle.Fill>
                -->
            </Rectangle>





        </Grid>
        <!-- ******** Ventil links Ende *********** -->
        <!-- ************************************** -->




        <!-- ************************************** -->
        <!-- ******** Ventil rechts Anfang ******** -->
        <Grid  x:Name="gridValveR"  Grid.Row="3" Grid.Column="1" 
               HorizontalAlignment="{Binding ElementName=gridValveL, Path=HorizontalAlignment}" 
               VerticalAlignment="{Binding ElementName=gridValveL, Path=VerticalAlignment}"
               Margin="{Binding ElementName=gridValveL, Path=Margin}" 
               RenderTransformOrigin="{Binding ElementName=gridValveL, Path=RenderTransformOrigin}">

            <Grid.RowDefinitions>
                <RowDefinition x:Name="Row0R" Height="10"/>
                <RowDefinition x:Name="Row1R" Height="auto"/>
                <RowDefinition x:Name="Row2R" Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Col0R" Width="*"/>
                <ColumnDefinition x:Name="Col1R" Width="auto"/>
                <ColumnDefinition x:Name="Col2R" Width="auto"/>
                <ColumnDefinition x:Name="Col3R" Width="*"/>

            </Grid.ColumnDefinitions>



            <Polygon x:Name="PolygonLeftR" Grid.Row="1" Grid.Column="1" Style="{StaticResource PolygonValveStyle_Right}"    >
                <!-- HINWEIS: 
            die folgenden Punkte werden im C#-Code GELÖSCHT und anschließend neue Punkte hinzugefügt, 
            die durch das Parameter "length" definiert sind.            
            !!! WENN DIE GRÖßE DES VENTILS GEÄNDERT WERDEN MUSS, MUSS DAHER DAS PARAMETER "length" GEÄNDERT WERDEN !!!
            Im XAML-Code konnten die Point-Objekte nicht parametrisiert vorgegeben werden. 
            Die hier definierten Punkte (die dann gelöscht werden) erleichtern allerdings den Entwurf und das Styling -->
                <Polygon.Points  >
                    <Point  X="0"  Y="0"  />
                    <Point  X="0"  Y="20" />
                    <Point  X="20" Y="10" />
                </Polygon.Points>
            </Polygon>

            <Polygon x:Name="PolygonRightR" Grid.Row="1" Grid.Column="2" Style="{StaticResource PolygonValveStyle_Right}" >
                <!-- HINWEIS: 
            die folgenden Punkte werden im C#-Code GELÖSCHT und anschließend neue Punkte hinzugefügt, 
            die durch das Parameter "length" definiert sind.            
            !!! WENN DIE GRÖßE DES VENTILS GEÄNDERT WERDEN MUSS, MUSS DAHER DAS PARAMETER "length" GEÄNDERT WERDEN !!!
            Im XAML-Code konnten die Point-Objekte nicht parametrisiert vorgegeben werden. 
            Die hier definierten Punkte (die dann gelöscht werden) erleichtern allerdings den Entwurf und das Styling -->
                <Polygon.Points >
                    <Point X="0"  Y="0"  />
                    <Point X="0"  Y="20" />
                    <Point X="20" Y="10" />
                </Polygon.Points>
                <Polygon.RenderTransform>
                    <RotateTransform Angle="180" CenterX="10" CenterY="10"/>
                </Polygon.RenderTransform>

            </Polygon>

            <Ellipse x:Name="CenterCircleR" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"   Width="12" Height="12" Fill="Black" HorizontalAlignment="Center" >

            </Ellipse>

            <TextBlock Grid.Row="2" 
                   Grid.Column="0" 
                   Grid.ColumnSpan="4"  
                   Text="{Binding ElementName=UcCylContr, Path=DpCyl.sValveRestDescrHMI}" Margin="0,-2,0,10"
                   Style="{StaticResource UC_RIdescr_TextStyle}"/>

            <Grid x:Name="InnerGridR"  Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Top" Width="20" Height="20" >
                <Ellipse   Stroke="Black" StrokeThickness="{StaticResource LocThickness_Thick}" Fill="White" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Ellipse.Clip>
                        <RectangleGeometry Rect="{Binding ElementName=InnerGrid, Path=Width, Converter={StaticResource rectConverter}}"  />
                        <!-- "Rect" Parameter: "x-coord, y-coord, width, height" -->
                    </Ellipse.Clip>
                </Ellipse>

                <Line  X1="0" 
                   Y1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                   X2="{Binding ElementName=InnerGrid, Path=Width}" 
                   Y2="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                   Stroke="Black" 
                   StrokeThickness="{StaticResource LocThickness_Thick}" />

                <Line X1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  Y1="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  X2="{Binding ElementName=InnerGrid, Path=Width, Converter={ikriv:MathConverter}, ConverterParameter=x/2}"
                  Y2="{Binding ElementName=InnerGrid, Path=Width}" 
                  Stroke="Black" 
                  StrokeThickness="{StaticResource LocThickness_Thick}" />

            </Grid>

            <Rectangle x:Name="rectValveRight" Fill="Transparent"  Grid.RowSpan="3" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MouseDown="RectValveRight_MouseDown" Margin="{Binding ElementName=rectValveLeft, Path=Margin}" >
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DpCyl.bManualAllowedHMI, ElementName=UcCylContr}" Value="True" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCyl.bManualAllowedHMI, ElementName=UcCylContr}" Value="False" >
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>

                <!-- 
                <Rectangle.Fill>
                    <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode_White.png" Stretch="Uniform"/>
                </Rectangle.Fill>
                -->
            </Rectangle>


        </Grid>
        <!-- ******** Ventil rechts Ende ********** -->
        <!-- ************************************** -->



    </Grid>
</UserControl>
