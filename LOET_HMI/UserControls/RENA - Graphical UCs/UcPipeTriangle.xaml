<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcPipeTriangle"
             x:Name="UcPipe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 
             Height="auto" Width="auto" Loaded="UcPipe_Loaded">

    <Grid x:Name="mainGrid" RenderTransformOrigin="0.5, 0.5" >
        <Grid.RowDefinitions>
            <RowDefinition x:Name="row0" Height="auto"/>
            <RowDefinition x:Name="row1" Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="col0" Width="auto" />
        </Grid.ColumnDefinitions>



        <TextBlock x:Name="tbFluidName" FontSize="16" Grid.Row="0" Grid.Column="0"  Text="{Binding ElementName=UcPipe, Path=FluidName}" TextWrapping="NoWrap"  HorizontalAlignment="Center" VerticalAlignment="Center"  Style="{StaticResource UC_RIdescr_TextStyle}"  RenderTransformOrigin="0.5, 0.5" Margin="4,4,4,4"  />

        <Polygon x:Name="triangle" Grid.Row="1" Grid.Column="0"  HorizontalAlignment="Center" VerticalAlignment="Center"  Stroke="Black" StrokeThickness="1" RenderTransformOrigin="0.5, 0.5"  >
            <Polygon.Points  >
                <Point  X="0"  Y="0"  />
                <Point  X="13"  Y="20" />
                <Point  X="26" Y="0" />
            </Polygon.Points>
            
            <Polygon.Style>
                <Style  TargetType="{x:Type Polygon}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=UcPipe, Path=DpPipeState}" Value="True" >
                            <Setter Property="Fill" Value="LawnGreen"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=UcPipe, Path=DpPipeState}" Value="False" >
                            <Setter Property="Fill" Value="White" />
                        </DataTrigger>
                    </Style.Triggers>
                    
                </Style>
                
            </Polygon.Style>
        </Polygon>

    </Grid>
</UserControl>
