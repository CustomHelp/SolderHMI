<UserControl x:Class="LOET_HMI.UcLampText"
             x:Name="UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded">
    
    <Grid>
        <StackPanel Orientation="Horizontal" >
            <CheckBox x:Name="Led" Height="15" IsChecked="{Binding bIsON, ElementName=UserControl}" IsHitTestVisible="false" />
            <TextBlock x:Name="tbText" Width="Auto" Foreground="{StaticResource CHPStandartFontColor}" Margin="1,0,0,0" VerticalAlignment="Center" Text="{Binding sText,  ElementName=UserControl}" Style="{StaticResource CHP_TextBlock}" FontSize="12" TextAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>