<UserControl x:Class="LOET_HMI.UcStationButton"
             x:Name="UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded">

    <Grid>
        <Rectangle x:Name="RectBackground" Style="{StaticResource CHP_ButtonBackgroundState}" Margin="0,0,0,0"/>
        <Button x:Name="Btn"  Click="onButtonClick" Style="{StaticResource CHP_StationButton}" Margin="4,4,4,4">
            <TextBlock TextAlignment="Center" Focusable="False" Text="{Binding sText,  ElementName=UserControl}" TextWrapping="Wrap" FontWeight="Bold" Foreground="{StaticResource CHPStandartFontColor}"/> 
        </Button>
    </Grid>
</UserControl>