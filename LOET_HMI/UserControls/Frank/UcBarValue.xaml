<UserControl x:Class="LOET_HMI.UcBarValue"
             x:Name="UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded">
   
    
    
    <DockPanel>
        <DockPanel DockPanel.Dock="Top">
            <TextBlock x:Name="tblName" Text="{Binding sName, ElementName=UserControl}" Foreground="{StaticResource CHPStandartFontColor}" FontSize="{Binding dFontSize, ElementName=UserControl}" Width="Auto" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
        </DockPanel>
        <Grid>
            <ProgressBar x:Name="PBar" Minimum="0" Maximum="100" Value="{Binding dValue, ElementName=UserControl}" FontSize="{Binding dFontSize, ElementName=UserControl}" Height="24" BorderThickness="0" Margin="0,-3,0,0" />
            <TextBlock Text="{Binding ElementName=PBar, Path=Value, StringFormat={}{0:0.00}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{Binding dFontSizeVal, ElementName=UserControl}"  Margin="0,-3,0,0" />
        </Grid>
     </DockPanel>
</UserControl>