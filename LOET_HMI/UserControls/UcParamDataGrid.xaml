<UserControl x:Class="LOET_HMI.UcParamDataGrid"
             x:Name="UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI"
             xmlns:mscorlib="clr-namespace:System;assembly=mscorlib" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"  
             xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib" 
             mc:Ignorable="d" d:DesignHeight="865" d:DesignWidth="1650" 
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             
             xmlns:prop="clr-namespace:LOET_HMI.Properties"
             >

    <UserControl.Resources>
        <CollectionViewSource x:Key="itemCollectionViewSourceSet" CollectionViewType="ListCollectionView"/>
        <CollectionViewSource x:Key="itemCollectionViewSourceParameter" CollectionViewType="ListCollectionView"/>
        <local:ObjectToTypeStringConverter x:Key="ObjectToTypeString" />

        <Style TargetType="Button" BasedOn="{StaticResource  RENADataGridButtons}">
            <!-- die auskommentierten Properties wurden zum obigen Style hinzugefügt
            <Setter Property="Width" Value="170" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="10,0,0,10" />
            -->
        </Style>

        <Style TargetType="DataGrid"  BasedOn="{StaticResource RENADataGridStyle}">
            <!-- die auskommentierten Properties wurden zum obigen Style hinzugefügt
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF013F84" />
            -->
        </Style>



    </UserControl.Resources>

    <Grid >

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="col0" Width="307*" />
            <ColumnDefinition x:Name="col1" Width="518*"/>

        </Grid.ColumnDefinitions>

        <GroupBox Header="{x:Static prop:Resources.Paramset_gbHeader}"
                  Grid.Column="0"   Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>


                <StackPanel Orientation="Vertical"  HorizontalAlignment="Left" Grid.Row="1" Grid.Column="0" >
                    <Button x:Name="BtnNewParamSet"     Content="{x:Static prop:Resources.Paramset_btnNew}"            Click="BtnNewParamSet_Click"  />
                    <Button x:Name="BtnCopyParamSet"    Content="{x:Static prop:Resources.Paramset_btnCopy}"      Click="BtnCopyParamSet_Click"        />
                    <Button x:Name="BtnRenameParamSet"  Content="{x:Static prop:Resources.Paramset_btnRename}"     Click="BtnRenameParamSet_Click"  />
                    <Button x:Name="BtnDeleteParamSet"  Content="{x:Static prop:Resources.Paramset_btnDelete}"        Click="BtnDeleteParamSet_Click"     />
                    <Button x:Name="BtnLoadParamSetToPLC"    Content="{x:Static prop:Resources.Paramset_btnLoadToPLC}"   Click="BtnLoadParamSetToPLC_Click"    />
                    <Button x:Name="btnAddToOrder" Content="Zu Auftrag hinzufügen"     Click="BtnAddToOrder_Click"      />
                    <Label Height="150" />
                    <Button x:Name="btnSelectCurrentPLCRecipe" Content="{x:Static prop:Resources.Paramset_btnSelectCurrent}"     Click="BtnSelectCurrentPLCRecipe_Click"      />
                    <!-- 
                    <Button x:Name="btnPLCValuesToRecipe"      Content="PLC values to recipe"     Click="BtnPLCValuesToRecipe_Click"      />
                    -->

                </StackPanel>






                <DataGrid x:Name="dGParamSet" 
                          Grid.Column="1" Margin="20,0,0,0" HorizontalAlignment="Stretch"    IsReadOnly="True"  AutoGenerateColumns="False" EnableRowVirtualization="True"  RowDetailsVisibilityMode="VisibleWhenSelected" CanUserAddRows="False" 
                        ItemsSource="{Binding}" 
               
                        DataContext="{StaticResource itemCollectionViewSourceSet}"
                        SelectedCellsChanged="DGParamSet_SelectedCellsChanged" 
                        GotFocus="DGParamSet_GotFocus" 
                          Loaded="DGParamSet_Loaded"
                          PreviewKeyDown="DGParamSet_PreviewKeyDown"
                         >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_Name}"          Binding="{Binding sName}"       IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_CreatedBy}"     Binding="{Binding sCreatedBy}" IsReadOnly="True" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_CreatedOn}"     Binding="{Binding dtCreatedOn, StringFormat=\{0:dd/MM/yyyy HH:mm\} }" IsReadOnly="True" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_LastModified}"  Binding="{Binding dtLastModified, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" IsReadOnly="True" Width="auto" />
                    </DataGrid.Columns>
                    
                </DataGrid>

            </Grid>



        </GroupBox>


        <GroupBox x:Name="gbParam" Header="{x:Static prop:Resources.Param_gbHeader}" Grid.Column="1"   Width="{Binding ElementName=col0, Path=Width}" Style="{StaticResource RENA_GroupBox_Style}"  Margin="10,10,10,10" >

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical"  HorizontalAlignment="Left" Grid.Column="1">
                    <!-- 
                    <Button x:Name="btnEditAllParam" Content="{x:Static prop:Resources.Param_btnEditAll}"     Click="BtnEditAllParam_Click"      />
                    -->
                    <Button x:Name="btnExportCSV"    Content="{x:Static prop:Resources.Param_btnExportToCSV}"     Click="BtnExportCSV_Click"    />



                </StackPanel>

                <DataGrid x:Name="dgParameter" Grid.Column="0" BorderThickness="0" 
                          Margin="20,0,0,0" HorizontalAlignment="Stretch"
                          
                          AutoGenerateColumns="False" IsReadOnly="True" Height="Auto"  
                          
                      GotFocus="DgParameter_GotFocus"
                      SelectionChanged="DgParameter_SelectionChanged"  >
                    <DataGrid.Columns>
                         
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_Name}" Binding="{Binding strName, UpdateSourceTrigger=PropertyChanged}" Width="auto"  />

                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_Descritpion}"  Binding="{Binding strDescription, UpdateSourceTrigger=PropertyChanged}" Width="auto" MaxWidth="520" />

                        
                        <!--Test-->
                        <!-- 
                        <DataGridTextColumn Header="Value Test"  Binding="{Binding ValDB, UpdateSourceTrigger=PropertyChanged}" Width="auto" MaxWidth="520" />
                        -->

                        <DataGridTemplateColumn Header="{x:Static prop:Resources.DataGridParam_Value}" IsReadOnly="True" Width="auto" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate >
                                    <ContentControl   x:Name="ColumnCombinedDB"  Content="{Binding}"   />
                                    <DataTemplate.Triggers>

                                        <DataTrigger Binding="{Binding ValDB, Converter={StaticResource ObjectToTypeString}}" Value="Boolean">
                                            <Setter TargetName="ColumnCombinedDB" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:Boolean}">
                                                        <CheckBox IsChecked="{Binding ValDB,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource RENA_CheckboxStyle_LED}" HorizontalAlignment="Center" ></CheckBox>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding ValDB, Converter={StaticResource ObjectToTypeString}}" Value="Int32" >
                                            <Setter TargetName="ColumnCombinedDB" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:Int32}">
                                                        <TextBlock Text="{Binding ValDB,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  ></TextBlock>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding ValDB, Converter={StaticResource ObjectToTypeString}}" Value="Double" >
                                            <Setter TargetName="ColumnCombinedDB" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:Double}">
                                                        <TextBlock Text="{Binding ValDB,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  ></TextBlock>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        
                                        <DataTrigger Binding="{Binding ValDB, Converter={StaticResource ObjectToTypeString}}" Value="String" >
                                            <Setter TargetName="ColumnCombinedDB" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:String}">
                                                        <TextBlock Text="{Binding ValDB,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  ></TextBlock>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        
                        <DataGridTemplateColumn Header="{x:Static prop:Resources.DataGridParam_ValuePLC}" IsReadOnly ="true" Width="auto" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate >
                                    <ContentControl   x:Name="ColumnCombined"  Content="{Binding}"/>
                                    <DataTemplate.Triggers>

                                        <DataTrigger Binding="{Binding Val, Converter={StaticResource ObjectToTypeString}}" Value="Boolean">
                                            <Setter TargetName="ColumnCombined" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:Boolean}">
                                                        <CheckBox IsChecked="{Binding Val,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource RENA_CheckboxStyle_LED}" HorizontalAlignment="Center" ></CheckBox>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Val, Converter={StaticResource ObjectToTypeString}}" Value="Int32" >
                                            <Setter TargetName="ColumnCombined" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:Int32}">
                                                        <TextBlock Text="{Binding Val,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  ></TextBlock>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Val, Converter={StaticResource ObjectToTypeString}}" Value="Double" >
                                            <Setter TargetName="ColumnCombined" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:Double}">
                                                        <TextBlock Text="{Binding Val,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  ></TextBlock>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        
                                        
                                        <DataTrigger Binding="{Binding Val, Converter={StaticResource ObjectToTypeString}}" Value="String" >
                                            <Setter TargetName="ColumnCombined" Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate DataType="{x:Type mscorlib:String}">
                                                        <TextBlock Text="{Binding Val,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  ></TextBlock>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        

                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        
                        
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_Unit}"     Binding="{Binding strUnit}" Width="auto" />
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_RangeMin}" Binding="{Binding Min}"   Width="*"  />
                        <DataGridTextColumn Header="{x:Static prop:Resources.DataGridParam_RangeMax}" Binding="{Binding Max}"   Width="*" />
                        


                        <!--DataGridCheckBoxColumn Header="Allowed" Binding="{Binding bAllowedHMI}" ElementStyle="{DynamicResource RENA_CheckboxStyle_LED}" /-->
                    </DataGrid.Columns>

                </DataGrid>
            </Grid>






        </GroupBox>

    </Grid>

</UserControl>