<UserControl x:Class="LOET_HMI.UserControls.UcSettingAnalogString"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="150"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="tbInput" HorizontalAlignment="Stretch"  TextWrapping="Wrap" VerticalAlignment="Stretch" GotFocus="Value_GotFocus" Grid.Row="0" />
    </Grid>
</UserControl>
