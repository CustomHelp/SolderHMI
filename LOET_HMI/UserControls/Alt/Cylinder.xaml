<UserControl x:Class="LOET_HMI.Cylinder"
             x:Name="UcCylinder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI"
             mc:Ignorable="d" 
             d:DesignHeight="220.167" d:DesignWidth="185.834"               
             
             MinHeight="200" MinWidth="180" >



    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="StyleCHP_Button" TargetType="Button">
                <Setter Property="BorderBrush"      Value="Black" />
                <!-- Rahmenfarbe -->
                <Setter Property="Foreground"       Value="Black" />
                <!-- Textfarbe -->
                <Setter Property="BorderThickness"  Value="2" />
                <!-- Rahmenstärke -->
            </Style>

            <Style x:Key="StyleCHP_TextBlock" TargetType="TextBlock">
                <Setter Property="Foreground" Value="Black" />
                <!-- Textfarbe -->
                <Setter Property="FontSize"   Value="16" />
            </Style>

            <Style x:Key="StyleCHP_Rect" TargetType="Rectangle">
                <Setter Property="Stroke" Value="Black" />
                <!--Rahmenfarbe-->
                <Setter Property="StrokeThickness" Value="2" />
                <!-- Rahmenstärke -->
                <Setter Property="RadiusX"   Value="10" />
                <Setter Property="RadiusY"   Value="10" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>



    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="119"/>
            <RowDefinition Height="96"/>
        </Grid.RowDefinitions>

        <Rectangle x:Name="RectBackground"  Grid.Row="0" Grid.Column="0" Style="{StaticResource StyleCHP_Rect}" Margin="0,0,0,0"   Grid.ColumnSpan="2" Grid.RowSpan="2">
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFB0B1C7"/>
                    <GradientStop Color="#FF7477A4" Offset="0.939"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle x:Name="RectForerun" Grid.Row="1" Grid.Column="0" Style="{StaticResource StyleCHP_Rect}"  Margin="5,5,5,5"   
                   Fill="{Binding DpCylinderHMI.BrushValveForerun, ElementName=UcCylinder}" >
        </Rectangle>

        <Rectangle x:Name="RectRest"  Grid.Row="1" Grid.Column="1" Style="{StaticResource StyleCHP_Rect}" Margin="5,5,5,5"  
                   Fill="{Binding DpCylinderHMI.BrushValveRest, ElementName=UcCylinder}">
        </Rectangle>



        <TextBlock x:Name="tbCylName" Text="{Binding DpCylinderHMI.sCylNameHMI, ElementName=UcCylinder}" 
                   HorizontalAlignment="Center" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="-7,11,-7,0" Width="200" 
                   Style="{StaticResource StyleCHP_TextBlock}" FontSize="20" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" Height="27"  />

        <Button x:Name="btnChangeState" FontSize="16" Style="{StaticResource StyleCHP_Button}"   Width="72" Height="72" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="57,42,57,5"    
                    Visibility= "{Binding DpCylinderHMI.VisManualAllowed, ElementName=UcCylinder}"
                    Command   = "{Binding DpCylinderHMI.cmdManual, ElementName=UcCylinder}" Grid.ColumnSpan="2"   >
            <Button.Background>
                <ImageBrush ImageSource="{Binding DpCylinderHMI.sManBtnPath, ElementName=UcCylinder}"/>
            </Button.Background>
        </Button>

        <TextBlock x:Name="tbStateOff" Text="Vorlauf"  Style="{StaticResource StyleCHP_TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="19,8,17,0" TextAlignment="Center" Grid.Row="1" Grid.Column="0"  Width="57" Height="21" FontWeight="Bold"/>
        <TextBlock x:Name="tbStateOn"  Text="Ruhelage" Style="{StaticResource StyleCHP_TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,8,10,0" TextAlignment="Center" Grid.Row="1" Grid.Column="1" Height="21" Width="73" FontWeight="Bold" />
        <TextBlock x:Name="tbTimeForerun" Text="{Binding DpCylinderHMI.sTextForerunTime, ElementName=UcCylinder}" Visibility="{Binding DpCylinderHMI.VisHasForerunPos, ElementName=UcCylinder}" HorizontalAlignment="Center" VerticalAlignment="Bottom"  Grid.Row="1" Grid.Column="0"   Style="{StaticResource StyleCHP_TextBlock}" FontSize="14" Height="16" Margin="16,0,17,12" Width="60" TextAlignment="Center" TextInput="TbTimeForerun_TextInput" />
        <TextBlock                        Text="{Binding DpCylinderHMI.sTextRestPosTime, ElementName=UcCylinder}" Visibility="{Binding DpCylinderHMI.VisHasRestPos,    ElementName=UcCylinder}" HorizontalAlignment="Center" VerticalAlignment="Bottom"  Grid.Row="1" Grid.Column="1"   Style="{StaticResource StyleCHP_TextBlock}" FontSize="14" Height="16" Margin="16,0,17,12" Width="60" TextAlignment="Center"  />

        <Rectangle x:Name="LED1" Grid.Column="0" Grid.Row="1"  Height="36"  Width="35" HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="29,31,29,29" 
            Visibility="{Binding DpCylinderHMI.VisHasForerunPos, ElementName=UcCylinder}" >
            <Rectangle.Fill>
                <!--
                <ImageBrush ImageSource="/LOET_HMI;component/Resources/LEDs/green-led-off-th.png" AlignmentX="Left" Stretch="Uniform"  />
                -->
                <ImageBrush ImageSource="{Binding DpCylinderHMI.sLEDPath_ForerunPos, ElementName=UcCylinder}" />
            </Rectangle.Fill>
        </Rectangle>


        <Rectangle x:Name="LED2" Grid.Column="1"  Grid.Row="1"  Height="36"  Width="35" HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="29,31,29,29" 
             Visibility="{Binding DpCylinderHMI.VisHasRestPos,    ElementName=UcCylinder}"  >
            <Rectangle.Fill>
                <!--
                <ImageBrush ImageSource="/LOET_HMI;component/Resources/LEDs/green-led-off-th.png" AlignmentX="Left" Stretch="Uniform"  />
                -->
                <ImageBrush ImageSource="{Binding DpCylinderHMI.sLEDPath_RestPos, ElementName=UcCylinder}" />

            </Rectangle.Fill>
        </Rectangle>
        <!--
        <Image HorizontalAlignment="Left" Height="100" Margin="-150,23,0,-12" Grid.Row="1" VerticalAlignment="Top" Width="100"
               Source="/LOET_HMI;component/Resources/LEDs/green-led-off-th.png" />
        -->

        <TextBlock x:Name="tbSideCylComment" HorizontalAlignment="Stretch"  TextWrapping="Wrap" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="-1,50,1,0" TextAlignment="Center"
                   Text="{Binding DpCylinderHMI.sSideCylCommentHMI, ElementName=UcCylinder}" Visibility="{Binding DpCylinderHMI.VisIsSlide, ElementName=UcCylinder}">
        </TextBlock>

        <TextBlock x:Name="tbMainCylName" HorizontalAlignment="Stretch"  TextWrapping="Wrap" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="0,81,0,0" TextAlignment="Center"
                   Text="{Binding DpCylinderHMI.sMainCylNameHMI, ElementName=UcCylinder}" Visibility="{Binding DpCylinderHMI.VisIsSlide, ElementName=UcCylinder}">
        </TextBlock>




    </Grid>
</UserControl>
