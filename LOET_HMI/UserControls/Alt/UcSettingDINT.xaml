<UserControl x:Class="LOET_HMI.UserControls.UcSettingAnalogDINT"
             x:Name="UcSettingAnalogDINT_UIdef" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d"
             xmlns:sys="clr-namespace:System;assembly=mscorlib" Height="66.333"  Width="208.38"  
             xmlns:t="clr-namespace:System.Windows;assembly=PresentationFramework" 
             
             FontSize="14" 
             GotFocus="UcSettingAnalogDINT_UIdef_GotFocus">


    <UserControl.Resources>
        <Thickness x:Key="myGlobalMargin" Left="2" Top="2" Right="2" Bottom ="2" ></Thickness>
    </UserControl.Resources>



    <Grid Margin="2,2,2,5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="11*"/>

            <RowDefinition Height="12*"/>

        </Grid.RowDefinitions>


        <Rectangle Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2" Stroke="Black" StrokeThickness="1" >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFB0B1C7"/>
                    <GradientStop Color="#FF7477A4" Offset="0.939"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <TextBlock x:Name="Set_Name" Text="{Binding DpSettingDINT_HMI.sSettingNameHMI, ElementName=UcSettingAnalogDINT_UIdef}" FontSize="18" TextAlignment="Center" FontWeight="Bold"
                   Grid.Row="0" Grid.ColumnSpan="2" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="{StaticResource myGlobalMargin}"  />

        <TextBox   x:Name="Value"    Text="{Binding DpSettingDINT_HMI.iValHMI, ElementName=UcSettingAnalogDINT_UIdef, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center"
                   Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="5,2,2,4"  />

        <TextBlock x:Name="Unit"     Text="{Binding DpSettingDINT_HMI.sUnitHMI, ElementName=UcSettingAnalogDINT_UIdef}" TextAlignment="Center"
                   Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="{StaticResource myGlobalMargin}" />


        <!--
        <TextBox  x:Name="Min"   Text="{Binding DpSettingDINT_HMI.iMinHMI, ElementName=UcSettingAnalogDINT_UIdef}"    Margin="0,2,0,31" Grid.Row="1" Grid.ColumnSpan="3"/>
        <TextBox  x:Name="Max"   Text="{Binding DpSettingDINT_HMI.iMaxHMI, ElementName=UcSettingAnalogDINT_UIdef}"    Margin="0,28,0,5" Grid.Row="1" Grid.ColumnSpan="3"/>
        -->

    </Grid>
</UserControl>
