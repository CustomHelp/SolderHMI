<UserControl x:Class="LOET_HMI.UserControls.UcValueInOut"
             x:Name="ucValueInOut"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             Loaded="UcValueInOut_Loaded" Unloaded="UcValueInOut_Unloaded"
             Height="auto" Width="auto"
             >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition  Height="{Binding ElementName=ucValueInOut, Path=UCHeight, FallbackValue=30}" MinHeight="13" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"   />
            <ColumnDefinition Width="{Binding ElementName=ucValueInOut, Path=UCDistanceValueLabel, FallbackValue=10}"  />
            <ColumnDefinition Width="auto"  />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="tbxValue" Grid.Row="0"  Grid.Column="0"   
                 MinWidth="30"
                 HorizontalAlignment="Center" TextAlignment="Center" VerticalContentAlignment="Center"
                 Text="{Binding ElementName=ucValueInOut, Path=UCValue, FallbackValue=_value}"
                 FontSize="{Binding ElementName=ucValueInOut, Path=UCFontSize, FallbackValue=10}"
                 Width="{Binding ElementName=ucValueInOut, Path=UCWidthValue, FallbackValue=50}"                    
                 >
        </TextBox>
                
        <TextBlock x:Name="tblLabel" Grid.Row="0"  Grid.Column="2"   
                   VerticalAlignment="Center" 
                   Text="{Binding ElementName=ucValueInOut, Path=UCTextLabel, FallbackValue=_label}"
                   FontSize="{Binding ElementName=ucValueInOut, Path=UCFontSize, FallbackValue=10}"
                   Width="{Binding ElementName=ucValueInOut, Path=UCWidthLabel, FallbackValue=80}"
                   >
        </TextBlock>

    </Grid>
</UserControl>
