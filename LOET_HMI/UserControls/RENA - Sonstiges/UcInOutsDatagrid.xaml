<UserControl x:Class="LOET_HMI.UserControls.UcInOutsDatagrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
                          
             xmlns:mscorlib="clr-namespace:System;assembly=mscorlib" 
             d:DesignHeight="300" d:DesignWidth="400">

    <UserControl.Resources>
        <local:ObjectToTypeStringConverter x:Key="ObjectToTypeString" />
    </UserControl.Resources>
    
    <Grid>
        <DataGrid x:Name="dgSetting" AutoGenerateColumns="false" IsReadOnly="True" HorizontalAlignment="Stretch"   VerticalAlignment="Stretch" BorderThickness="0" SelectionChanged="DgSettingBool_SelectionChanged"  GotFocus="DgSettingBool_GotFocus"  Margin="0,0,0,0" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Electrical Description" Binding="{Binding sElectrDescrHMI}" />
                <DataGridTextColumn Header="Name" Binding="{Binding sSettingNameHMI}" />
                <DataGridTextColumn Header="RI designation" Binding="{Binding sRIDesignationHMI}" />

                <DataGridTemplateColumn Header="Value" >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate >
                            <ContentControl   x:Name="ColumnCombined"  Content="{Binding}"   />
                            <DataTemplate.Triggers>

                                <DataTrigger Binding="{Binding ValHMI, Converter={StaticResource ObjectToTypeString}}" Value="Boolean">
                                    <Setter TargetName="ColumnCombined" Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate DataType="{x:Type mscorlib:Boolean}">
                                                <CheckBox IsChecked="{Binding ValHMI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource RENA_CheckboxStyle_LED}" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding ValHMI, Converter={StaticResource ObjectToTypeString}}" Value="Int32" >
                                    <Setter TargetName="ColumnCombined" Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate DataType="{x:Type mscorlib:Int32}">
                                                <TextBlock Text="{Binding ValHMI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding ValHMI, Converter={StaticResource ObjectToTypeString}}" Value="Single" >
                                    <Setter TargetName="ColumnCombined" Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate >
                                                <TextBlock Text="{Binding ValHMI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"  />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>


                <DataGridTextColumn Header="Unit" Binding="{Binding sUnitHMI, UpdateSourceTrigger=PropertyChanged}" />


            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
