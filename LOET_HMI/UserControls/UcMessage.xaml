<UserControl x:Class="LOET_HMI.UserControls.UcMessage"
             x:Name="ucMsg"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             xmlns:prop="clr-namespace:LOET_HMI.Properties"
             mc:Ignorable="d" 
             Loaded="UcMsg_Loaded"
             Unloaded="UcMsg_Unloaded"
             d:DesignHeight="350" d:DesignWidth="{StaticResource frameWidth}" 
             Height="auto"
             >

    <UserControl.Resources>
        <CollectionViewSource x:Key="itemCollectionViewSourceMessages" CollectionViewType="ListCollectionView"/>
        <CollectionViewSource x:Key="itemCollectionViewSourceErrors" CollectionViewType="ListCollectionView"/>

        <BitmapImage x:Key="DefaultOPImg" UriSource="/LOET_HMI;component/Resources/OP5AutomaticOFF.png" />

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Rectangle x:Name="RectBackground" Grid.ColumnSpan="2" Style="{StaticResource CHP_ControlBackgroundState}" Margin="0,0,0,0" />

        <Grid Grid.Column="0" MaxHeight="300" VerticalAlignment="Center" Margin="0,0,0,0"  >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="23*"/>
                <ColumnDefinition Width="17*"/>
            </Grid.ColumnDefinitions>

        </Grid>


        <StackPanel x:Name="spLevel3_A" Orientation="Vertical" Width="80"  VerticalAlignment="Center" MaxHeight="290" Margin="0,0,0,0"  >

            <Button  x:Name="btnOP" Style="{StaticResource CHP_AnimatedButton}"  Width="60" Height="60"  Margin="0,10,5,0" Click="BtnOP_Click" HorizontalAlignment="Right">
                <Image Source="{Binding sOPImage, ElementName=ucMsg, FallbackValue={StaticResource DefaultOPImg}}" Margin="5,5,5,5"  ></Image>
            </Button>

            
            <!-- 
            <Button x:Name="btnStart" Style="{StaticResource CHP_Button}"                Height="60" Width="60" Margin="0,30,5,0" Click="BtnStart_Click" HorizontalAlignment="Right">
                <Image Source="/LOET_HMI;component/Resources/Start.png"  Margin="5,5,5,5"></Image>
            </Button>
            -->
            
            <RepeatButton x:Name="repbtnStart" Background="Transparent" BorderThickness="0" Height="60" Width="60" Margin="0,10,5,0" Click="BtnStart_Click" HorizontalAlignment="Right"   >
                <Image Source="/LOET_HMI;component/Resources/Start.png"  Margin="7,7,7,7"></Image>

            </RepeatButton>

            <Button x:Name="btnStop" Style="{StaticResource CHP_Button}" Height="60" Width="60" Margin="0,0,5,0" Click="BtnStop_Click" HorizontalAlignment="Right">
                <Image Source="/LOET_HMI;component/Resources/Stop.png" Margin="5,5,5,5"></Image>
            </Button>
            <Button x:Name="btnQuit" Style="{StaticResource CHP_Button}"   Height="60" Width="60" Margin="0,0,5,0" Click="BtnQuit_Click" HorizontalAlignment="Right">
                <Image Source="/LOET_HMI;component/Resources/Quit.png" Margin="5,5,5,5"></Image>
            </Button>
        </StackPanel>







        <Grid x:Name="gridOfDataGrids" Grid.Column="1" 

              >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="5" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />

            </Grid.RowDefinitions>


            <TextBlock x:Name="tbModulName" Text="Name" Grid.Row="0" Grid.Column="1"  VerticalAlignment="Top" Height="25" Margin="0,10,0,5"
                        FontWeight="Bold" FontSize="18" TextAlignment="Center" >
            </TextBlock>

            <Button x:Name="btnExpand" Content="+" FontSize="44" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalContentAlignment="Center" VerticalAlignment="Center" Padding="0,-14,0,0"
                    Background="Transparent" Foreground="DarkGray" FontWeight="Bold" BorderThickness="0"
                    
                    Width="50" Height="40"  Click="BtnExpand_Click" >
                
            </Button>
            

            <!-- MBA 13.8.2020:
                - ColumnHeaderStyle entfernt
                - CellStyle entfernt
            -->
            <DataGrid x:Name="dGMeldungen" Grid.Row="1" Grid.Column="1"
                      
                      Style="{StaticResource CHP_DataGrid}"    
                      RowStyle="{StaticResource Style_AlarmDataGridRowColors}"
                      CellStyle="{StaticResource CHP_DataGridCellStyle}"
                                            
             

                      
                      ItemsSource             = "{Binding}" 
                      DataContext             = "{StaticResource itemCollectionViewSourceMessages}" 
                                                
                      IsReadOnly              = "True" 
                      AutoGenerateColumns     = "False" 
                      EnableRowVirtualization = "True" 
                      RowDetailsVisibilityMode= "VisibleWhenSelected" 
                      CanUserAddRows          = "False"   >

                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColComeMsg" Binding="{Binding dtCome, StringFormat=\{0:dd.MM.yyyy HH:mm:ss\}}" Header="{x:Static prop:Resources.DgCol_Occurred}" IsReadOnly="True" Width="300"/>

                    <DataGridTextColumn x:Name="ColStatMsg" Binding="{Binding sStation}" Header="{x:Static prop:Resources.DgCol_Station}"  IsReadOnly="True" Width="200"/>
                    <DataGridTextColumn x:Name="ColBMKMsg"  Binding="{Binding sBMK}" Header="{x:Static prop:Resources.DgCol_BMK}" IsReadOnly="True" Width="100"/>


                    <!-- 
                    <DataGridTextColumn x:Name="ColMessage" Binding="{Binding sText}" Header="Meldungen" IsReadOnly="True" Width="*"/>
                    -->
                    <DataGridTextColumn x:Name="ColMessage" Binding="{Binding sMsgTextAllHMI}" Header="{x:Static prop:Resources.DgCol_Message}" IsReadOnly="True" Width="*"/>
                </DataGrid.Columns>

                <DataGrid.Resources>
                    <Style TargetType="{x:Type Button}" x:Key="{ComponentResourceKey ResourceId=DataGridSelectAllButtonStyle, TypeInTargetAssembly={x:Type DataGrid}}">
                        <Setter Property="Visibility" Value="Hidden" />
                    </Style>
                </DataGrid.Resources>
            </DataGrid>


            <DataGrid   x:Name="dGFehler" Grid.Row="3" Grid.Column="1"
                        Style="{StaticResource CHP_DataGrid}"      
                        CellStyle="{StaticResource CHP_DataGridCellStyle}"
                        RowStyle="{StaticResource Style_AlarmDataGridRowColors}"

                        ItemsSource="{Binding}" 
                        DataContext="{StaticResource itemCollectionViewSourceErrors}"  

                        
                        IsReadOnly              ="True" 
                        AutoGenerateColumns     ="False" 
                        EnableRowVirtualization ="True" 
                        RowDetailsVisibilityMode="VisibleWhenSelected" 
                        CanUserAddRows          ="False"  >
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColComeErr" Binding="{Binding dtCome, StringFormat=\{0:dd.MM.yyyy HH:mm:ss\}}" Header="{x:Static prop:Resources.DgCol_Occurred}"  IsReadOnly="True" Width="150"/>
                    <DataGridTextColumn x:Name="ColGoneErr" Binding="{Binding dtGone, StringFormat=\{0:dd.MM.yyyy HH:mm:ss\}}" Header="{x:Static prop:Resources.DgCol_Gone}" IsReadOnly="True" Width="150"/>

                    <DataGridTextColumn x:Name="ColStatErr" Binding="{Binding sStation}" Header="{x:Static prop:Resources.DgCol_Station}" IsReadOnly="True" Width="200"/>
                    <DataGridTextColumn x:Name="ColBMKErr" Binding="{Binding sBMK}" Header="{x:Static prop:Resources.DgCol_BMK}" IsReadOnly="True" Width="100"/>
                    
                    <!-- 
                    <DataGridTextColumn x:Name="ColFehler" Binding="{Binding sText}" Header="Fehler" IsReadOnly="True" Width="*"/>
                    -->
                    <DataGridTextColumn x:Name="ColFehler" Binding="{Binding sMsgTextAllHMI}" Header="{x:Static prop:Resources.DgCol_Error}" IsReadOnly="True" Width="*"/>
                </DataGrid.Columns>



            </DataGrid>
        </Grid>

    </Grid>
    

            
</UserControl>
