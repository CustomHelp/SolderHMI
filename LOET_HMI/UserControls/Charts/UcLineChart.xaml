<UserControl x:Class="LOET_HMI.UserControls.UcLineChart"
             x:Name="uclineChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"

             
             
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>

        <lvc:CartesianChart x:Name="chart" Series="{Binding seriesCollection1}" LegendLocation="Right" Margin="40,40,20,20" Zoom="Xy"     >

            <lvc:CartesianChart.AxisX >
                <lvc:Axis x:Name="axisX"
                          Title="s [mm]" 
                          LabelFormatter="{Binding XFormatter}"                           
                          >
                </lvc:Axis>
            </lvc:CartesianChart.AxisX>

            <lvc:CartesianChart.AxisY>
                <lvc:Axis x:Name="axisY"
                          Title="F [N]" 
                          LabelFormatter="{Binding YFormatter}"  
                          >
                </lvc:Axis>
            </lvc:CartesianChart.AxisY>
        </lvc:CartesianChart>



    </Grid>
</UserControl>
