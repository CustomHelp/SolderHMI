<UserControl x:Class="LOET_HMI.UserControls.UcBeckhoffAxis"
             x:Name="UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             xmlns:path="clr-namespace:LOET_HMI"
             Width="540" Height="436"
             mc:Ignorable="d"
             xmlns:prop="clr-namespace:LOET_HMI.Properties"
             >
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition  Height="80" />
            <!-- ursprünglich: 65 -->
            <RowDefinition  Height="40" />
            <RowDefinition  Height="40" />
            <RowDefinition  Height="95" />
            <RowDefinition  Height="50" />
            <RowDefinition  Height="80" />

            <RowDefinition  Height="20" />
            <RowDefinition  Height="30" />

        </Grid.RowDefinitions>


        <!-- Hintergrund-->
        <!-- 
        <Rectangle x:Name="RectBackground" Style="{StaticResource CHP_ControlBackgroundState}"/>
        -->


        <Rectangle Grid.RowSpan="8"  Grid.ColumnSpan="2" Stroke="Black" StrokeThickness="1" >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FFB0ADAD" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>





        <Grid Grid.Row="0" >


            <Button x:Name="btnEnableManual" Grid.Column="2" Margin="10,20,25,10" FontSize="16" 
                    HorizontalAlignment="Right" VerticalAlignment="Center" 
                    Style      ="{StaticResource CHP_AnimatedButton}"   Width="50" Height="50" 
                    Visibility = "{Binding PLCToHMI.VisManualAllowed, ElementName=UserControl}"
                    Command    = "{Binding PLCToHMI.cmdManual, ElementName=UserControl}">
                <Image Source="{Binding PLCToHMI.sManBtnPath, ElementName=UserControl, FallbackValue={StaticResource DefaultManFuncImg}}"></Image>
            </Button>




            <TextBlock x:Name="tbBMK"  Grid.Column="0" 
                       Style="{StaticResource CHP_TextBlock}"                           
                       HorizontalAlignment="Left" VerticalAlignment="Top"  TextAlignment="Center"  Margin="20,10,0,0" 
                       FontSize="18" FontWeight="Bold" TextWrapping="Wrap"  
                       Text="{Binding PLCToHMI.sBMK, ElementName=UserControl, FallbackValue=_BMK}" 
                       >
            </TextBlock>



            <TextBlock x:Name="tbName"  Grid.Column="1" 
                   Style="{StaticResource CHP_TextBlock}"                           
                   HorizontalAlignment="Center" VerticalAlignment="Top"  TextAlignment="Center"  Margin="0,10,0,0" 
                   FontSize="18" FontWeight="Bold" TextWrapping="Wrap"  
                   Text="{Binding PLCToHMI.sName, ElementName=UserControl, FallbackValue=_Name}" 
                   >
            </TextBlock>


            <TextBlock x:Name="tbDescr"  Grid.Column="1" 
                   Style="{StaticResource CHP_TextBlock}"                           
                   HorizontalAlignment="Center" VerticalAlignment="Top"  TextAlignment="Center"  Margin="0,30,0,0" 
                   FontSize="16"  TextWrapping="Wrap"  
                   Text="{Binding PLCToHMI.sDescription , ElementName=UserControl, FallbackValue=_Description}" 
                   >
            </TextBlock>




            <path:UcValue x:Name="ActPos" Width="160" Height="40" Grid.Column="0"
                           sName="{x:Static prop:Resources.UcAx_lblActPos}" 
                           sUnit="{Binding PLCToHMI.sUnit, ElementName=UserControl}"  
                           sValue="{Binding PLCToHMI.lrPosAct, ElementName=UserControl}" 
                           eUcValueType="Output" 
                           
                           Margin="20,0,30,0" HorizontalAlignment="Left" VerticalAlignment="Bottom">
            </path:UcValue>

        </Grid>
        <!--Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid  Width="100" HorizontalAlignment="Left" Grid.Column="0">
        
                <Button x:Name="btnEnableManual" FontSize="16" Style="{StaticResource CHP_AnimatedButton}"   Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                     Command = "{Binding PLCToHMI.cmdManual, ElementName=UserControl}">
                    <Image Source="{Binding PLCToHMI.sManBtnPath, ElementName=UserControl}"></Image>
                </Button>
            </Grid>
            <Grid Grid.Column="1">
        
                <TextBlock x:Name="tbName" DockPanel.Dock="Top" Text="{Binding PLCToHMI.sName, ElementName=UserControl}" Margin="0,5,0,0"
               HorizontalAlignment="Center" VerticalAlignment="Top"
               Style="{StaticResource CHP_TextBlock}" FontSize="16" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" Height="Auto" Width="538"/>
               
                <Grid Height="35" Width="235" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <Rectangle x:Name="RectActPos" Fill="#FF21A3A6"/>
                    <StackPanel Orientation="Horizontal" Margin="5,0,0,0" >
                        <TextBox x:Name="tbActPos" VerticalContentAlignment="Center" Style="{StaticResource CHP_TBOutput}" Text="{Binding PLCToHMI.lrPosAct, ElementName=UserControl}" FontSize="16" Height="28" Width="200" TextAlignment="Right"  />
                        <TextBlock x:Name="tblActPosUnit"   Text="{Binding PLCToHMI.sUnit, ElementName=UserControl}" FontSize="16" Foreground="Black" Height="25" Width="30" Margin="3,0,0,0"/>
                    </StackPanel>
                </Grid>
             
            </Grid>
        </-->


        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="10,0,0,0">
            <path:UcValue x:Name="SetpointPos"     Width="160" Height="40" sName="{x:Static prop:Resources.UcAx_lblSetPointPos}"   sUnit="{Binding PLCToHMI.sUnit, ElementName=UserControl}"      sValue="{Binding PLCToHMI.lrPosTarget, ElementName=UserControl}" eUcValueType="Output" Margin="10,0,0,0"></path:UcValue>
            <path:UcValue x:Name="ActSpeed"        Width="160" Height="40" sName="{x:Static prop:Resources.UcAx_lblActSpeed}"      sUnit="{Binding PLCToHMI.sUnitSpeed, ElementName=UserControl}"  sValue="{Binding PLCToHMI.lrSpeedAct, ElementName=UserControl}" eUcValueType="Output" Margin="10,0,0,0"></path:UcValue>
            <path:UcValue x:Name="SetpointSpeed"   Width="160" Height="40" sName="{x:Static prop:Resources.UcAx_lblSetPointSpeed}" sUnit="{Binding PLCToHMI.sUnitSpeed, ElementName=UserControl}"  sValue="{Binding PLCToHMI.lrSpeedSetPoint, ElementName=UserControl}" eUcValueType="Output" Margin="10,0,0,0"></path:UcValue>
        </StackPanel>


        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="10,0,0,0">
            <path:UcValue x:Name="PosLag"      Width="160" Height="40" sName="{x:Static prop:Resources.UcAx_lblPosLag}"     sUnit="{Binding PLCToHMI.sUnit, ElementName=UserControl}"  sValue="{Binding PLCToHMI.lrPositionLag, ElementName=UserControl}" eUcValueType="Output" Margin="10,0,0,0"></path:UcValue>
            <path:UcValue x:Name="Override"    Width="160" Height="40" sName="{x:Static prop:Resources.UcAx_lblOverride}"   sUnit="[%]"                                                 sValue="{Binding PLCToHMI.lrActOverride, ElementName=UserControl}" eUcValueType="Output" Margin="10,0,0,0"></path:UcValue>
            <path:UcValue x:Name="Error"       Width="160" Height="40" sName="{x:Static prop:Resources.UcAx_lblError}"      sUnit=""                                                    sValue="{Binding PLCToHMI.sError, ElementName=UserControl}" eUcValueType="Output" Margin="10,0,0,0"></path:UcValue>
        </StackPanel>

        <Grid Grid.Row="3">
            <StackPanel Orientation="Horizontal" Margin="10,5,0,0">
                <Grid>
                    <GroupBox Header="{x:Static prop:Resources.UcAx_gbStatusLog}" Foreground="{StaticResource CHPStandartFontColor}" HorizontalAlignment="Left" VerticalAlignment="Top" Height="90" Width="220" BorderBrush="Black" BorderThickness="1" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Vertical">
                                <path:UcLampText x:Name="LampReady"  eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblReady}"  bIsON="{Binding PLCToHMI.bReady, ElementName=UserControl}"></path:UcLampText>
                                <path:UcLampText x:Name="LampRefOk"  eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblRefOK}"  bIsON="{Binding PLCToHMI.bHomed, ElementName=UserControl}"></path:UcLampText>
                                <path:UcLampText x:Name="LampHasJob" eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblHasJob}" bIsON="{Binding PLCToHMI.bHasJob, ElementName=UserControl}"></path:UcLampText>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin=" 20,0,0,0">
                                <path:UcLampText x:Name="LampNotMoving" eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblNotMoving}" bIsON="{Binding PLCToHMI.bNotMoving, ElementName=UserControl}"></path:UcLampText>
                                <path:UcLampText x:Name="LampMovesPos"  eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblMovesPos}"  bIsON="{Binding PLCToHMI.bPositiveDirection, ElementName=UserControl}"></path:UcLampText>
                                <path:UcLampText x:Name="LampMovesNeg"  eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblMovesNeg}"  bIsON="{Binding PLCToHMI.bNegativeDirection, ElementName=UserControl}"></path:UcLampText>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>

                <Grid>
                    <GroupBox Header="{x:Static prop:Resources.UcAx_gbStatusPhys}" Foreground="{StaticResource CHPStandartFontColor}" HorizontalAlignment="Left" VerticalAlignment="Top" Height="90" Width="120" BorderBrush="Black" BorderThickness="1" Margin="20,0,0,0">
                        <StackPanel Orientation="Vertical">
                            <path:UcLampText x:Name="LampCoupled"        eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblCoupled}"       bIsON="{Binding PLCToHMI.bCoupled, ElementName=UserControl}"></path:UcLampText>
                            <path:UcLampText x:Name="LampInTargetPos"    eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblInTargetPos}"   bIsON="{Binding PLCToHMI.bInTargetPosition, ElementName=UserControl}"></path:UcLampText>
                            <path:UcLampText x:Name="LampInTargetArea"   eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblInTargetArea}"  bIsON="{Binding PLCToHMI.bInPositionArea, ElementName=UserControl}"></path:UcLampText>
                        </StackPanel>
                    </GroupBox>
                </Grid>

                <Grid>
                    <GroupBox Header="{x:Static prop:Resources.UcAx_gbRelease}" HorizontalAlignment="Left" Foreground="{StaticResource CHPStandartFontColor}" VerticalAlignment="Top" Height="90" Width="120" BorderBrush="Black" BorderThickness="1" Margin="20,0,0,0">
                        <StackPanel Orientation="Vertical">
                            <path:UcLampText x:Name="LampController"   eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblController}" bIsON="{Binding PLCToHMI.bController, ElementName=UserControl}"></path:UcLampText>
                            <path:UcLampText x:Name="LampPosEnable"    eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblLimitPos}"   bIsON="{Binding PLCToHMI.bLimit_P, ElementName=UserControl}"></path:UcLampText>
                            <path:UcLampText x:Name="LampNegEnable"    eLEDColor="Green" sText="{x:Static prop:Resources.UcAx_lblLimitNeg}"   bIsON="{Binding PLCToHMI.bLimit_N, ElementName=UserControl}"></path:UcLampText>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="10,5,0,0">
            <path:UcValue x:Name="TargetPos"    Width="245"  Margin="10,0,0,0"
                           eUcValueType="Input"
                           sName="{x:Static prop:Resources.UcAx_lblTargetPos}"    
                           sUnit="{Binding PLCToHMI.sUnit, ElementName=UserControl}"       
                           sValue="{Binding PLCToHMI.lrPosTarget , ElementName=UserControl}"   
                           IsEnabled="{Binding ElementName=UserControl, Path=PLCToHMI.bManOn }"
                           PreviewMouseUp="TargetPos_PreviewMouseUp"
                           >
            </path:UcValue>

            <path:UcValue x:Name="TargetSpeed"  Width="245" Margin="10,0,0,0"
                           eUcValueType="Input"
                           sName="{x:Static prop:Resources.UcAx_lblTargetSpeed}"  
                           sUnit="{Binding PLCToHMI.sUnitSpeed, ElementName=UserControl}"  
                           sValue="{Binding PLCToHMI.lrSpeedSetPoint, ElementName=UserControl}"
                           IsEnabled="{Binding ElementName=UserControl, Path=PLCToHMI.bManOn }"
                           PreviewMouseUp="TargetSpeed_PreviewMouseUp"
                           >
            </path:UcValue>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="5" Margin="20,20,0,15">

            <!-- 
            <Button  x:Name="btnMinusMinus" Style="{StaticResource CHP_AnimatedButton}"  HorizontalAlignment="Center" VerticalAlignment="Center" Width="45" Height="45"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                PreviewMouseDown="BtnMinusMinus_PreviewMouseDown" PreviewMouseUp="BtnMinusMinus_PreviewMouseUp">
                <Image Source="/LOET_HMI;component/Resources/Minus Minus.png"></Image>
            
            </Button>
        
            <Button x:Name="btnMinus" Style="{StaticResource CHP_AnimatedButton}" Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                PreviewMouseDown="BtnMinus_PreviewMouseDown" PreviewMouseUp="BtnMinus_PreviewMouseUp">
                <Image Source="/LOET_HMI;component/Resources/Minus.png"></Image>
                </Button>
        
        
            <Button x:Name="btnPlus" Style="{StaticResource CHP_AnimatedButton}" Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}" 
                PreviewMouseDown="BtnPlus_PreviewMouseDown" PreviewMouseUp="BtnPlus_PreviewMouseUp">
                <Image Source="/LOET_HMI;component/Resources/Plus.png"></Image>
                </Button>
        
            <Button x:Name="btnPlusPlus" Style="{StaticResource CHP_AnimatedButton}" Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                PreviewMouseDown="BtnPlusPlus_PreviewMouseDown" PreviewMouseUp="BtnPlusPlus_PreviewMouseUp" >
                <Image Source="/LOET_HMI;component/Resources/Plus Plus.png"></Image>
                </Button>
             -->

            <!-- Die Ursünglichen Buttons werden auf RepeatButtons ausgetauscht, damit die Events beim ständigen Drucken auch am TouchDisplay ausgelöst werden.  -->
            <!-- Das Style CHP_AnimatedButton wurde auch an den RepeatButtons angepasst (CHP_AnimatedRepeatButton). 
                 Alledings werden diese aktuell nicht verwendet, weil die Animationen zu ein paar Sekunden Verzögerungen der Auslösung des Events führen.-->
            <!-- Visibility: da der Handbetrieb nur bei hochgefahrenen Schotts erlaubt ist, wird das Visibility-Property von "VisManualOn" auf "VisManualAllowed" geändert.
                             Dies ist eine "strengere Bedingung", die auch die Sichtbarkeit des ManualAllow-Tasters bestimmt. -->

            <Button x:Name="repbtnMinusMinus"           Width="45" Height="45" Background="Transparent" BorderThickness="0"
               Stylus.IsPressAndHoldEnabled="False"
                Stylus.IsFlicksEnabled="False"
                StylusDown="DirectionButton_StylusDown"
                PreviewMouseDown="DirectionButton_PreviewMouseDown" 
                PreviewMouseUp="DirectionButton_Release"
                MouseLeave="DirectionButton_Release"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                 >
                <Image Source="/LOET_HMI;component/Resources/Minus Minus.png"></Image>
            </Button>

            <Button x:Name="repbtnMinus"           Width="45" Height="45" Background="Transparent" BorderThickness="0"
               Stylus.IsPressAndHoldEnabled="False"
                Stylus.IsFlicksEnabled="False"
                StylusDown="DirectionButton_StylusDown"
                PreviewMouseDown="DirectionButton_PreviewMouseDown" 
                PreviewMouseUp="DirectionButton_Release"
                MouseLeave="DirectionButton_Release"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}" >
                <Image Source="/LOET_HMI;component/Resources/Minus.png"></Image>
            </Button>

            <Button x:Name="repbtnPlus"  Width="45" Height="45" Background="Transparent" BorderThickness="0"
                Stylus.IsPressAndHoldEnabled="False"
                Stylus.IsFlicksEnabled="False"
                StylusDown="DirectionButton_StylusDown"
                PreviewMouseDown="DirectionButton_PreviewMouseDown" 
                PreviewMouseUp="DirectionButton_Release"
                MouseLeave="DirectionButton_Release"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}">
                <Image Source="/LOET_HMI;component/Resources/Plus.png"/>
            </Button>


            <Button x:Name="repbtnPlusPlus"           Width="45" Height="45" Background="Transparent" BorderThickness="0"
               Stylus.IsPressAndHoldEnabled="False"
                Stylus.IsFlicksEnabled="False"
                StylusDown="DirectionButton_StylusDown"
                PreviewMouseDown="DirectionButton_PreviewMouseDown" 
                PreviewMouseUp="DirectionButton_Release"
                MouseLeave="DirectionButton_Release"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}">
                <Image Source="/LOET_HMI;component/Resources/Plus Plus.png"></Image>
            </Button>





            <Button x:Name="btnStart" Style="{StaticResource CHP_AnimatedButton}" Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="55,0,0,0"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                Command   = "{Binding PLCToHMI.cmdStart, ElementName=UserControl}" Grid.ColumnSpan="2">
                <Image Source="/LOET_HMI;component/Resources/Start.png"></Image>
            </Button>

            <Button x:Name="btnStop" Style="{StaticResource CHP_AnimatedButton}" Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="2,0,0,0"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                Command   = "{Binding PLCToHMI.cmdStop, ElementName=UserControl}" Grid.ColumnSpan="2">
                <Image Source="/LOET_HMI;component/Resources/Stop.png"></Image>
            </Button>


            <Button x:Name="btnRef" Style="{StaticResource CHP_AnimatedButton}"  Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="50,0,0,0"
                Visibility= "{Binding PLCToHMI.VisRefAllowed, ElementName=UserControl}"
                IsEnabled="True" 
                Command   = "{Binding PLCToHMI.cmdRef, ElementName=UserControl}" Grid.ColumnSpan="2">
                <Image Source="/LOET_HMI;component/Resources/Ref.png"></Image>
            </Button>
            <!-- Info, Balog 29.6.2020: das Btn wird nicht verwendet, daher wird der Taster deaktiviert -->


            <Button x:Name="btnQuit" Style="{StaticResource CHP_AnimatedButton}"  Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="2,0,0,0"
                Visibility= "{Binding PLCToHMI.VisManualOn, ElementName=UserControl}"
                Command   = "{Binding PLCToHMI.cmdQuit, ElementName=UserControl}" Grid.ColumnSpan="2">
                <Image Source="/LOET_HMI;component/Resources/Quit.png"></Image>
            </Button>
        </StackPanel>



        <TextBlock x:Name="tbSoEMsg" Grid.Row="6" Grid.Column="0" 
                       Style="{StaticResource CHP_TextBlock}"                           
                       HorizontalAlignment="Center" VerticalAlignment="Center"  TextAlignment="Center"  Margin="0,0,0,0" 
                        TextWrapping="Wrap"  
                       >
            <Run Text="{Binding PLCToHMI.sSoEMessage , ElementName=UserControl, FallbackValue=_SoEMessage}" />
        </TextBlock>

        <Rectangle Grid.Row="7" Grid.ColumnSpan="2" Fill="{Binding ElementName=UserControl, Path=PLCToHMI.brushState, FallbackValue=Green }" 
               StrokeThickness="1" Stroke="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,0,0,0" />
        <TextBlock Style="{StaticResource CHP_TextBlock}" Foreground="White" Grid.Row="7" Grid.ColumnSpan="2"  Text="{Binding ElementName=UserControl, Path=PLCToHMI.textState, FallbackValue=Info_Zustand }" VerticalAlignment="Center" HorizontalAlignment="Center" />



    </Grid>
</UserControl>