<UserControl x:Class="LOET_HMI.UserControls.UcSensBOOL"
             x:Name="UcSens"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             Width="170" Height="115"
             >

    <Grid  x:Name="gridMain"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
        <Grid.RowDefinitions>
            <RowDefinition Height="15" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition  Width="170"/>
        </Grid.ColumnDefinitions>


        <Rectangle Grid.Row="0"  >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FF020202" Offset="0.967"/>
                    <GradientStop Color="#FF726C6C" Offset="0.11"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <TextBlock Grid.Row="0" Text="D i g i t a l e r   S e n s o r" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="9" FontFamily="Tahoma"  FontWeight="Bold" Foreground="#FFFFFCFC" />

        <Grid Grid.Row="1">
            <!-- Hintergrund und Rahmen -->
            <Rectangle Grid.RowSpan="2"  Grid.ColumnSpan="2" Stroke="Black" StrokeThickness="1">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FFAEA9A9" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>


            <StackPanel >
                <!-- INFO: FallbackValue ist nur ein DefaultWert im Designer-Ansicht. Es erleichtert den Entwurf, hat aber in der Binding keine Funktion-->
                <TextBlock Text="{Binding ElementName=UcSens, Path=DpSensStruct.strNameHMI, FallbackValue=_Name}" HorizontalAlignment="Right" Margin="0,10,10,0"  VerticalAlignment="Top" FontSize="16" FontWeight="Bold" />
                <TextBlock Text="{Binding ElementName=UcSens, Path=DpSensStruct.strDescriptionHMI, FallbackValue=_Description}" HorizontalAlignment="Right" Margin="0,0,10,2"  VerticalAlignment="Bottom" FontSize="12" />
                <TextBlock  Text="{Binding ElementName=UcSens, Path=DpSensStruct.strBMK_HMI, FallbackValue=_BMK}"  HorizontalAlignment="Right"  Margin="0,10,10,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" />
            </StackPanel>


            <CheckBox Grid.Row="1" HorizontalAlignment="Left" Margin="15,0,0,15" VerticalAlignment="Bottom"
                              Style="{DynamicResource CheckboxStyle_LED_Cyl}"
                              IsChecked  ="{Binding ElementName=UcSens, Path=DpSensStruct.ValHMI,  UpdateSourceTrigger=PropertyChanged}" 
                                >
            </CheckBox>
        </Grid>




    </Grid>
</UserControl>
