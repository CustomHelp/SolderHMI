<UserControl x:Class="LOET_HMI.UserControls.UcDeviceOnOff"
             x:Name="UcDev"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             xmlns:prop="clr-namespace:LOET_HMI.Properties"

             Width="300" Height="150"
             
             >
    <Grid  x:Name="gridMain"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="70" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition  Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Hintergrund und Rahmen -->
        <Rectangle Grid.RowSpan="3"  Grid.ColumnSpan="2" Stroke="Black" StrokeThickness="1">
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FFAEA9A9" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        
        
        <Grid x:Name="grGrid1" Grid.Row="0" >


            <!-- INFO: FallbackValue ist nur ein DefaultWert im Designer-Ansicht. Es erleichtert den Entwurf, hat aber in der Binding keine Funktion-->
            <TextBlock Text="{Binding ElementName=UcDev, Path=DpDeviceStruct.sBMK, FallbackValue=_BMK}"  HorizontalAlignment="Left"  Margin="10,10,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" />
            <TextBlock Text="{Binding ElementName=UcDev, Path=DpDeviceStruct.sName, FallbackValue=_Name}" HorizontalAlignment="Right" Margin="0,10,10,0"  VerticalAlignment="Top" FontSize="16" FontWeight="Bold" />
            <TextBlock Text="{Binding ElementName=UcDev, Path=DpDeviceStruct.sDescription, FallbackValue=_Description}" HorizontalAlignment="Right" Margin="0,0,10,2"  VerticalAlignment="Bottom" FontSize="12" />

        </Grid>


        <TextBlock Grid.Row="1" Text="{x:Static prop:Resources.UcDevOnOff_Output}"  VerticalAlignment="Top"     FontSize="10" FontStyle="Italic" Margin="18,10,0,0" />
        <CheckBox Grid.Row="1" HorizontalAlignment="Left" Margin="20,10,0,0" 
                              Style="{DynamicResource CheckboxStyle_LED_Cyl}"
                              IsChecked  ="{Binding ElementName=UcDev, Path=DpDeviceStruct.bOut,  UpdateSourceTrigger=PropertyChanged}" 
                                >
        </CheckBox>




        <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" Width="90">
            <TextBlock Margin="0,10,0,0" >
                <Run Text="{x:Static prop:Resources.UcDevOnOff_SwitchLogic}" />
                <Run Text=":"/>
            </TextBlock>
            <TextBlock  x:Name="tbLogikTyp" Text="{Binding ElementName=UcDev, Path=DpDeviceStruct.textLogikTyp, FallbackValue=_Typ}" Margin="0,5,0,0" />
        </StackPanel>




        <DockPanel Grid.Column="1" Grid.Row="1" Width="140" HorizontalAlignment="Right">
            <!-- Für Typ "Toggle Switch". Wenn das RepeatButton dauernd gedrückt wird, wird das Event NUR EINMAL ausgeführt. -->
            <Button x:Name="btnChangeState" DockPanel.Dock="Right"
                    Style="{StaticResource CHP_AnimatedButton}"    Margin="0,0,15,0"                 
                    Width="50" Height="50" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Visibility= "{Binding ElementName=UcDev, Path=DpDeviceStruct.VisManualAllowed_ToggleSwitch }"
                    Command   = "{Binding ElementName=UcDev, Path=DpDeviceStruct.cmdManual }" 
                    BorderThickness="2" BorderBrush="Black" 
                    >
                <Image Source="{Binding ElementName=UcDev, Path=DpDeviceStruct.sManBtnPath,  FallbackValue={StaticResource DefaultManFuncImg}}"></Image>
            </Button>

            <!-- Für Typ "Push Button". Wenn das RepeatButton dauernd gedrückt wird, wird das Event DAUERND ausgeführt. -->
            <RepeatButton x:Name="repbtnChangeState"   DockPanel.Dock="Right"         
                      Background="Transparent" BorderThickness="0" Margin="0,0,15,0"                 
                    Width="45" Height="45" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Visibility= "{Binding ElementName=UcDev, Path=DpDeviceStruct.VisManualAllowed_PushButton }"
                    Command   = "{Binding ElementName=UcDev, Path=DpDeviceStruct.cmdManual }" 
                     BorderBrush="Black" 
                 >
                <Image Source="{Binding ElementName=UcDev, Path=DpDeviceStruct.sManBtnPath,  FallbackValue={StaticResource DefaultManFuncImg}}"></Image>
            </RepeatButton>

        </DockPanel>
    




        <Rectangle Grid.Row="2" Grid.ColumnSpan="2" Fill="{Binding ElementName=UcDev, Path=DpDeviceStruct.brushState , FallbackValue=Green }" 
                   StrokeThickness="1" Stroke="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,-1,0,0" />
        <TextBlock Foreground="White" Grid.Row="2" Grid.ColumnSpan="2"  Text="{Binding ElementName=UcDev, Path=DpDeviceStruct.textState, FallbackValue=Info_Zustand }" VerticalAlignment="Center" HorizontalAlignment="Center" />


    </Grid>
</UserControl>
