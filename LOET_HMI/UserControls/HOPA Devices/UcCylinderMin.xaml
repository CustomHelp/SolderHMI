<UserControl x:Class="LOET_HMI.UserControls.HOPA_Devices.UcCylinderMin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.HOPA_Devices"
             mc:Ignorable="d" 
            xmlns:prop="clr-namespace:LOET_HMI.Properties"
            x:Name="UcCyl"
             Width="300" Height="100"
             MouseLeave="UcCyl_MouseLeave" 
             MouseEnter="UcCyl_MouseEnter"
             xmlns:my="clr-namespace:LOET_HMI">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="tbStyleCyl_SensInfo" >
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>


        <Style TargetType="Grid" x:Key="SubGridMarginStyle">
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>

    </UserControl.Resources>

    <Grid x:Name="gridMain"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="69*" />
            <ColumnDefinition Width="31*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition  Height="1*"/>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Rectangle Grid.RowSpan="2"  Grid.ColumnSpan="2"  >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FFAEA9A9" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border BorderBrush="Black" BorderThickness="1" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
        <Border    BorderThickness="1" BorderBrush="Black" Margin="0,0,0,-1" />

        <Grid x:Name="grGrid1" Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <!-- INFO: FallbackValue ist nur ein DefaultWert im Designer-Ansicht. Es erleichtert den Entwurf, hat aber in der Binding keine Funktion-->
            <TextBlock Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strBMK_HMI, FallbackValue=_BMK}"  HorizontalAlignment="Left"  Margin="10,2,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Grid.Row="0"/>
            <TextBlock Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strNameHMI, FallbackValue=_Name}" HorizontalAlignment="Right" Margin="0,2,10,0"  VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Grid.Row="1"/>

        </Grid>





        <Grid Grid.Row="1" Grid.Column="0">

            
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            
            <Border BorderBrush="Black" BorderThickness="1" Grid.ColumnSpan="2" Grid.RowSpan="2"/>
            
            <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static prop:Resources.UcCyl_Restpos}" VerticalAlignment="Top"  FontSize="10" FontStyle="Italic" Margin="10,0,0,0" />
            <TextBlock Grid.Column="1" Grid.Row="0" Text="{x:Static prop:Resources.UcCyl_Forerun}" VerticalAlignment="Top" FontSize="10" FontStyle="Italic" Margin="10,0,0,0" />
            <CheckBox Grid.Row="1" Grid.Column="0" Margin="0,0,0,5" IsChecked="{Binding ElementName=UcCyl, Path=DpCylinderHMI.bValveRestHMI ,    Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource CheckboxStyle_LED_Cyl}" HorizontalAlignment="Center" VerticalAlignment="Center" >
            </CheckBox>
            <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" IsChecked="{Binding ElementName=UcCyl, Path=DpCylinderHMI.bValveForerunHMI , Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource CheckboxStyle_LED_Cyl}" HorizontalAlignment="Center" VerticalAlignment="Center" ></CheckBox>


           




            


        </Grid>
        <Button x:Name="btnChangeState" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                    Style="{StaticResource CHP_AnimatedButton}"                     
                    Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"
                    PreviewMouseDown="BtnChangeState_PreviewMouseDown"
                    Visibility= "{Binding ElementName=UcCyl, Path=DpCylinderHMI.VisManualAllowed }"
                    Command   = "{Binding ElementName=UcCyl, Path=DpCylinderHMI.cmdManual }" 
                    BorderThickness="2" BorderBrush="Black" Background="Wheat"
                    >

            <Image Source="{Binding ElementName=UcCyl, Path=DpCylinderHMI.sManBtnPath,  FallbackValue={StaticResource DefaultManFuncImg}}"></Image>
        </Button>
    </Grid>
</UserControl>
