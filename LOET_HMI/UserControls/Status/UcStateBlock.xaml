<UserControl x:Class="LOET_HMI.UserControls.UcStateBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"                    
             xmlns:t="clr-namespace:System.Windows;assembly=PresentationFramework"
             mc:Ignorable="d" 
             d:DesignHeight="154" d:DesignWidth="296">

    <UserControl.Resources>
        <t:GridLength x:Key="myGlobalGridHeight">24</t:GridLength>
        <!-- Hierfür oben hinzugefügt:    xmlns:t="clr-namespace:System.Windows;assembly=PresentationFramework"-->

        <Thickness x:Key="myGlobalMargin" Left="2" Top="2" Right="2" Bottom ="2" ></Thickness>

        <Style  TargetType="TextBlock">
            <Setter Property="Text" Value="30"/>
            <Setter Property="Foreground" Value="#FF013F84"/>
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        
    </UserControl.Resources>
    
    <Grid>
        <GroupBox Style="{StaticResource RENA_GroupBox_Style}" Header="State" HorizontalAlignment="Stretch"   VerticalAlignment="Stretch" Width="300" >
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{StaticResource myGlobalGridHeight}"/>
                    <RowDefinition Height="{StaticResource myGlobalGridHeight}"/>
                    <RowDefinition Height="{StaticResource myGlobalGridHeight}"/>
                    <RowDefinition Height="{StaticResource myGlobalGridHeight}"/>
                </Grid.RowDefinitions>

                <CheckBox x:Name="cbReady" Grid.Row="0" Grid.Column="0" Style="{StaticResource RENA_CheckboxStyle_LED}" Margin="{StaticResource myGlobalMargin}" IsHitTestVisible="False" Focusable="false" />
                <!-- IsHitTestVisible="False" Focusable="false"  verwenden, damit das Checkbox Read-Only ist, d.h. weder durch Mausclick noch durch Tastatur geändert werden können -->
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Ready" Background="#FFE5E5E5" />

                <CheckBox x:Name="cbPowerOn" Grid.Row="1" Grid.Column="0" Style="{StaticResource RENA_CheckboxStyle_LED}" Margin="{StaticResource myGlobalMargin}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Power is on" />

                <CheckBox x:Name="cbError" Grid.Row="2" Grid.Column="0" Style="{StaticResource RENA_CheckboxStyle_LED}" Margin="{StaticResource myGlobalMargin}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Error" />

                <CheckBox x:Name="cbSafetySTOActive" Grid.Row="3" Grid.Column="0" Style="{StaticResource RENA_CheckboxStyle_LED}" Margin="{StaticResource myGlobalMargin}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="Safety STO is active" />


            </Grid>
            
        </GroupBox>

    </Grid>
</UserControl>
