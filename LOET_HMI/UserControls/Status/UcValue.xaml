<UserControl x:Class="LOET_HMI.UcValue"
             x:Name="UserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded">
   
    
    
    <DockPanel>
        <DockPanel DockPanel.Dock="Top">
            <TextBlock x:Name="tblName" Text="{Binding sName, ElementName=UserControl}" Foreground="{StaticResource CHPStandartFontColor}" FontSize="{Binding dFontSize, ElementName=UserControl}" Width="Auto" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
            <TextBlock x:Name="tblUnit" Text="{Binding sUnit, ElementName=UserControl}" Foreground="{StaticResource CHPStandartFontColor}" FontSize="{Binding dFontSizeVal, ElementName=UserControl}" Width="Auto" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </DockPanel>
        <TextBox x:Name="tbValue" VerticalContentAlignment="Center" DockPanel.Dock="Bottom" FontSize="14" Height="24" Width="Auto" TextAlignment="Right" Text="{Binding sValue, ElementName=UserControl, Mode=TwoWay, StringFormat={}{0:0.00} }"  VerticalAlignment="top" PreviewKeyUp="TbValue_PreviewKeyUp"/>
    </DockPanel>
</UserControl>