<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrHeater"
             x:Name="UcHeater"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="70" Loaded="UcHeater_Loaded" >

    <Grid  >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="37"/>
            <ColumnDefinition Width="20" />

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="16"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>


        <Path Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Stroke="Black" StrokeThickness="1" Grid.Column="1">
            <Path.Data>
                <EllipseGeometry Center="{Binding ElementName=EllipseToClip, Path=Center}" 
                                 RadiusX="{Binding ElementName=EllipseToClip, Path=RadiusX}" 
                                 RadiusY="{Binding ElementName=EllipseToClip, Path=RadiusY}"/>
            </Path.Data>
            <Path.Style>
                <Style TargetType="{x:Type Path}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DpHeaterHMI.bOut, ElementName=UcHeater}" Value="True" >
                            <Setter Property="Fill" Value="{StaticResource BrushValveOn}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DpHeaterHMI.bOut, ElementName=UcHeater}" Value="False" >
                            <Setter Property="Fill" Value="{StaticResource BrushValveOff}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Path.Style>
        </Path>


        <Polyline Grid.Row="1" Grid.Column="1"   Grid.RowSpan="1" Stroke="Black" StrokeThickness="1" Stretch="Fill"   Margin="0,0,0,0"  >
            <Polyline.Points>
                <Point X="0" Y="0" />
                <Point X="1" Y="0" />
                <Point X="0.7" Y="0.3" />
                <Point X="1" Y="0.5" />
                <Point X="0.7" Y="0.7" />
                <Point X="1" Y="1" />
                <Point X="0" Y="1" />
            </Polyline.Points>
            <Polyline.Clip>
                <EllipseGeometry x:Name="EllipseToClip" Center="25,8" RadiusX="25" RadiusY="25"  />
            </Polyline.Clip>
        </Polyline>

        <TextBlock Text="{Binding ElementName=UcHeater, Path=DpHeaterHMI.sRIDesignationHMI}" 
                   Style="{StaticResource UC_RIdescr_TextStyle}" 
                   Grid.Row="2"  Grid.Column="0" Grid.ColumnSpan="3" 
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"  />

        <Border x:Name="borderClickArea" MouseDown="BorderClickArea_MouseDown"  Grid.RowSpan="3" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0.2" Background="Gray" Margin="0,0,0,2" />



    </Grid>
</UserControl>
