<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcSwitchSymbol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 
             d:DesignHeight="44.752" d:DesignWidth="48.805">
    <Grid Width="25" Height="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="7.5"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Rectangle Stroke="Black" StrokeThickness="0.5" Fill="White" Grid.ColumnSpan="3" Grid.RowSpan="3" />

        <Line Grid.Row="1" Grid.Column="1" Stroke="Black" X2="1" StrokeThickness="0.5" Stretch="Fill" VerticalAlignment="Top"   StrokeEndLineCap="Round"   StrokeStartLineCap="Round"  />
        <Line Grid.Row="1" Grid.Column="1" Stroke="Black" X2="1" StrokeThickness="0.5" Stretch="Fill" VerticalAlignment="Bottom" StrokeEndLineCap="Round"   StrokeStartLineCap="Round"  />

        <Line Grid.Row="1" Grid.Column="1" Stroke="Black" Y2="1" StrokeThickness="3" Stretch="Fill" HorizontalAlignment="Left"  StrokeEndLineCap="Square"   StrokeStartLineCap="Square" Margin="3,0,0,0" />
        <Line Grid.Row="1" Grid.Column="1" Stroke="Black" Y2="1" StrokeThickness="3" Stretch="Fill" HorizontalAlignment="Right"  StrokeEndLineCap="Square"   StrokeStartLineCap="Square" Margin="0,0,3,0" />


    </Grid>
</UserControl>
