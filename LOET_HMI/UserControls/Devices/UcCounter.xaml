<UserControl x:Class="LOET_HMI.UserControls.UcCounter"
             x:Name="UcCount"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             Width="300" Height="150" 
             xmlns:LOET ="clr-namespace:LOET_HMI"
             >

    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}" >
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="FontSize" Value="12"  />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="FontSize" Value="12"  />
        </Style>
    </UserControl.Resources>
    
    
    <Grid x:Name="gridMain"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition  Width="300"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.RowSpan="3"  Grid.ColumnSpan="2"  >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FFAEA9A9" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border    BorderThickness="1" BorderBrush="Black" Margin="0,0,0,-1" />

        <Grid x:Name="grGrid1" Grid.Row="0" >
            <!-- INFO: FallbackValue ist nur ein DefaultWert im Designer-Ansicht. Es erleichtert den Entwurf, hat aber in der Binding keine Funktion-->
            <TextBlock Text="{Binding ElementName=UcCount, Path=DpCounterHMI.sName,         FallbackValue=_Name}" HorizontalAlignment="Center" Margin="0,4,10,0"  VerticalAlignment="Top" FontSize="18" FontWeight="Bold" />
            <TextBlock Text="{Binding ElementName=UcCount, Path=DpCounterHMI.sDescription,  FallbackValue=_Description}" HorizontalAlignment="Center" Margin="0,0,10,2"  VerticalAlignment="Bottom"  />

        </Grid>

        <Grid x:Name="grGrid2" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>

            <Border  Grid.Row="0" Grid.ColumnSpan="3" BorderThickness="1" BorderBrush="Black" />


            <!-- *************************************************************** -->
            <!-- ***************** Beschriftungen PLC-TO-HMI *******************-->
            <!-- *************************************************************** -->
            <StackPanel Grid.Column="0" Margin="10,10,10,0" HorizontalAlignment="Left" UseLayoutRounding="True" >

                <StackPanel x:Name="spLeft_TypeTotal"  >
                    <TextBlock Text="Total:"  />

                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_10_Total_ShowDetail }">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_11_Total_DontShowDetail }">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_20_Act }">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>

                <StackPanel x:Name="spLeft_TypeTotal_Detail"  >
                    <TextBlock Text="i.O.:"           />
                    <TextBlock Text="n.i.O.:"         />
                    <TextBlock Text="Quote:"    />

                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_10_Total_ShowDetail }">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_11_Total_DontShowDetail }">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_20_Act }">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>

                <StackPanel x:Name="spLeft_TypeAct" Grid.Column="0" >
                    <TextBlock Text="Aktuell:" />
                    <TextBlock Text="Ziel:" />

                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_10_Total_ShowDetail }">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_11_Total_DontShowDetail }">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.eType}" Value="{x:Static LOET:eCounterType.CT_20_Act }">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>
            </StackPanel>

            <!-- *************************************************************** -->
            <!-- ************************  Werte PLC-TO-HMI********************* -->
            <!-- *************************************************************** -->
            <StackPanel  Grid.Column="1"  Margin="0,10,20,0">
                <StackPanel x:Name="spRight_TypeTotal"  Visibility="{Binding ElementName=spLeft_TypeTotal, Path=Visibility}">
                    <TextBlock x:Name="tbTotal"     Text="{Binding ElementName=UcCount,Path=DpCounterHMI.uiTotal,       FallbackValue=valueTotal}" />
                </StackPanel>

                <StackPanel x:Name="spRight_TypeTotal_Detail" Visibility="{Binding ElementName=spLeft_TypeTotal_Detail, Path=Visibility}">
                    <TextBlock x:Name="tbIO"        Text="{Binding ElementName=UcCount,Path=DpCounterHMI.uiIO,          FallbackValue=valueIO}" />
                    <TextBlock x:Name="tbNIO"       Text="{Binding ElementName=UcCount,Path=DpCounterHMI.uiNIO,         FallbackValue=valueNIO}"/>
                    <TextBlock x:Name="tbQuote" Text="{Binding ElementName=UcCount,Path=DpCounterHMI.flQuote,      FallbackValue=valueQuote, StringFormat={}{0}%}"/>
                </StackPanel>

                <StackPanel x:Name="spRight_TypeAct" Visibility="{Binding ElementName=spLeft_TypeAct, Path=Visibility}">
                    <TextBlock x:Name="tbAct"       Text="{Binding ElementName=UcCount,Path=DpCounterHMI.uiAct,         FallbackValue=valueTotal}" Margin="3,0,0,0"/>
                    <TextBox   x:Name="tbTarget"    Text="{Binding ElementName=UcCount,Path=DpCounterHMI.uiTarget,      FallbackValue=valuetarget}"  PreviewMouseUp="TbTarget_PreviewMouseUp" />
                </StackPanel>
            </StackPanel>


            <!-- *************************************************************** -->
            <!-- ************************ Reset ******************************** -->
            <!-- *************************************************************** -->
            <Button x:Name="btnReset" Grid.Column="2" Margin="0,0,10,10" VerticalAlignment="Bottom" Height="60" Content="Reset"  Click="BtnReset_Click"
                    Command   = "{Binding ElementName=UcCount, Path=DpCounterHMI.cmdReset }" 
                    >
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.bEnableReset }" Value="true" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding ElementName=UcCount, Path=DpCounterHMI.bEnableReset }" Value="false" >
                                <Setter Property="Visibility" Value="Hidden" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>


        </Grid>

    </Grid>
</UserControl>
