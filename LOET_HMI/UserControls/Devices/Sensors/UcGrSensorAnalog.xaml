<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrSensorAnalog"
             x:Name="UcSensorAnalog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 
             
                          
             xmlns:mscorlib="clr-namespace:System;assembly=mscorlib" 
             Style="{StaticResource UcGrSensorStyle}" >
    
    <UserControl.Resources>
        <local:ObjectToTypeStringConverter x:Key="ObjectToTypeString" />
    </UserControl.Resources>

    <Grid Margin="0,0,5,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Rectangle Grid.RowSpan="2" Fill="{StaticResource UcGrBrushOff}"  >
            <Rectangle.Style >
                <Style  TargetType="{x:Type Rectangle}" BasedOn="{StaticResource UcGrSensorRectOvalStyle}" >
                    <Style.Triggers>


                        <!--  Farben rausgenommen
                        <DataTrigger Binding="{Binding DpSensorAnalog.iStateHMI, ElementName=UcSensorAnalog}" Value="0" >
                            <Setter Property="Fill" Value="{StaticResource UcGrBrushOff}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DpSensorAnalog.iStateHMI, ElementName=UcSensorAnalog}" Value="1" >
                            <Setter Property="Fill" Value="{StaticResource UcGrBrushOn}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DpSensorAnalog.iStateHMI, ElementName=UcSensorAnalog}" Value="2" >
                            <Setter Property="Fill" Value="Red" />
                        </DataTrigger>
                        -->
                        
                        
                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <Line Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Stretch" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" X1="0" Y1="0" X2="100" Y2="0" Stretch="Uniform"  />

        <TextBlock x:Name="tbRectUp"   Text="{Binding ElementName=UcSensorAnalog, Path=DpSensorAnalog.sFunctionHMI}" Grid.Row="0"  Style="{StaticResource UcGrSensorTextBlockStyleOval}" />
        <TextBlock x:Name="tbRectDown" Text="{Binding ElementName=UcSensorAnalog, Path=DpSensorAnalog.sRIDesignationHMI}"  Grid.Row="1" Style="{StaticResource UcGrSensorTextBlockStyleOval}" />

        <Border  Grid.Row="2" Style="{StaticResource UcGrSensorBorderStyle}">
            <TextBlock x:Name="tbValue"  Style="{StaticResource UcGrSensorTextBlockStyleRect}"  >                            
                <Run Text="{Binding DpSensorAnalog.ValHMI, ElementName=UcSensorAnalog, StringFormat=N3}"/>            
                <Run Text="{Binding DpSensorAnalog.sUnitHMI, ElementName=UcSensorAnalog}"/>
            </TextBlock>
        </Border>

    </Grid>


</UserControl>
