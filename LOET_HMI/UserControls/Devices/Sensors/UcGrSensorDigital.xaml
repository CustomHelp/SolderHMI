<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrSensorDigital"
             x:Name="UcSensorDigital"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" MouseDown="UcSensorDigital_MouseDown"  Style="{StaticResource UcGrSensorStyle}" Height="42.449" >

    <Grid Margin="0,0,5,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Rectangle Grid.RowSpan="2"  >
            <Rectangle.Style >
                <Style  TargetType="{x:Type Rectangle}" BasedOn="{StaticResource UcGrSensorRectOvalStyle}" >
                    <Style.Triggers>

                        <!-- Digital Input "Normal": 1 (grün) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=DpSensorBOOL_HMI.ValHMI}" Value="True"  />
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=IsAlarm}" Value="False"  />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Fill" Value="{StaticResource UcGrBrushOn}" />
                        </MultiDataTrigger>

                        <!-- Digital Input "Normal": 0 (grau) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=DpSensorBOOL_HMI.ValHMI}" Value="False"  />
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=IsAlarm}" Value="False"  />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Fill" Value="{StaticResource UcGrBrushOff}" />
                        </MultiDataTrigger>

                        <!-- Digital Input "Alarm": 1 (rot) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=DpSensorBOOL_HMI.ValHMI}" Value="True"  />
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=IsAlarm}" Value="True"  />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Fill" Value="Red" />
                        </MultiDataTrigger>

                        <!-- Digital Input "Alarm": 0 (grau) -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=DpSensorBOOL_HMI.ValHMI}" Value="False"  />
                                <Condition Binding="{Binding  ElementName=UcSensorDigital, Path=IsAlarm}" Value="True"  />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Fill" Value="{StaticResource UcGrBrushOff}" />
                        </MultiDataTrigger>


                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <Line Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Stretch" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" X1="0" Y1="0" X2="100" Y2="0" Stretch="Uniform"  />

        <TextBlock x:Name="tbRectUp"   Text="{Binding ElementName=UcSensorDigital, Path=DpSensorBOOL_HMI.sFunctionHMI}" Grid.Row="0"  Style="{StaticResource UcGrSensorTextBlockStyleOval}" />
        <TextBlock x:Name="tbRectDown" Text="{Binding ElementName=UcSensorDigital, Path=DpSensorBOOL_HMI.sRIDesignationHMI}"  Grid.Row="1" Style="{StaticResource UcGrSensorTextBlockStyleOval}" />

        

    </Grid>

</UserControl>
