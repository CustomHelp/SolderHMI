<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcGrCylinder"
             x:Name="GrCylinder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             Loaded="GrCylinder_Loaded"
                                       
             xmlns:ikriv="clr-namespace:IKriv.Wpf"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="120" Height="auto" Width="auto" RenderTransformOrigin="0.5, 0.5"  >


    <UserControl.Resources >
        <SolidColorBrush x:Key="BrushValveOn" Color="LawnGreen" />
        <SolidColorBrush x:Key="BrushValveOff" Color="LightGray" />

        <BitmapImage x:Key="MyImageSource" UriSource="\\CHPSERVER\Ordnerumleitung\m.balog\Documents\Expression\Expression Design\PressWerkzeug2_90Grad.tif" />



    </UserControl.Resources>

    <UserControl.RenderTransform>
        <RotateTransform Angle="-0" />
    </UserControl.RenderTransform>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0, 0.5" >
        <Grid.RowDefinitions>
            <RowDefinition x:Name="Row0" Height="auto"/>
            <RowDefinition x:Name="Row1" Height="70"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="Col0" Width="{Binding ElementName=rectCylFrame, Path=Width}"/>
            <ColumnDefinition x:Name="Col1" Width="auto"/>
        </Grid.ColumnDefinitions>


        <Grid.RenderTransform>
            <RotateTransform  Angle="0" />
        </Grid.RenderTransform>


        <Grid x:Name="grid_tbCylName" Grid.Row="2" Grid.Column="1"  HorizontalAlignment="Left" Width="{Binding ElementName=rectCylFrame, Path=Width}" >
            <TextBlock x:Name="tbCylName"  Grid.Row="2" Grid.Column="1"    HorizontalAlignment="Center"  Text="{Binding DpCylinderHMI.sCylNameHMI, ElementName=GrCylinder}" MinWidth="10"   FontSize="11" />

        </Grid>
        

        <Grid x:Name="gridOfSens" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"  HorizontalAlignment="Left" VerticalAlignment="Top" Width="76" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="col0GridSens" Width="13"/>
                <ColumnDefinition x:Name="col1GridSens" Width="{Binding ElementName=col0GridSens, Path=Width}"/>
                <ColumnDefinition x:Name="col2GridSens" Width="10"/>
                <!--   HINWEIS: Diese Spalte wird im Code automatisch der Breite des Zyliders angepasst -->
                <ColumnDefinition x:Name="col3GridSens" Width="{Binding ElementName=col0GridSens, Path=Width}" />
                <ColumnDefinition x:Name="col4GridSens" Width="{Binding ElementName=col0GridSens, Path=Width}"/>
                <ColumnDefinition x:Name="col5GridSens" Width="{Binding ElementName=col0GridSens, Path=Width}"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="row0_gridOfText" Height="10"/>
                <RowDefinition x:Name="row1_gridOfText" Height="30"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="tbSensAname"  Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" MinWidth="20" HorizontalAlignment="Left" VerticalAlignment="Bottom"  Text="{Binding ElementName=GrCylinder, Path=DpCylinderHMI.sSensorNameAHMI}"  Margin="0"   >
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90" />
                </TextBlock.LayoutTransform>
                <TextBlock.Style >
                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource UC_RIdescr_TextStyle}" >
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasRestPosHMI, ElementName=GrCylinder}" Value="True" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasRestPosHMI, ElementName=GrCylinder}" Value="False" >
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock x:Name="tbSensBname"   Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" MinWidth="20" HorizontalAlignment="Center" VerticalAlignment="Bottom"  Text="{Binding ElementName=GrCylinder, Path=DpCylinderHMI.sSensorNameBHMI}"  Margin="0" >
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90" />
                </TextBlock.LayoutTransform>
                <TextBlock.Style >
                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource UC_RIdescr_TextStyle}" >
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasRestPosHMI, ElementName=GrCylinder}" Value="True" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasRestPosHMI, ElementName=GrCylinder}" Value="False" >
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid x:Name="gridSensA" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" >
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasRestPosHMI, ElementName=GrCylinder}" Value="True" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasRestPosHMI, ElementName=GrCylinder}" Value="False" >
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Rectangle x:Name="rectSensRestPos"   HorizontalAlignment="Stretch" VerticalAlignment="Bottom"  Height="30"  StrokeThickness="1" Stroke="Black"  >
                    <!-- Margin wird im C#-Code angepasst -->
                    <Rectangle.Style>
                        <Style  TargetType="{x:Type Rectangle}" >
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DpCylinderHMI.bRestPosHMI, ElementName=GrCylinder}" Value="True" >
                                    <Setter Property="Fill" Value="{StaticResource BrushValveOn}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DpCylinderHMI.bRestPosHMI, ElementName=GrCylinder}" Value="False" >
                                    <Setter Property="Fill" Value="{StaticResource BrushValveOff}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <Rectangle x:Name="rectArrowSensA" Margin="2,0,2,2">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/ArrowSens01.png" Stretch="Uniform"/>
                    </Rectangle.Fill>
                </Rectangle>

            </Grid >


            <Grid x:Name="gridSensB" Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" >
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasForerunPosHMI, ElementName=GrCylinder}" Value="True" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCylinderHMI.bHasForerunPosHMI, ElementName=GrCylinder}" Value="False" >
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Rectangle x:Name="rectSensForerunPos"   StrokeThickness="1" Stroke="Black" 
                           HorizontalAlignment="{Binding ElementName=rectSensRestPos, Path=HorizontalAlignment}" 
                           VerticalAlignment="{Binding ElementName=rectSensRestPos, Path=VerticalAlignment}"  
                           Height="{Binding ElementName=rectSensRestPos, Path=Height}"    
                            >
                    <!-- Margin wird im C#-Code angepasst -->
                    <Rectangle.Style>
                        <Style  TargetType="{x:Type Rectangle}" >
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DpCylinderHMI.bForerunPosHMI, ElementName=GrCylinder}" Value="True" >
                                    <Setter Property="Fill" Value="{StaticResource BrushValveOn}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DpCylinderHMI.bForerunPosHMI, ElementName=GrCylinder}" Value="False" >
                                    <Setter Property="Fill" Value="{StaticResource BrushValveOff}" />
                                </DataTrigger>


                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <Rectangle x:Name="rectArrowSensB" Margin="{Binding ElementName=rectArrowSensA, Path=Margin}">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/LOET_HMI;component/Images/ArrowSens01.png" Stretch="Uniform"/>
                    </Rectangle.Fill>
                </Rectangle>



            </Grid>
        </Grid>









        <Grid  HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="28" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" >

            <Grid Grid.Row="0" HorizontalAlignment="Left" Width="{Binding ElementName=rectCylFrame, Path=Width}" Panel.ZIndex="30" >

                <Rectangle x:Name="rectValveOn" Grid.Column="0"   Width="24" Fill="{StaticResource BrushValveOn}" HorizontalAlignment="Right"  Margin="0,1,3,1" >
                    <!-- Die Initialwerte für die "Fill", "Horizontal Alignment" und "Margin" werden nach dem Laden gelöscht -->
                    <Rectangle.Style>
                        <Style TargetType="Rectangle" >
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DpCylinderHMI.bValveForerunHMI, ElementName=GrCylinder}" Value="True"  />
                                        <Condition Binding="{Binding DpCylinderHMI.bValveRestHMI, ElementName=GrCylinder}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Fill" Value="{StaticResource BrushValveOn}" />
                                    <Setter Property="Stroke" Value="Black" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                </MultiDataTrigger>

                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DpCylinderHMI.bValveForerunHMI, ElementName=GrCylinder}" Value="False"  />
                                        <Condition Binding="{Binding DpCylinderHMI.bValveRestHMI, ElementName=GrCylinder}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Fill" Value="{StaticResource BrushValveOn}" />
                                    <Setter Property="Stroke" Value="Black" />
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                </MultiDataTrigger>

                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DpCylinderHMI.bValveForerunHMI, ElementName=GrCylinder}" Value="False"  />
                                        <Condition Binding="{Binding DpCylinderHMI.bValveRestHMI, ElementName=GrCylinder}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Fill" Value="Transparent" />
                                    <Setter Property="Stroke" Value="Transparent" />
                                </MultiDataTrigger>

                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>



            </Grid>




            <Rectangle x:Name="rectCylFrame"  HorizontalAlignment="Left"  Width="75" Stroke="Black" VerticalAlignment="Stretch" StrokeThickness="1" Panel.ZIndex="25"
                      >



                <Rectangle.Style>
                    <Style  TargetType="{x:Type Rectangle}" >
                        <Setter Property="Fill"  >
                            <Setter.Value>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#FFA8A7A7" Offset="0"/>
                                    <GradientStop Color="#FFA8A7A7" Offset="1"/>
                                    <GradientStop Color="#FFFBFBFB" Offset="0.5"/>
                                </LinearGradientBrush>
                            </Setter.Value>

                        </Setter>

                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <Grid x:Name="grGridToMove" HorizontalAlignment="Left"  Panel.ZIndex="30"  >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ToMoveCol0" Width="77" />
                    <ColumnDefinition x:Name="ToMoveCol1" Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="RowOfGrToMove" Height="*" />
                </Grid.RowDefinitions>

                <Grid.Style >
                    <Style  TargetType="{x:Type Grid}" >
                        <Style.Triggers>

                            <!-- Die Margin-Werte GridToMoveForerunPos und GridToMoveMiddlePos werden in C#-Code berechnet -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <!-- Zylinder ist ausgefahren-->
                                    <Condition Binding="{Binding DpCylinderHMI.bForerunPosHMI, ElementName=GrCylinder}" Value="True"  />
                                    <Condition Binding="{Binding DpCylinderHMI.bRestPosHMI, ElementName=GrCylinder}" Value="False" />
                                    <Condition Binding="{Binding IsMovable, ElementName=GrCylinder}" Value="True" />

                                </MultiDataTrigger.Conditions>
                                <Setter Property="Margin" Value="{Binding ElementName=GrCylinder, Path=GridToMoveForerunPos}"/>
                            </MultiDataTrigger>


                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <!-- Zylinder ist in Ruhelage -->
                                    <Condition Binding="{Binding DpCylinderHMI.bForerunPosHMI, ElementName=GrCylinder}" Value="False"  />
                                    <Condition Binding="{Binding DpCylinderHMI.bRestPosHMI, ElementName=GrCylinder}" Value="True" />
                                    <Condition Binding="{Binding IsMovable, ElementName=GrCylinder}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Margin" Value="0,0,0,0"/>
                            </MultiDataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <!-- Zylinder ist zwischen den beiden Endpositionen -->
                                    <Condition Binding="{Binding DpCylinderHMI.bForerunPosHMI, ElementName=GrCylinder}" Value="False"  />
                                    <Condition Binding="{Binding DpCylinderHMI.bRestPosHMI, ElementName=GrCylinder}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Margin" Value="{Binding ElementName=GrCylinder, Path=GridToMoveMiddlePos}"/>
                            </MultiDataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <!-- Zylinder ist zwischen den beiden Endpositionen -->
                                    <Condition Binding="{Binding IsMovable, ElementName=GrCylinder}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Margin" Value="{Binding ElementName=GrCylinder, Path=GridToMoveMiddlePos}"/>
                            </MultiDataTrigger>


                        </Style.Triggers>
                    </Style>

                </Grid.Style>


                <Rectangle x:Name="rectPiston" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" Stroke="Black" Fill="Black" VerticalAlignment="Stretch"  Width="10" StrokeThickness="1"  />

                <Rectangle x:Name="rectPistonRod" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="8" Stroke="Black" Fill="Black" StrokeThickness="1"  Margin="0,9,0,8" />


                <!-- Source="LOET_HMI/Images/Presswerkzeug3.PNG"-->
                <Image x:Name="ImageNextToCyl" Source="/LOET_HMI;component/UserControls/Devices/_Images/Presswerkzeug6.PNG" Grid.Column="1" Grid.Row="0"  HorizontalAlignment="Left" VerticalAlignment="Center"  Stretch="Fill" Height="{Binding ElementName=rectCylFrame, Path=Height}" Width="70" >
                    <Image.Style>
                        <Style TargetType="{x:Type Image}" >
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=GrCylinder, Path=ImageNextToCylVisbilityTrueFalse}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=GrCylinder, Path=ImageNextToCylVisbilityTrueFalse}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>


                <!-- HINWEIS: 
                btnManFunc wird im C#-Code zum Start deaktiviert. 
                Bei RENA wird die Handfunktion über den UserControl "UcGrCylControl" ausgeführt. -->
                <Button x:Name="btnManFunc" Opacity="1" BorderThickness="0"    Foreground="Red" FontSize="10" HorizontalAlignment="Left" Width="25"                       
                        Command   = "{Binding ElementName=GrCylinder, Path=DpCylinderHMI.cmdManual}" Margin="25,2,24,2"
                        Visibility="{Binding ElementName=GrCylinder, Path=DpCylinderHMI.VisManualAllowed}">
                    <Button.Background>
                        <ImageBrush ImageSource="/LOET_HMI;component/Resources/Manual Mode_White.png" Stretch="Uniform"/>
                    </Button.Background>
                </Button>








            </Grid>

        </Grid>
    </Grid>
</UserControl>
