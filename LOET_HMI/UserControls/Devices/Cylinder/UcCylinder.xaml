<UserControl x:Class="LOET_HMI.UserControls.UcCylinder"
             x:Name="UcCyl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls"
             mc:Ignorable="d" 
             xmlns:prop="clr-namespace:LOET_HMI.Properties"

             Width="300" Height="180"

              MouseLeave="UcCyl_MouseLeave" 
             MouseEnter="UcCyl_MouseEnter"
             xmlns:my="clr-namespace:LOET_HMI"
             
             >
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="tbStyleCyl_SensInfo" >
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>


        <Style TargetType="Grid" x:Key="SubGridMarginStyle">
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>

    </UserControl.Resources>


    <Grid x:Name="gridMain"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="100" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition  Width="300"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.RowSpan="3"  Grid.ColumnSpan="2"  >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFF0F0F0"/>
                    <GradientStop Color="#FFAEA9A9" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border    BorderThickness="1" BorderBrush="Black" Margin="0,0,0,-1" />

        <Grid x:Name="grGrid1" Grid.Row="0" >
            <!-- INFO: FallbackValue ist nur ein DefaultWert im Designer-Ansicht. Es erleichtert den Entwurf, hat aber in der Binding keine Funktion-->
            <TextBlock Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strBMK_HMI, FallbackValue=_BMK}"  HorizontalAlignment="Left"  Margin="10,10,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" />
            <TextBlock Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strNameHMI, FallbackValue=_Name}" HorizontalAlignment="Right" Margin="0,10,10,0"  VerticalAlignment="Top" FontSize="16" FontWeight="Bold" />
            <TextBlock Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strDescriptionHMI, FallbackValue=_Description}" HorizontalAlignment="Right" Margin="0,0,10,2"  VerticalAlignment="Bottom" FontSize="12" />

        </Grid>





        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="69*" />
                <ColumnDefinition Width="31*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border  Grid.Row="0"  BorderThickness="1" BorderBrush="Black" />
            <Border  Grid.Row="1"  BorderThickness="1" BorderBrush="Black" Margin="0,-1,0,0"/>
            <Border  Grid.Row="0"  BorderThickness="1" BorderBrush="Black" Margin="-1,0,0,0"   Grid.Column="1" Grid.RowSpan="2"  />


            <TextBlock Grid.Row="0" Text="{x:Static prop:Resources.UcCyl_Restpos}" VerticalAlignment="Top"     FontSize="10" FontStyle="Italic" Margin="10,0,0,0" />
            <TextBlock Grid.Row="1" Text="{x:Static prop:Resources.UcCyl_Forerun}" VerticalAlignment="Stretch" FontSize="10" FontStyle="Italic" Margin="10,0,0,0" />



            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Orientation="Horizontal" >
                <!-- Text (aktuell inaktiv, Breite=0)-->
                <Grid x:Name="grPosName" Width="0" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ruhelage" Grid.Row="0" VerticalAlignment="Center" FontSize="14" FontStyle="Italic"/>
                    <TextBlock Text="Vorlauf"  Grid.Row="1" VerticalAlignment="Center" FontSize="14" FontStyle="Italic"/>
                </Grid>

                <!-- Ventile -->
                <Grid x:Name="grValveLEDs">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" Margin="0,10,0,0" IsChecked="{Binding ElementName=UcCyl, Path=DpCylinderHMI.bValveRestHMI ,    Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource CheckboxStyle_LED_Cyl}" HorizontalAlignment="Center"  >
                        <GroupBox Header="GroupBox" Height="100" Width="100"/>
                    </CheckBox>
                    <CheckBox Grid.Row="1" Margin="0,10,0,0" IsChecked="{Binding ElementName=UcCyl, Path=DpCylinderHMI.bValveForerunHMI , Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource CheckboxStyle_LED_Cyl}" HorizontalAlignment="Center"  ></CheckBox>

                </Grid>

                <!-- LED Sensoren  -->
                <Grid x:Name="grSensLEDs" Width="50">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,0" 
                              Style="{DynamicResource CheckboxStyle_LED_Cyl}"
                              Visibility ="{Binding ElementName=UcCyl, Path=DpCylinderHMI.VisHasRestPos    }"
                              IsChecked  ="{Binding ElementName=UcCyl, Path=DpCylinderHMI.bRestPosHMI  , Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                >
                    </CheckBox>

                    <CheckBox Grid.Row="1" HorizontalAlignment="Center" Margin="0,10,0,0" 
                              Style="{DynamicResource CheckboxStyle_LED_Cyl}" 
                              Visibility="{Binding ElementName=UcCyl, Path=DpCylinderHMI.VisHasForerunPos }"  
                              IsChecked ="{Binding ElementName=UcCyl, Path=DpCylinderHMI.bForerunPosHMI  , Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                              >
                    </CheckBox>
                </Grid>


                <!-- BMK-Sensor und Sensorzeit -->
                <Grid x:Name="grSensInfo">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />

                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock   x:Name="tbBMK_SensA" Grid.Row="0"
                             Style  ="{StaticResource tbStyleCyl_SensInfo}"
                             Text   ="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strSensor_BMK_A_HMI, FallbackValue=BMK_A}" 
                             VerticalAlignment="Bottom"    
                                 >
                        </TextBlock>


                        <TextBlock   x:Name="tbTimeRestPos" Grid.Row="1"
                             Style      ="{StaticResource tbStyleCyl_SensInfo}"
                             Text       ="{Binding DpCylinderHMI.sTextRestPosTime, ElementName=UcCyl, FallbackValue=T#Rest}"
                             Visibility ="{Binding DpCylinderHMI.VisHasRestPos,    ElementName=UcCyl}" 
                             VerticalAlignment="Top"   
                                 >
                        </TextBlock>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock   x:Name="tbBMK_SensB" Grid.Row="0"
                             Style  ="{StaticResource tbStyleCyl_SensInfo}"
                             Text   ="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strSensor_BMK_B_HMI, FallbackValue=BMK_B}" 
                             VerticalAlignment="Bottom"   
                                 >
                        </TextBlock>


                        <TextBlock  x:Name="tbTimeForerun" Grid.Row="1"
                            Style        ="{StaticResource tbStyleCyl_SensInfo}"
                            Text         ="{Binding Path=DpCylinderHMI.sTextForerunTime, ElementName=UcCyl, FallbackValue=T#Fore}" 
                            Visibility   ="{Binding DpCylinderHMI.VisHasForerunPos, ElementName=UcCyl}" 
                            VerticalAlignment="Top"   
                                >
                        </TextBlock>


                    </Grid>





                </Grid>

            </StackPanel>




            <Button x:Name="btnChangeState" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                    Style="{StaticResource CHP_AnimatedButton}"                     
                    Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"
                    PreviewMouseDown="BtnChangeState_PreviewMouseDown"
                    Visibility= "{Binding ElementName=UcCyl, Path=DpCylinderHMI.VisManualAllowed }"
                    Command   = "{Binding ElementName=UcCyl, Path=DpCylinderHMI.cmdManual }" 
                    BorderThickness="2" BorderBrush="Black" Background="Wheat"
                    >

                <Image Source="{Binding ElementName=UcCyl, Path=DpCylinderHMI.sManBtnPath,  FallbackValue={StaticResource DefaultManFuncImg}}"></Image>
            </Button>

            <TextBlock x:Name="tbSlideCyl"  Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                       HorizontalAlignment="Stretch"  TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource CHPStandartFontColor}"
                        Margin="0,10,0,0"
                    Visibility="{Binding ElementName=UcCyl, Path=DpCylinderHMI.VisIsSlide     }" FontSize="12" >
                <Run Text="{x:Static prop:Resources.UcCyl_SlideCylOf}"  />
                <Run Text=" "  />
                <Run Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.strSideCylCommentHMI, FallbackValue=_BMKNebenZyl}" />
            </TextBlock>


            <!-- 
            <Button x:Name="btnChangeState" Grid.Column="1" Width="50" Height="50" >
                <Button.Resources>
                    <DataTemplate x:Key="Unpressed" >
                        <Image Source="/LOET_HMI;component/Resources/Manual Mode.png"/>
                    </DataTemplate>
                    <DataTemplate x:Key="Pressed" >
                        <Image Source="/LOET_HMI;component/Resources/Manual Mode - Select.png" />
                    </DataTemplate>
                </Button.Resources>

                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource CHP_AnimatedButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DpCyl.bManualAllowedHMI, ElementName=UcCyl, FallbackValue=True }" Value="True" >
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DpCyl.bManualAllowedHMI, ElementName=UcCyl, FallbackValue=True }" Value="False" >
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            



                        </Style.Triggers>
                    </Style>
            
                </Button.Style>
               
                
            </Button>
            -->

            <!--  
                                        <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCyl, FallbackValue={StaticResource DefaultManFuncImg}}" Value="False" >
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <Image Source="/LOET_HMI;component/Resources/Manual Mode.png" Stretch="Uniform" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCyl, FallbackValue={StaticResource DefaultManFuncImg} }" Value="True" >
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <Image Source="/LOET_HMI;component/Resources/Manual Mode - Select.png" Stretch="Uniform" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
            
            -->


            <!-- 
                                        <Trigger Property="IsPressed" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource Pressed}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="False">
                                <Setter Property="ContentTemplate" Value="{StaticResource Unpressed}"/>
                            </Trigger>
            -->

            <!--
                                        <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCyl, FallbackValue={StaticResource DefaultManFuncImg}}" Value="False" >
                                <Setter Property="ContentTemplate" Value="{StaticResource Unpressed}" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding DpCyl.bManOnHMI, ElementName=UcCyl, FallbackValue={StaticResource DefaultManFuncImg}}" Value="True" >
                                <Setter Property="ContentTemplate" Value="{StaticResource Pressed}" />
                            </DataTrigger>
            -->


        </Grid>




        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                BorderBrush="{Binding ElementName=UcCyl, Path=DpCylinderHMI.brushState }" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
            <TextBlock Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.textState, FallbackValue=Info_Zustand }" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </Border>

        <Rectangle Grid.Row="2" Grid.ColumnSpan="2" Fill="{Binding ElementName=UcCyl, Path=DpCylinderHMI.brushState, FallbackValue=Green }" 
                   StrokeThickness="1" Stroke="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,-1,0,0" />
        <TextBlock Foreground="White" Grid.Row="2" Grid.ColumnSpan="2"  Text="{Binding ElementName=UcCyl, Path=DpCylinderHMI.textState, FallbackValue=Info_Zustand }" VerticalAlignment="Center" HorizontalAlignment="Center" />


        <!-- 
        <TextBlock Grid.Row="2" Grid.ColumnSpan="2"  HorizontalAlignment="Center" VerticalAlignment="Center"  >
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DpCyl.eStateHMI, ElementName=UcCyl, FallbackValue=Infozeile}" Value="CS_00_Normal" >
                            <Setter Property="Text" Value="Zustand: Normal"   />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding DpCyl.eStateHMI, ElementName=UcCyl, FallbackValue=Infozeile}" Value="20" >
                            <Setter Property="Text" Value="Zustand: OK" />
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
       -->



    </Grid>
</UserControl>
