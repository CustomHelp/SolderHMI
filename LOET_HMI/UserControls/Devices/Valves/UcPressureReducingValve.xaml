<UserControl x:Class="LOET_HMI.UserControls.Graphical_UCs.UcPressureReducingValve"
             Name="UcPressRedValve"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LOET_HMI.UserControls.Graphical_UCs"
             mc:Ignorable="d" 
             d:DesignHeight="50.438"  >

    <Grid Margin="0,0,0,5" Width="50" Height="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Rectangle Grid.Row="1"   >
            <Rectangle.Fill>
                <ImageBrush ImageSource="/LOET_HMI;component/Images/Druckminderer.png" Stretch="Uniform"/>
            </Rectangle.Fill>
        </Rectangle>

        <TextBlock 
                   Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Top"
                   Grid.Column="1"  
                   Text="{Binding ElementName=UcPressRedValve, Path=OutputPressure}" Margin="-5,0,5,0"
                   FontSize="10"
                    Style="{StaticResource UC_RIdescr_TextStyle}"/>

        <TextBlock 
                   Grid.Column="0"  
                    Grid.Row="1"
                   Text="{Binding ElementName=UcPressRedValve, Path=ValveName}" Margin="-5,25,5,0"
                   Style="{StaticResource UC_RIdescr_TextStyle}" Grid.RowSpan="2" />

    </Grid>
</UserControl>
